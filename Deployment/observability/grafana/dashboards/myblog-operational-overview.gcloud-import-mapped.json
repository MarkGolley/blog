{
    "id":  null,
    "uid":  "myblog-ops-overview",
    "title":  "MyBlog Operational Overview",
    "tags":  [
                 "myblog",
                 "operations",
                 "observability"
             ],
    "timezone":  "browser",
    "schemaVersion":  39,
    "version":  1,
    "refresh":  "10s",
    "time":  {
                 "from":  "now-3h",
                 "to":  "now"
             },
    "templating":  {
                       "list":  [
                                    {
                                        "name":  "service",
                                        "label":  "Service",
                                        "type":  "custom",
                                        "query":  "myblog-app,myblog-blog,myblog-aislepilot",
                                        "current":  {
                                                        "text":  "myblog-app",
                                                        "value":  "myblog-app"
                                                    },
                                        "includeAll":  true,
                                        "allValue":  ".*",
                                        "multi":  true
                                    }
                                ]
                   },
    "panels":  [
                   {
                       "id":  1,
                       "title":  "Request Rate (req/s)",
                       "type":  "stat",
                       "datasource":  "${DS_PROMETHEUS}",
                       "gridPos":  {
                                       "h":  4,
                                       "w":  6,
                                       "x":  0,
                                       "y":  0
                                   },
                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "expr":  "sum(rate({__name__=~\"myblog_http_request_duration.*_count\",service_name=~\"$service\"}[5m]))"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "reqps",
                                                            "decimals":  2
                                                        },
                                           "overrides":  [

                                                         ]
                                       },
                       "options":  {
                                       "colorMode":  "value",
                                       "graphMode":  "area",
                                       "reduceOptions":  {
                                                             "calcs":  [
                                                                           "lastNotNull"
                                                                       ],
                                                             "fields":  "",
                                                             "values":  false
                                                         }
                                   }
                   },
                   {
                       "id":  2,
                       "title":  "Error Rate (%)",
                       "type":  "stat",
                       "datasource":  "${DS_PROMETHEUS}",
                       "gridPos":  {
                                       "h":  4,
                                       "w":  6,
                                       "x":  6,
                                       "y":  0
                                   },
                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "expr":  "100 * sum(rate({__name__=~\"myblog_http_request_duration.*_count\",service_name=~\"$service\",error=\"true\"}[5m])) / clamp_min(sum(rate({__name__=~\"myblog_http_request_duration.*_count\",service_name=~\"$service\"}[5m])), 0.0001)"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "percent",
                                                            "decimals":  2
                                                        },
                                           "overrides":  [

                                                         ]
                                       },
                       "options":  {
                                       "colorMode":  "value",
                                       "graphMode":  "area",
                                       "reduceOptions":  {
                                                             "calcs":  [
                                                                           "lastNotNull"
                                                                       ],
                                                             "fields":  "",
                                                             "values":  false
                                                         }
                                   }
                   },
                   {
                       "id":  3,
                       "title":  "P95 Latency (ms)",
                       "type":  "stat",
                       "datasource":  "${DS_PROMETHEUS}",
                       "gridPos":  {
                                       "h":  4,
                                       "w":  6,
                                       "x":  12,
                                       "y":  0
                                   },
                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "expr":  "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"myblog_http_request_duration.*_bucket\",service_name=~\"$service\"}[5m])))"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "ms",
                                                            "decimals":  1
                                                        },
                                           "overrides":  [

                                                         ]
                                       },
                       "options":  {
                                       "colorMode":  "value",
                                       "graphMode":  "area",
                                       "reduceOptions":  {
                                                             "calcs":  [
                                                                           "lastNotNull"
                                                                       ],
                                                             "fields":  "",
                                                             "values":  false
                                                         }
                                   }
                   },
