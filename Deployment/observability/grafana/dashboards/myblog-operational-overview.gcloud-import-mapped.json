                                                      "displayMode":  "table",
                                                      "placement":  "right"
                                                  },
                                       "tooltip":  {
                                                       "mode":  "multi"
                                                   }
                                   }
                   },
                   {
                       "id":  8,
                       "title":  "Recent Failures (Correlate To TraceId)",
