                                          "type":  "loki",
                                          "uid":  "loki"
                                      },
                       "gridPos":  {
                                       "h":  8,
                                       "w":  12,
                                       "x":  12,
                                       "y":  12
                                   },
                       "targets":  [
                                       {
                                           "refId":  "A",
                                           "expr":  "{service_name=~\"$service\"} |~ \"StatusCode=5[0-9]{2}|ExceptionType=[A-Za-z0-9_]+\"",
                                           "queryType":  "range"
                                       }
                                   ],
                       "options":  {
                                       "dedupStrategy":  "none",
                                       "enableLogDetails":  true,
                                       "prettifyLogMessage":  true,
                                       "showCommonLabels":  false,
                                       "showLabels":  true,
                                       "sortOrder":  "Descending",
                                       "wrapLogMessage":  true
