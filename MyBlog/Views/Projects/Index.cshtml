@{
    ViewData["Title"] = "Projects";
    ViewData["MetaDescription"] =
        "Build-focused engineering projects from Mark Golley with implementation notes, testing evidence, and measurable outcomes.";
    ViewData["CanonicalPath"] = "/projects";
}

<section aria-labelledby="projects-title" class="portfolio-hero" data-reveal>
    <p class="hero-kicker">Build Log</p>
    <h1 id="projects-title">Projects with clear scope, tradeoffs, and proof.</h1>
    <p class="section-intro">
        Active builds that move from idea to working implementation. Kept concise, with detail on demand.
    </p>
    <div class="hero-actions">
        <a class="btn btn-primary" asp-controller="Blog" asp-action="Index">Read implementation notes</a>
        <a class="btn btn-secondary" asp-controller="AIExperiments" asp-action="Index">Try AI experiments</a>
    </div>
</section>

<section aria-labelledby="project-templates-title" data-reveal>
    <h2 id="project-templates-title">Current projects</h2>
    <p class="section-intro">Each project follows the same shape so updates stay practical and comparable.</p>

    <div class="case-template-grid">
        <partial name="_CaseStudyTemplate" model='new CaseStudyTemplateViewModel
        {
            Title = "AI Moderation v2 for Blog Comments",
            Status = "In progress",
            OneLiner = "Move moderation from pass/fail to explicit decisions with reason codes and a repeatable smoke check.",
            WhyItMatters = "Low-volume comments still need safe defaults and clear behavior when model calls fail or are unavailable.",
            TechnicalScope = new[]
            {
                "Introduce `Allow`, `Block`, and `ManualReview` decisions with stable reason codes.",
                "Keep a small smoke dataset for regression checks while comment volume is low.",
                "Run moderation diagnostics from the repo with report output.",
                "Use safe fallback behavior when API key or provider response is missing."
            },
            ProofChecklist = new[]
            {
                "Service tests for decision mapping and fallback paths.",
                "CLI eval report generated from the smoke dataset.",
                "Live moderation playground wired to production service path.",
                "Documented reason-code behavior."
            },
            WhatItShows = "Pragmatic safety engineering for a small real site, not a synthetic benchmark-only demo.",
            NextMilestone = "Add moderation category details to diagnostics output."
        }' />

        <partial name="_CaseStudyTemplate" model='new CaseStudyTemplateViewModel
        {
            Title = "Operational Reliability Dashboard",
            Status = "Planned",
            OneLiner = "Track core site workflows with clear health signals and actionable failures.",
            WhyItMatters = "Small projects still benefit from a lightweight reliability loop before issues compound.",
            TechnicalScope = new[]
            {
                "Add structured events for comments, likes, and subscriptions.",
                "Define lightweight SLIs for write success and latency.",
                "Create one dashboard view with top errors and throughput trends.",
                "Document a short incident-response checklist."
            },
            ProofChecklist = new[]
            {
                "Telemetry event map and sample logs.",
                "Dashboard screenshot from real data.",
                "One load-test snapshot with bottleneck notes.",
                "Runbook section in docs."
            },
            WhatItShows = "Can keep operations understandable without overbuilding observability.",
            NextMilestone = "Ship first telemetry events and dashboard skeleton."
        }' />

        <partial name="_CaseStudyTemplate" model='new CaseStudyTemplateViewModel
        {
            Title = "Subscriber Digest Pipeline",
            Status = "Planned",
            OneLiner = "Generate a weekly digest with ranking, dedupe, and delivery safeguards.",
            WhyItMatters = "Turns content into a reliable user-facing workflow with measurable output quality.",
            TechnicalScope = new[]
            {
                "Define ranking rules based on recency and engagement.",
                "Implement idempotent generation and retry-safe sends.",
                "Apply unsubscribe-safe filtering and per-user dedupe.",
                "Capture delivery success and bounce metrics."
            },
            ProofChecklist = new[]
            {
                "Integration tests for ranking and dedupe rules.",
                "Dry-run output preview for sample subscribers.",
                "Retry behavior test for transient send failure.",
                "Delivery metrics snapshot from staging."
            },
            WhatItShows = "Workflow automation with correctness and operational safety in the loop.",
            NextMilestone = "Implement digest generator and fixture-backed tests."
        }' />
    </div>
</section>
