<!DOCTYPE html>
@using MyBlog.Services
@inject IDailyCodingCapsuleProvider DailyCodingCapsuleService
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    @{
        var siteName = "MyBlog";
        var pageTitle = ViewData["Title"]?.ToString();
        var metaTitle = ViewData["MetaTitle"]?.ToString()
                        ?? (string.IsNullOrWhiteSpace(pageTitle) ? siteName : $"{pageTitle} - {siteName}");
        var metaDescription = ViewData["MetaDescription"]?.ToString()
                              ?? "Engineering posts on C#, .NET, Python, testing, and software design.";
        var metaRobots = ViewData["MetaRobots"]?.ToString() ?? "index,follow";
        var ogType = ViewData["OgType"]?.ToString() ?? "website";
        var twitterCard = ViewData["TwitterCard"]?.ToString() ?? "summary_large_image";
        var canonicalPath = ViewData["CanonicalPath"]?.ToString() ?? Context.Request.Path.Value ?? "/";
        if (!canonicalPath.StartsWith("/"))
        {
            canonicalPath = "/" + canonicalPath;
        }

        var configuration = Context.RequestServices.GetService(typeof(IConfiguration)) as IConfiguration;
        var configuredBaseUrl = Environment.GetEnvironmentVariable("PUBLIC_BASE_URL")
                                ?? configuration?["Site:PublicBaseUrl"];

        string baseUrl;
        if (!string.IsNullOrWhiteSpace(configuredBaseUrl) &&
            Uri.TryCreate(configuredBaseUrl.Trim().TrimEnd('/'), UriKind.Absolute, out var configuredUri) &&
            (string.Equals(configuredUri.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) ||
             string.Equals(configuredUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)))
        {
            baseUrl = configuredUri.ToString().TrimEnd('/');
        }
        else
        {
            var forwardedProto = Context.Request.Headers["X-Forwarded-Proto"].FirstOrDefault()
                ?.Split(',')[0]
                .Trim();
            var forwardedHost = Context.Request.Headers["X-FH-Requested-Host"].FirstOrDefault()
                ?.Split(',')[0]
                .Trim();

            if (string.IsNullOrWhiteSpace(forwardedHost))
            {
                forwardedHost = Context.Request.Headers["X-Forwarded-Host"].FirstOrDefault()
                    ?.Split(',')[0]
                    .Trim();
            }

            var scheme = string.Equals(forwardedProto, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) ||
                         string.Equals(forwardedProto, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)
                ? forwardedProto!
                : Context.Request.Scheme;

            if (!string.Equals(scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase))
            {
                scheme = Uri.UriSchemeHttps;
            }

            var host = !string.IsNullOrWhiteSpace(forwardedHost)
                ? forwardedHost
                : Context.Request.Host.Value;

            baseUrl = !string.IsNullOrWhiteSpace(host)
                ? $"{scheme}://{host}".TrimEnd('/')
                : "https://markgolley.dev";
        }

        var canonicalUrl = $"{baseUrl}{canonicalPath}";
        var ogImagePath = ViewData["OgImage"]?.ToString() ?? "/images/me.jpg";
        var ogImageUrl = ogImagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? ogImagePath
            : $"{baseUrl}{(ogImagePath.StartsWith("/") ? ogImagePath : "/" + ogImagePath)}";
    }
    <title>@metaTitle</title>
    <meta name="description" content="@metaDescription"/>
    <meta name="robots" content="@metaRobots"/>
    <link rel="canonical" href="@canonicalUrl"/>
    <link rel="alternate" type="application/rss+xml" title="MyBlog RSS" href="@($"{baseUrl}/rss.xml")"/>
    <meta property="og:type" content="@ogType"/>
    <meta property="og:site_name" content="@siteName"/>
    <meta property="og:title" content="@metaTitle"/>
    <meta property="og:description" content="@metaDescription"/>
    <meta property="og:url" content="@canonicalUrl"/>
    <meta property="og:image" content="@ogImageUrl"/>
    <meta name="twitter:card" content="@twitterCard"/>
    <meta name="twitter:title" content="@metaTitle"/>
    <meta name="twitter:description" content="@metaDescription"/>
    <meta name="twitter:image" content="@ogImageUrl"/>
    <script>
        (() => {
            try {
                const storageKey = "myblog:theme";
                const storedTheme = localStorage.getItem(storageKey);
                const hasStoredTheme = storedTheme === "light" || storedTheme === "dark";
                const prefersDark = typeof window.matchMedia === "function"
                    && window.matchMedia("(prefers-color-scheme: dark)").matches;
                const activeTheme = hasStoredTheme ? storedTheme : (prefersDark ? "dark" : "light");
                document.documentElement.dataset.theme = activeTheme;
                document.documentElement.style.colorScheme = activeTheme;
            } catch {
                document.documentElement.dataset.theme = "light";
                document.documentElement.style.colorScheme = "light";
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/MyBlog.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    DailyCodingCapsuleViewModel? navCapsule = null;
    DailyCodingCapsuleViewModel? previousNavCapsule = null;

    bool IsController(string controller)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
    }

    bool IsActive(string controller, string action = "Index")
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    }

    try
    {
        navCapsule = await DailyCodingCapsuleService.GetCapsuleForCurrentDayAsync(Context.RequestAborted);
        previousNavCapsule = await DailyCodingCapsuleService.TryGetStoredCapsuleForOffsetDaysAsync(-1, Context.RequestAborted);
    }
    catch
    {
        navCapsule = null;
        previousNavCapsule = null;
    }
}

<a class="skip-link" href="#main-content">Skip to content</a>
<div class="page-aurora" aria-hidden="true">
    <span class="orb orb-a"></span>
    <span class="orb orb-b"></span>
    <span class="orb orb-c"></span>
</div>
<div class="scroll-progress" aria-hidden="true" data-scroll-progress></div>

<header class="site-header">
    <div class="container nav-shell">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-wordmark">Mark Golley</span>
            <span class="brand-subtitle">Software Engineering</span>
        </a>

        @if (navCapsule is not null)
        {
            <details class="nav-capsule" data-nav-capsule>
                <summary class="nav-capsule-summary">
                    <span class="nav-capsule-label">Today in code</span>
                    <span class="nav-capsule-cta" aria-hidden="true">
                        <span class="nav-capsule-spark"></span>
                        <span class="nav-capsule-cta-text">Open</span>
                    </span>
                </summary>
                <div class="nav-capsule-panel">
                    @if (previousNavCapsule is not null)
                    {
                        <button type="button" class="nav-capsule-nav-btn nav-capsule-nav-btn-prev" data-nav-capsule-prev aria-label="Show yesterday's insight">&#8249;</button>
                        <button type="button" class="nav-capsule-nav-btn nav-capsule-nav-btn-next" data-nav-capsule-next aria-label="Show today's insight" aria-disabled="true" disabled>&#8250;</button>
                    }

                    <div class="nav-capsule-content" data-nav-capsule-content="today">
                        <div class="nav-capsule-head">
                            <span class="nav-capsule-pill">@navCapsule.CapsuleType</span>
                            <p class="nav-capsule-panel-title">@navCapsule.Title</p>
                        </div>
                        <p class="nav-capsule-copy">@navCapsule.Body</p>
                        <p class="nav-capsule-example">
                            <span class="nav-capsule-example-label">Example</span>
                            <code>@navCapsule.Example</code>
                        </p>
                        <p class="nav-capsule-reset">
                            Refreshes in
                            <span
                                data-daily-capsule-countdown="true"
                                data-next-reset-utc="@navCapsule.NextResetUtcIso">
                                calculating...
                            </span>
                        </p>
                    </div>

                    @if (previousNavCapsule is not null)
                    {
                        <div class="nav-capsule-content" data-nav-capsule-content="yesterday" hidden>
                            <div class="nav-capsule-head">
                                <span class="nav-capsule-pill">@previousNavCapsule.CapsuleType</span>
                                <p class="nav-capsule-panel-title">@previousNavCapsule.Title</p>
                            </div>
                            <p class="nav-capsule-copy">@previousNavCapsule.Body</p>
                            <p class="nav-capsule-example">
                                <span class="nav-capsule-example-label">Example</span>
                                <code>@previousNavCapsule.Example</code>
                            </p>
                        </div>
                    }
                </div>
            </details>
        }

        <div class="nav-controls">
            <button
                type="button"
                class="theme-toggle nav-theme-toggle"
                data-theme-toggle
                aria-label="Switch color theme"
                aria-pressed="false">
                <span class="theme-toggle-track" aria-hidden="true">
                    <span class="theme-toggle-icon theme-toggle-icon-sun">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <circle cx="12" cy="12" r="4.25"></circle>
                            <path d="M12 2.5v2.3M12 19.2v2.3M21.5 12h-2.3M4.8 12H2.5M18.9 5.1l-1.6 1.6M6.7 17.3l-1.6 1.6M18.9 18.9l-1.6-1.6M6.7 6.7 5.1 5.1"></path>
                        </svg>
                    </span>
                    <span class="theme-toggle-icon theme-toggle-icon-moon">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M16.5 3.5a8.7 8.7 0 1 0 4 16.2A9.4 9.4 0 0 1 16.5 3.5z"></path>
                        </svg>
                    </span>
                    <span class="theme-toggle-thumb"></span>
                </span>
                <span class="sr-only" data-theme-toggle-label>Switch to dark mode</span>
            </button>

            <button
                type="button"
                class="nav-toggle"
                aria-expanded="false"
                aria-controls="primary-nav"
                data-nav-toggle>
                <span class="sr-only">Toggle navigation</span>
                <span class="nav-toggle-bar"></span>
                <span class="nav-toggle-bar"></span>
                <span class="nav-toggle-bar"></span>
            </button>
        </div>

        <nav id="primary-nav" class="nav-links" aria-label="Primary" data-nav-menu>
            <a class="nav-link @(IsActive("Home") ? "is-active" : string.Empty)" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-link @(IsController("Blog") ? "is-active" : string.Empty)" asp-controller="Blog" asp-action="Index">Blog</a>
            <a class="nav-link @(IsController("Projects") ? "is-active" : string.Empty)" asp-controller="Projects" asp-action="Index">Projects</a>
            <a class="nav-link @(IsActive("Learning") ? "is-active" : string.Empty)" asp-controller="Learning" asp-action="Index">Learning</a>
            <a class="nav-link @(IsActive("Contact") ? "is-active" : string.Empty)" asp-controller="Contact" asp-action="Index">Contact</a>
            <a class="nav-link @(IsActive("About") ? "is-active" : string.Empty)" asp-controller="About" asp-action="Index">About</a>
        </nav>
    </div>
</header>

<main id="main-content" role="main" class="container page-main" data-page-main>
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="container footer-shell">
        <p>&copy; @DateTime.UtcNow.Year Mark Golley</p>
        <p>Built with ASP.NET Core, clean architecture, and obsessive pragmatism.</p>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
