<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    @{
        var siteName = "MyBlog";
        var pageTitle = ViewData["Title"]?.ToString();
        var metaTitle = ViewData["MetaTitle"]?.ToString()
                        ?? (string.IsNullOrWhiteSpace(pageTitle) ? siteName : $"{pageTitle} - {siteName}");
        var metaDescription = ViewData["MetaDescription"]?.ToString()
                              ?? "Engineering posts on C#, .NET, Python, testing, and software design.";
        var metaRobots = ViewData["MetaRobots"]?.ToString() ?? "index,follow";
        var ogType = ViewData["OgType"]?.ToString() ?? "website";
        var twitterCard = ViewData["TwitterCard"]?.ToString() ?? "summary_large_image";
        var canonicalPath = ViewData["CanonicalPath"]?.ToString() ?? Context.Request.Path.Value ?? "/";
        if (!canonicalPath.StartsWith("/"))
        {
            canonicalPath = "/" + canonicalPath;
        }

        var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}".TrimEnd('/');
        var canonicalUrl = $"{baseUrl}{canonicalPath}";
        var ogImagePath = ViewData["OgImage"]?.ToString() ?? "/images/me.jpg";
        var ogImageUrl = ogImagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? ogImagePath
            : $"{baseUrl}{(ogImagePath.StartsWith("/") ? ogImagePath : "/" + ogImagePath)}";
    }
    <title>@metaTitle</title>
    <meta name="description" content="@metaDescription"/>
    <meta name="robots" content="@metaRobots"/>
    <link rel="canonical" href="@canonicalUrl"/>
    <link rel="alternate" type="application/rss+xml" title="MyBlog RSS" href="@($"{baseUrl}/rss.xml")"/>
    <meta property="og:type" content="@ogType"/>
    <meta property="og:site_name" content="@siteName"/>
    <meta property="og:title" content="@metaTitle"/>
    <meta property="og:description" content="@metaDescription"/>
    <meta property="og:url" content="@canonicalUrl"/>
    <meta property="og:image" content="@ogImageUrl"/>
    <meta name="twitter:card" content="@twitterCard"/>
    <meta name="twitter:title" content="@metaTitle"/>
    <meta name="twitter:description" content="@metaDescription"/>
    <meta name="twitter:image" content="@ogImageUrl"/>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/MyBlog.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
<header class="navbar">
    <div class="container">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">MyBlog</a>
        <nav class="nav-links" aria-label="Primary">
            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-link" asp-controller="Blog" asp-action="Index">My Blogs</a>
            <a class="nav-link" asp-controller="Learning" asp-action="Index">Learning Plan</a>
            <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
            <a class="nav-link" asp-controller="About" asp-action="Index">About</a>
        </nav>
    </div>
</header>

<main role="main" class="container">
    @RenderBody()
</main>

<footer>
    <div class="container">
        &copy; 2026 - MyBlog
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
