<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    @{
        var siteName = "MyBlog";
        var pageTitle = ViewData["Title"]?.ToString();
        var metaTitle = ViewData["MetaTitle"]?.ToString()
                        ?? (string.IsNullOrWhiteSpace(pageTitle) ? siteName : $"{pageTitle} - {siteName}");
        var metaDescription = ViewData["MetaDescription"]?.ToString()
                              ?? "Engineering posts on C#, .NET, Python, testing, and software design.";
        var metaRobots = ViewData["MetaRobots"]?.ToString() ?? "index,follow";
        var ogType = ViewData["OgType"]?.ToString() ?? "website";
        var twitterCard = ViewData["TwitterCard"]?.ToString() ?? "summary_large_image";
        var canonicalPath = ViewData["CanonicalPath"]?.ToString() ?? Context.Request.Path.Value ?? "/";
        if (!canonicalPath.StartsWith("/"))
        {
            canonicalPath = "/" + canonicalPath;
        }

        var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}".TrimEnd('/');
        var canonicalUrl = $"{baseUrl}{canonicalPath}";
        var ogImagePath = ViewData["OgImage"]?.ToString() ?? "/images/me.jpg";
        var ogImageUrl = ogImagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? ogImagePath
            : $"{baseUrl}{(ogImagePath.StartsWith("/") ? ogImagePath : "/" + ogImagePath)}";
    }
    <title>@metaTitle</title>
    <meta name="description" content="@metaDescription"/>
    <meta name="robots" content="@metaRobots"/>
    <link rel="canonical" href="@canonicalUrl"/>
    <link rel="alternate" type="application/rss+xml" title="MyBlog RSS" href="@($"{baseUrl}/rss.xml")"/>
    <meta property="og:type" content="@ogType"/>
    <meta property="og:site_name" content="@siteName"/>
    <meta property="og:title" content="@metaTitle"/>
    <meta property="og:description" content="@metaDescription"/>
    <meta property="og:url" content="@canonicalUrl"/>
    <meta property="og:image" content="@ogImageUrl"/>
    <meta name="twitter:card" content="@twitterCard"/>
    <meta name="twitter:title" content="@metaTitle"/>
    <meta name="twitter:description" content="@metaDescription"/>
    <meta name="twitter:image" content="@ogImageUrl"/>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/MyBlog.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    bool IsController(string controller)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
    }

    bool IsActive(string controller, string action = "Index")
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
    }
}

<a class="skip-link" href="#main-content">Skip to content</a>
<div class="page-aurora" aria-hidden="true">
    <span class="orb orb-a"></span>
    <span class="orb orb-b"></span>
    <span class="orb orb-c"></span>
</div>
<div class="scroll-progress" aria-hidden="true" data-scroll-progress></div>

<header class="site-header">
    <div class="container nav-shell">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-wordmark">Mark Golley</span>
            <span class="brand-subtitle">Engineering Notes</span>
        </a>

        <button
            type="button"
            class="nav-toggle"
            aria-expanded="false"
            aria-controls="primary-nav"
            data-nav-toggle>
            <span class="sr-only">Toggle navigation</span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
        </button>

        <nav id="primary-nav" class="nav-links" aria-label="Primary" data-nav-menu>
            <a class="nav-link @(IsActive("Home") ? "is-active" : string.Empty)" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-link @(IsController("Blog") ? "is-active" : string.Empty)" asp-controller="Blog" asp-action="Index">Blog</a>
            <a class="nav-link @(IsActive("Learning") ? "is-active" : string.Empty)" asp-controller="Learning" asp-action="Index">Learning</a>
            <a class="nav-link @(IsActive("Contact") ? "is-active" : string.Empty)" asp-controller="Contact" asp-action="Index">Contact</a>
            <a class="nav-link @(IsActive("About") ? "is-active" : string.Empty)" asp-controller="About" asp-action="Index">About</a>
        </nav>
    </div>
</header>

<main id="main-content" role="main" class="container page-main" data-page-main>
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="container footer-shell">
        <p>&copy; @DateTime.UtcNow.Year Mark Golley</p>
        <p>Built with ASP.NET Core, clean architecture, and obsessive pragmatism.</p>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
