@model CaseStudyTemplateViewModel

<article class="case-template" data-reveal>
    <header class="case-template-header">
        <h3 class="case-template-title">@Model.Title</h3>
        <span class="case-status-pill">@Model.Status</span>
    </header>

    <p class="case-one-liner">@Model.OneLiner</p>

    <details class="case-details">
        <summary>View details</summary>
        <div class="case-details-body">
            <div class="case-block">
                <h4>Why this matters</h4>
                <p>@Model.WhyItMatters</p>
            </div>

            @if (Model.Screenshots.Count > 0)
            {
                <div class="case-block">
                    <h4>Snapshots</h4>
                    <div class="case-screenshot-grid">
                        @foreach (var screenshot in Model.Screenshots)
                        {
                            <figure class="case-screenshot-card">
                                <img src="@Url.Content(screenshot.ImagePath)" alt="@screenshot.AltText" loading="lazy" />
                                @if (!string.IsNullOrWhiteSpace(screenshot.Caption))
                                {
                                    <figcaption>@screenshot.Caption</figcaption>
                                }
                            </figure>
                        }
                    </div>
                </div>
            }

            @if (Model.TechnicalScope.Count > 0)
            {
                <div class="case-block">
                    <h4>Technical scope</h4>
                    <ul class="case-list">
                        @foreach (var item in Model.TechnicalScope)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.ProofChecklist.Count > 0)
            {
                <div class="case-block">
                    <h4>Proof checklist</h4>
                    <ul class="case-list">
                        @foreach (var item in Model.ProofChecklist)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.BuildNotes.Count > 0)
            {
                <div class="case-block">
                    <h4>Build notes</h4>
                    <ul class="case-list">
                        @foreach (var item in Model.BuildNotes)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }

            <div class="case-block">
                <h4>What this shows</h4>
                <p>@Model.WhatItShows</p>
            </div>
        </div>
    </details>

    @if (!string.IsNullOrWhiteSpace(Model.NextMilestone))
    {
        <div class="case-next-milestone">
            <strong>Next:</strong> @Model.NextMilestone
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.CtaText))
    {
        <div class="case-template-actions">
            @if (!string.IsNullOrWhiteSpace(Model.CtaUrl))
            {
                <a class="btn btn-primary" href="@Model.CtaUrl">
                    @if (!string.IsNullOrWhiteSpace(Model.CtaIconPath))
                    {
                        <img class="btn-logo-icon" src="@Url.Content(Model.CtaIconPath)" alt="" aria-hidden="true" />
                    }
                    <span>@Model.CtaText</span>
                </a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.CtaController))
            {
                var currentPathAndQuery = $"{Context.Request.Path}{Context.Request.QueryString}";
                <a class="btn btn-primary" asp-controller="@Model.CtaController" asp-action="@Model.CtaAction" asp-route-returnUrl="@currentPathAndQuery">
                    @if (!string.IsNullOrWhiteSpace(Model.CtaIconPath))
                    {
                        <img class="btn-logo-icon" src="@Url.Content(Model.CtaIconPath)" alt="" aria-hidden="true" />
                    }
                    <span>@Model.CtaText</span>
                </a>
            }
        </div>
    }
</article>
