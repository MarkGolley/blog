@model ContactFormModel
@{
    ViewData["Title"] = "Contact";
    ViewData["MetaDescription"] = "Get in touch with Mark Golley for software engineering discussions, collaboration, or project opportunities.";
    ViewData["CanonicalPath"] = "/contact";
}

<section id="contact" aria-labelledby="contact-title" data-reveal>
    <h1 id="contact-title">Get in touch</h1>
    <p class="section-intro">
        Email or LinkedIn are the fastest routes if you are reaching out about a role, collaboration, or project.
    </p>

    <div class="hero-actions">
        <a class="btn btn-primary" href="mailto:mark.golley@icloud.com">Email me</a>
        <a class="btn btn-secondary" href="https://www.linkedin.com/in/MarkGolley" target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn btn-secondary" href="https://github.com/MarkGolley" target="_blank" rel="noopener">GitHub</a>
    </div>

    <div class="contact-info">
        <p><strong>Email:</strong> <a href="mailto:mark.golley@icloud.com">mark.golley@icloud.com</a></p>
        <p><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/MarkGolley" target="_blank" rel="noopener">linkedin.com/in/MarkGolley</a></p>
        <p><strong>GitHub:</strong> <a href="https://github.com/MarkGolley" target="_blank" rel="noopener">github.com/MarkGolley</a></p>
    </div>

    @if (ViewBag.MessageSent != null && ViewBag.MessageSent == true)
    {
        <p class="confirmation-message">Thanks for your message! I'll get back to you shortly.</p>
    }
    @if (ViewBag.Error != null)
    {
        <p class="error-message">@ViewBag.Error</p>
    }

    <form method="post" asp-action="Index" class="contact-form">
        @Html.AntiForgeryToken()

        <label for="name">Your name</label>
        <input type="text" id="name" name="Name" value="@Model?.Name" placeholder="Enter your name" required />

        <label for="email">Your email</label>
        <input type="email" id="email" name="Email" value="@Model?.Email" placeholder="Enter your email" required />

        <label for="message">Your message</label>
        <textarea id="message" name="Message" rows="6" placeholder="Type your message here..." required>@Model?.Message</textarea>

        <button type="submit">Send message</button>
    </form>
</section>
