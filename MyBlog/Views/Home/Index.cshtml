@model HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
    ViewData["MetaTitle"] = "Mark Golley | C#/.NET Engineer";
    ViewData["MetaDescription"] = "Mark Golley is a C#/.NET engineer building reliable ASP.NET Core and Python software with testing, clear architecture, and practical delivery.";
    ViewData["CanonicalPath"] = "/";
    var resumeUrl = ViewData["ResumeUrl"]?.ToString() ?? string.Empty;
    var gitHubUrl = ViewData["GitHubUrl"]?.ToString() ?? string.Empty;
    var linkedInUrl = ViewData["LinkedInUrl"]?.ToString() ?? string.Empty;
    var aislePilotPublicUrl = ViewData["AislePilotPublicUrl"]?.ToString() ?? string.Empty;
    var aislePilotLocalEnabled = ViewData["AislePilotLocalEnabled"] as bool? ?? true;
}

<section id="hero" class="home-hero" data-reveal>
    <div class="home-hero-grid">
        <div class="hero-copy">
            <p class="hero-kicker">Mark Golley · C#/.NET Engineer · Burley in Wharfedale, UK</p>
            <h1 class="hero-title">I build reliable ASP.NET Core and Python software with clear architecture, testing, and practical delivery.</h1>
            <p class="hero-lead">
                This site is both portfolio and working product: case studies, engineering writing, and the platform
                features behind them. It is designed to show how I think, how I build, and what I ship.
            </p>
            <div class="hero-actions">
                <a class="btn btn-primary" asp-controller="Projects" asp-action="Index">View selected work</a>
                <a class="btn btn-secondary" asp-controller="Blog" asp-action="Index">Read featured writing</a>
                <a class="btn btn-secondary" asp-controller="Contact" asp-action="Index">Get in touch</a>
            </div>
            <div class="hero-actions hero-actions-secondary">
                @if (!string.IsNullOrWhiteSpace(aislePilotPublicUrl))
                {
                    <a class="btn btn-secondary" href="@aislePilotPublicUrl" data-profile-link="aislepilot">Try AislePilot</a>
                }
                else if (aislePilotLocalEnabled)
                {
                    <a class="btn btn-secondary" asp-controller="AislePilot" asp-action="Index" asp-route-returnUrl="/" data-profile-link="aislepilot">Try AislePilot</a>
                }
                @if (!string.IsNullOrWhiteSpace(resumeUrl))
                {
                    <a class="btn btn-secondary" href="@resumeUrl" target="_blank" rel="noreferrer" data-profile-link="resume">Resume</a>
                }
                @if (!string.IsNullOrWhiteSpace(gitHubUrl))
                {
                    <a class="btn btn-secondary" href="@gitHubUrl" target="_blank" rel="noreferrer" data-profile-link="github">GitHub</a>
                }
                @if (!string.IsNullOrWhiteSpace(linkedInUrl))
                {
                    <a class="btn btn-secondary" href="@linkedInUrl" target="_blank" rel="noreferrer" data-profile-link="linkedin">LinkedIn</a>
                }
            </div>
            <div class="hero-metrics">
                <article class="metric-card">
                    <p class="metric-value">@Model.PublishedPostCount</p>
                    <p class="metric-label">Published articles and technical write-ups</p>
                </article>
                <article class="metric-card">
                    <p class="metric-value">ASP.NET Core + Python</p>
                    <p class="metric-label">Primary stack for delivery, automation, and product work</p>
                </article>
                <article class="metric-card">
                    <p class="metric-value">Tests + Guardrails</p>
                    <p class="metric-label">Moderation, subscriptions, and release checks built into the workflow</p>
                </article>
            </div>
        </div>
        <aside class="hero-portrait" aria-label="Profile highlights">
            <div class="hero-portrait-frame">
                <img src="~/images/me.jpg" alt="Portrait of Mark" />
            </div>
            <section class="hero-spotlight" aria-label="Delivery highlights" data-focus-carousel>
                <div class="hero-spotlight-head">
                    <div>
                        <p class="spotlight-eyebrow">Delivery highlights</p>
                        <p class="spotlight-title" data-focus-label>Current emphasis</p>
                    </div>
                    <div class="hero-spotlight-controls" aria-label="Focus navigation">
                        <button type="button" class="hero-spotlight-nav" data-focus-prev aria-label="Show previous highlight">&#8249;</button>
                        <button type="button" class="hero-spotlight-nav" data-focus-next aria-label="Show next highlight">&#8250;</button>
                    </div>
                </div>

                <div class="hero-focus-card" data-focus-panel>
                    <p class="hero-focus-period" data-focus-period>Now</p>
                    <p class="hero-focus-heading" data-focus-heading>Clear portfolio proof and stronger case studies.</p>
                    <p class="hero-focus-copy" data-focus-copy>
                        The current emphasis is turning this site into stronger proof of delivery: clearer project framing,
                        clearer paths through the work, and sharper evidence of how I build.
                    </p>
                </div>

                <div class="hero-focus-progress" role="tablist" aria-label="Focus timeline">
                    <button type="button" class="hero-focus-dot is-active" data-focus-dot="0" aria-label="Show current emphasis" aria-selected="true"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="1" aria-label="Show applied AI highlight" aria-selected="false"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="2" aria-label="Show cloud and deployment highlight" aria-selected="false"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="3" aria-label="Show testing highlight" aria-selected="false"></button>
                </div>

                <script type="application/json" data-focus-items>
                    [
                      {
                        "label": "Current emphasis",
                        "period": "Now",
                        "heading": "Clear portfolio proof and stronger case studies.",
                        "copy": "The current emphasis is turning this site into stronger proof of delivery: clearer project framing, clearer paths through the work, and sharper evidence of how I build."
                      },
                      {
                        "label": "Recent highlight",
                        "period": "Applied AI with guardrails",
                        "heading": "Turning AI features into deterministic product behavior.",
                        "copy": "The moderation workflow focused on safe defaults, reasoned fallback behavior, and test coverage rather than shipping AI as a black box."
                      },
                      {
                        "label": "Recent highlight",
                        "period": "Cloud and deployment",
                        "heading": "Getting software live reliably, not just working locally.",
                        "copy": "Release scripts, health checks, and deployment cleanup became a real focus so shipping felt repeatable instead of fragile."
                      },
                      {
                        "label": "Recent highlight",
                        "period": "Testing and quality",
                        "heading": "Using tests to make iteration safer.",
                        "copy": "Integration coverage, moderation checks, and anti-forgery handling all came from the same goal: move quickly without guessing whether changes are safe."
                      }
                    ]
                </script>
            </section>
        </aside>
    </div>
</section>

<section aria-labelledby="quick-bits-title" class="showcase-section" data-reveal>
    <h2 id="quick-bits-title">How I work</h2>
    <div class="credentials-grid">
        <div class="credential-card">
            <div class="credential-title">Architecture</div>
            <div class="credential-value">Readable boundaries over cleverness</div>
            <p class="credential-copy">I care about code that can be extended safely by the next person who touches it.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Testing</div>
            <div class="credential-value">Regression coverage for risky paths</div>
            <p class="credential-copy">Comments, moderation, likes, subscriptions, and admin flows are all backed by automated checks.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Delivery</div>
            <div class="credential-value">Pragmatic scope with proof</div>
            <p class="credential-copy">I try to ship useful slices with visible outcomes rather than leave everything as intent.</p>
        </div>
    </div>
</section>

<section aria-labelledby="focus-areas-title" class="showcase-section" data-reveal>
    <h2 id="focus-areas-title">Where to start</h2>
    <p class="section-intro">If you are reviewing the site quickly, these are the best entry points.</p>
    <div class="focus-grid">
        <a class="focus-card" asp-controller="Projects" asp-action="Index">
            <p class="focus-title">Selected work</p>
            <p>Project summaries with delivery scope, proof points, and what each build demonstrates.</p>
        </a>
        <a class="focus-card" asp-controller="Blog" asp-action="Index">
            <p class="focus-title">Articles</p>
            <p>Technical writing on ASP.NET Core, testing, cloud delivery, and engineering tradeoffs.</p>
        </a>
        <a class="focus-card" asp-controller="About" asp-action="Index">
            <p class="focus-title">About me</p>
            <p>The quick version of how I work, what I use day to day, and what I care about in software delivery.</p>
        </a>
        <a class="focus-card" asp-controller="Contact" asp-action="Index">
            <p class="focus-title">Get in touch</p>
            <p>Email, LinkedIn, and GitHub links for roles, collaborations, or technical conversations.</p>
        </a>
    </div>
</section>

<section aria-labelledby="featured-writing-title" class="showcase-section" data-reveal>
    <h2 id="featured-writing-title">Featured writing</h2>
    <p class="section-intro">A few articles that best show how I think about testing, reliability, and practical engineering decisions.</p>

    @if (Model.FeaturedPosts.Any())
    {
        <div class="focus-grid">
            @foreach (var post in Model.FeaturedPosts)
            {
                <a class="focus-card" asp-controller="Blog" asp-action="Post" asp-route-slug="@post.Id">
                    <p class="focus-title">@post.Title</p>
                    <div class="post-meta">
                        @post.DatePosted.ToString("dd MMMM yyyy")
                        <span class="meta-dot">•</span>
                        @post.ReadingTimeMinutes min read
                    </div>
                    @if (post.Tags.Any())
                    {
                        <div class="tag-list">
                            @foreach (var tag in post.Tags.Take(3))
                            {
                                <span class="tag-chip">@tag</span>
                            }
                        </div>
                    }
                </a>
            }
        </div>
    }
    else
    {
        <p class="section-intro">Featured articles will appear here as the writing library grows.</p>
    }
</section>
