@{
    ViewData["Title"] = "Home";
    ViewData["MetaDescription"] = "Mark Golley builds reliable software in C#/.NET and Python, with a focus on clean architecture and testing.";
    ViewData["CanonicalPath"] = "/";
    var resumeUrl = ViewData["ResumeUrl"]?.ToString() ?? string.Empty;
    var gitHubUrl = ViewData["GitHubUrl"]?.ToString() ?? string.Empty;
    var linkedInUrl = ViewData["LinkedInUrl"]?.ToString() ?? string.Empty;
    var aislePilotPublicUrl = ViewData["AislePilotPublicUrl"]?.ToString() ?? string.Empty;
    var aislePilotLocalEnabled = ViewData["AislePilotLocalEnabled"] as bool? ?? true;
}

<section id="hero" class="home-hero" data-reveal>
    <div class="home-hero-grid">
        <div class="hero-copy">
            <p class="hero-kicker">C#/.NET + Python Engineer</p>
            <h1 class="hero-title">Building reliable software with clear architecture and practical delivery.</h1>
            <p class="hero-lead">
                I write pragmatic, test-driven software and share what works: architecture decisions, delivery tradeoffs,
                and practical lessons from real projects.
            </p>
            <div class="hero-actions">
                @if (!string.IsNullOrWhiteSpace(aislePilotPublicUrl))
                {
                    <a class="btn btn-primary" href="@aislePilotPublicUrl" data-recruiter-link="aislepilot">Try AislePilot</a>
                }
                else if (aislePilotLocalEnabled)
                {
                    <a class="btn btn-primary" asp-controller="AislePilot" asp-action="Index" asp-route-returnUrl="/" data-recruiter-link="aislepilot">Try AislePilot</a>
                }
                <a class="btn btn-secondary" asp-controller="Projects" asp-action="Index">See my projects</a>
                <a class="btn btn-secondary" asp-controller="Contact" asp-action="Index">Start a conversation</a>
            </div>
            <div class="hero-actions hero-actions-secondary">
                @if (!string.IsNullOrWhiteSpace(resumeUrl))
                {
                    <a class="btn btn-secondary" href="@resumeUrl" target="_blank" rel="noreferrer" data-recruiter-link="resume">Resume</a>
                }
                @if (!string.IsNullOrWhiteSpace(gitHubUrl))
                {
                    <a class="btn btn-secondary" href="@gitHubUrl" target="_blank" rel="noreferrer" data-recruiter-link="github">GitHub</a>
                }
                @if (!string.IsNullOrWhiteSpace(linkedInUrl))
                {
                    <a class="btn btn-secondary" href="@linkedInUrl" target="_blank" rel="noreferrer" data-recruiter-link="linkedin">LinkedIn</a>
                }
            </div>
            <div class="hero-metrics">
                <article class="metric-card">
                    <p class="metric-value">4 Years</p>
                    <p class="metric-label">Hands-on software development</p>
                </article>
                <article class="metric-card">
                    <p class="metric-value">.NET + Python</p>
                    <p class="metric-label">Core stack for delivery and automation</p>
                </article>
                <article class="metric-card">
                    <p class="metric-value">Testing First</p>
                    <p class="metric-label">Quality engineered into the build cycle</p>
                </article>
            </div>
        </div>
        <aside class="hero-portrait" aria-label="Profile highlights">
            <div class="hero-portrait-frame">
                <img src="~/images/me.jpg" alt="Portrait of Mark" />
            </div>
            <section class="hero-spotlight" aria-label="Focus timeline" data-focus-carousel>
                <div class="hero-spotlight-head">
                    <div>
                        <p class="spotlight-eyebrow">What I'm focused on</p>
                        <p class="spotlight-title" data-focus-label>Current focus</p>
                    </div>
                    <div class="hero-spotlight-controls" aria-label="Focus navigation">
                        <button type="button" class="hero-spotlight-nav" data-focus-prev aria-label="Show previous focus">&#8249;</button>
                        <button type="button" class="hero-spotlight-nav" data-focus-next aria-label="Show next focus">&#8250;</button>
                    </div>
                </div>

                <div class="hero-focus-card" data-focus-panel>
                    <p class="hero-focus-period" data-focus-period>Now</p>
                    <p class="hero-focus-heading" data-focus-heading>Architecture, testing, and more deliberate project delivery.</p>
                    <p class="hero-focus-copy" data-focus-copy>
                        Right now I am concentrating on cleaner boundaries in my .NET work, stronger automated test coverage,
                        and turning ideas on this site into projects with clearer proof of delivery.
                    </p>
                </div>

                <div class="hero-focus-progress" role="tablist" aria-label="Focus timeline">
                    <button type="button" class="hero-focus-dot is-active" data-focus-dot="0" aria-label="Show current focus" aria-selected="true"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="1" aria-label="Show cloud and deployment focus" aria-selected="false"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="2" aria-label="Show testing focus" aria-selected="false"></button>
                    <button type="button" class="hero-focus-dot" data-focus-dot="3" aria-label="Show C# foundations focus" aria-selected="false"></button>
                </div>

                <script type="application/json" data-focus-items>
                    [
                      {
                        "label": "Current focus",
                        "period": "Now",
                        "heading": "Architecture, testing, and more deliberate project delivery.",
                        "copy": "Right now I am concentrating on cleaner boundaries in my .NET work, stronger automated test coverage, and turning ideas on this site into projects with clearer proof of delivery."
                      },
                      {
                        "label": "Previous focus",
                        "period": "Cloud and deployment",
                        "heading": "Getting software live reliably, not just built locally.",
                        "copy": "A big recent focus was deployment and operational confidence: hosting the site, working through cloud setup, and making releases feel repeatable instead of fragile."
                      },
                      {
                        "label": "Previous focus",
                        "period": "Testing and quality",
                        "heading": "Building the habit of proving behaviour with tests first.",
                        "copy": "A strong stretch of work went into xUnit, Moq, moderation checks, and comment workflows so the site could grow without guessing whether changes were safe."
                      },
                      {
                        "label": "Previous focus",
                        "period": "C# foundations",
                        "heading": "Sharpening design patterns, SOLID, and code organisation.",
                        "copy": "Earlier work centred on the fundamentals in my learning plan: class structure, object-oriented design, and the practical patterns that make code easier to extend."
                      }
                    ]
                </script>
            </section>
        </aside>
    </div>
</section>

<section aria-labelledby="quick-bits-title" class="showcase-section" data-reveal>
    <h2 id="quick-bits-title">Quick bits</h2>
    <div class="credentials-grid">
        <div class="credential-card">
            <div class="credential-title">Stack</div>
            <div class="credential-value">C#, .NET, xUnit, Python, GCP</div>
            <p class="credential-copy">I focus on maintainable code, strong tests, and clean delivery.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Learning style</div>
            <div class="credential-value">Short focused sprints</div>
            <p class="credential-copy">Consistent, intentional learning beats marathon sessions.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Outside work</div>
            <div class="credential-value">Climbing and long walks</div>
            <p class="credential-copy">Usually with Ellie, my cocker spaniel.</p>
        </div>
    </div>
</section>

<section aria-labelledby="focus-areas-title" class="showcase-section" data-reveal>
    <h2 id="focus-areas-title">Focus areas</h2>
    <p class="section-intro">A mix of production projects and practical writeups from shipping software.</p>
    <div class="focus-grid">
        <a class="focus-card" asp-controller="Projects" asp-action="Index">
            <p class="focus-title">Projects</p>
            <p>Production-focused builds with architecture tradeoffs, testing evidence, and measurable outcomes.</p>
        </a>
        <a class="focus-card" asp-controller="Blog" asp-action="Index" asp-route-tag="C#">
            <p class="focus-title">C# and .NET</p>
            <p>Clean architecture, practical patterns, and maintainable backend workflows.</p>
        </a>
        <a class="focus-card" asp-controller="Blog" asp-action="Index" asp-route-tag="Testing">
            <p class="focus-title">Testing and quality</p>
            <p>xUnit, test strategy, and reliability habits that reduce production risk.</p>
        </a>
        <a class="focus-card" asp-controller="Blog" asp-action="Index" asp-route-tag="Cloud">
            <p class="focus-title">Cloud and deployment</p>
            <p>Lessons from hosting, infrastructure decisions, and real operational concerns.</p>
        </a>
    </div>
</section>
