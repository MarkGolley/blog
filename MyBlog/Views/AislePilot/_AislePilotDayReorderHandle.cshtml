@model string
@{
    var safeDayName = string.IsNullOrWhiteSpace(Model) ? "day" : Model.Trim();
}

<button type="button"
        class="aislepilot-day-card-reorder-handle"
        data-day-reorder-handle
        aria-label="@($"Reorder {safeDayName}")"
        title="@($"Reorder {safeDayName}")">
    <span class="aislepilot-day-card-reorder-handle-glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
            <circle cx="8" cy="7" r="1.6"></circle>
            <circle cx="16" cy="7" r="1.6"></circle>
            <circle cx="8" cy="12" r="1.6"></circle>
            <circle cx="16" cy="12" r="1.6"></circle>
            <circle cx="8" cy="17" r="1.6"></circle>
            <circle cx="16" cy="17" r="1.6"></circle>
        </svg>
    </span>
    <span class="aislepilot-day-card-reorder-handle-label" aria-hidden="true">Drag</span>
    <span class="sr-only">Drag to reorder @safeDayName</span>
</button>
