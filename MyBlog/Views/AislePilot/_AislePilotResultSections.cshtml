@using System.Globalization
@using System.Text
@model AislePilotPageViewModel

@if (Model.HasResult && Model.Result is not null)
{
    var result = Model.Result;
    var ukCulture = CultureInfo.GetCultureInfo("en-GB");
    string ResolveClientMealImageUrl(string? imageUrl)
    {
        var normalized = imageUrl?.Trim();
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return "/projects/aisle-pilot/images/aislepilot-icon.svg";
        }

        if (normalized.StartsWith("/projects/aisle-pilot/images/", StringComparison.OrdinalIgnoreCase))
        {
            return normalized;
        }

        if (normalized.StartsWith("/images/", StringComparison.OrdinalIgnoreCase))
        {
            return $"/projects/aisle-pilot/images/{normalized["/images/".Length..]}";
        }

        normalized = normalized.Replace('\\', '/');
        if (!normalized.StartsWith("/", StringComparison.Ordinal))
        {
            var trimmed = normalized.TrimStart('/');
            if (trimmed.StartsWith("images/", StringComparison.OrdinalIgnoreCase))
            {
                return $"/projects/aisle-pilot/images/{trimmed["images/".Length..]}";
            }

            if (trimmed.StartsWith("aislepilot-meals/", StringComparison.OrdinalIgnoreCase))
            {
                return $"/projects/aisle-pilot/images/{trimmed}";
            }

            var hasImageExtension =
                trimmed.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                trimmed.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                trimmed.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                trimmed.EndsWith(".webp", StringComparison.OrdinalIgnoreCase) ||
                trimmed.EndsWith(".svg", StringComparison.OrdinalIgnoreCase);
            if (hasImageExtension)
            {
                return $"/projects/aisle-pilot/images/aislepilot-meals/{trimmed}";
            }
        }

        if (Uri.TryCreate(normalized, UriKind.Absolute, out var absoluteUri) &&
            (absoluteUri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
             absoluteUri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase)))
        {
            return normalized;
        }

        return normalized;
    }

    var fallbackMealImageUrl = ResolveClientMealImageUrl("/images/aislepilot-icon.svg");
    var mealImagesPollUrl = Url.Action("MealImages", "AislePilot") ?? "/projects/aisle-pilot/meal-images";
    var aisleRank = result.AisleOrderUsed
        .Select((department, index) => new { department, index })
        .ToDictionary(x => x.department, x => x.index, StringComparer.OrdinalIgnoreCase);
    var groupedItems = result.ShoppingItems
        .GroupBy(item => item.Department)
        .OrderBy(group => aisleRank.GetValueOrDefault(group.Key, int.MaxValue))
        .ToList();
    var planDays = Math.Clamp(result.PlanDays, 1, 7);
    var weekDayNames = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    var weekDayShortLabels = new[] { "M", "T", "W", "T", "F", "S", "S" };
    var planWeekDayNames = weekDayNames.Take(planDays).ToArray();
    var planWeekDayShortLabels = weekDayShortLabels.Take(planDays).ToArray();
    var mealTypeOrder = new[] { "Dinner", "Lunch", "Breakfast" };
    var mealTypeRank = mealTypeOrder
        .Select((type, index) => new { type, index })
        .ToDictionary(x => x.type, x => x.index, StringComparer.OrdinalIgnoreCase);
    var dayMealGroups = result.MealPlan
        .Select((meal, index) => new { meal, index })
        .GroupBy(entry => entry.meal.Day)
        .Select(group => new
        {
            Day = group.Key,
            Entries = group
                .OrderBy(entry => mealTypeRank.GetValueOrDefault(entry.meal.MealType ?? string.Empty, int.MaxValue))
                .ThenBy(entry => entry.index)
                .ToList(),
            LeftoverDaysCovered = group.Max(entry => entry.meal.LeftoverDaysCovered)
        })
        .ToList();
    var weekDayLookup = planWeekDayNames
        .Select((name, index) => new { name, index })
        .ToDictionary(x => x.name, x => x.index, StringComparer.OrdinalIgnoreCase);
    var leftoverSourceWeekDayIndexes = dayMealGroups
        .SelectMany(dayGroup =>
        {
            if (!weekDayLookup.TryGetValue(dayGroup.Day, out var weekDayIndex))
            {
                return Enumerable.Empty<int>();
            }

            return Enumerable.Repeat(weekDayIndex, dayGroup.LeftoverDaysCovered);
        })
        .ToList();
    var leftoverSourceDayIndexesCsv = string.Join(",", leftoverSourceWeekDayIndexes);
    var currentPlanMealNames = result.MealPlan
        .Select(meal => meal.MealName)
        .ToList();
    var mealCount = result.MealPlan.Count;
    HashSet<int> ParseIgnoredMealSlotIndexes(string? ignoredMealSlotIndexesCsv, int maxMealSlotIndex)
    {
        if (string.IsNullOrWhiteSpace(ignoredMealSlotIndexesCsv))
        {
            return [];
        }

        return ignoredMealSlotIndexesCsv
            .Split([',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(token => int.TryParse(token, out var index) ? index : -1)
            .Where(index => index >= 0 && index <= maxMealSlotIndex)
            .Distinct()
            .ToHashSet();
    }
    var ignoredMealSlotIndexes = ParseIgnoredMealSlotIndexes(Model.Request.IgnoredMealSlotIndexesCsv, Math.Max(0, mealCount - 1));
    var dayCardCount = dayMealGroups.Count;
    var mealLabel = mealCount == 1 ? "meal" : "meals";
    var shoppingListNotesBuilder = new StringBuilder();
    shoppingListNotesBuilder.AppendLine("AislePilot Shopping List");
    shoppingListNotesBuilder.AppendLine($"Supermarket: {result.Supermarket}");
    shoppingListNotesBuilder.AppendLine($"Estimated total: {result.EstimatedTotalCost.ToString("C", ukCulture)}");
    shoppingListNotesBuilder.AppendLine();
    foreach (var department in groupedItems)
    {
        shoppingListNotesBuilder.AppendLine(department.Key);
        foreach (var item in department)
        {
            shoppingListNotesBuilder.AppendLine(
                $"[ ] {item.Name} ({item.QuantityDisplay}) - {item.EstimatedCost.ToString("C", ukCulture)}");
        }
        shoppingListNotesBuilder.AppendLine();
    }
    var shoppingListNotesText = shoppingListNotesBuilder.ToString().TrimEnd();
    AislePilotHiddenRequestFieldsViewModel BuildHiddenRequestFields(
        bool includeCurrentPlanMealNames = false,
        bool includeLeftoverCsvDataAttribute = false)
    {
        return new AislePilotHiddenRequestFieldsViewModel
        {
            ReturnUrl = Model.ReturnUrl,
            Request = Model.Request,
            LeftoverCookDayIndexesCsv = leftoverSourceDayIndexesCsv,
            CurrentPlanMealNames = includeCurrentPlanMealNames
                ? currentPlanMealNames
                : Array.Empty<string>(),
            IncludeCurrentPlanMealNames = includeCurrentPlanMealNames,
            IncludeLeftoverCsvDataAttribute = includeLeftoverCsvDataAttribute
        };
    }

    <section id="aislepilot-overview" aria-labelledby="aislepilot-budget-title" class="aislepilot-shell" data-reveal>
        <div class="aislepilot-section-head">
            <h2 id="aislepilot-budget-title" class="aislepilot-section-title">Overview</h2>
            <div class="aislepilot-overview-actions">
                <form method="post" action="@Url.Action("Index", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                    @Html.AntiForgeryToken()
                    <partial name="_AislePilotHiddenRequestFields"
                             model="BuildHiddenRequestFields()" />
                    <button type="submit" class="aislepilot-overview-regenerate-btn" data-loading-label="Regenerating...">Regenerate plan</button>
                </form>
                <button
                    type="button"
                    class="aislepilot-edit-setup-btn"
                    data-setup-toggle
                    aria-controls="aislepilot-setup"
                    aria-expanded="false">
                    Edit setup
                </button>
            </div>
        </div>
        @if (result.IsOverBudget)
        {
            <div class="aislepilot-overbudget-flag" role="status" aria-live="polite">
                <p class="aislepilot-overbudget-title">
                    This plan is @Math.Abs(result.BudgetDelta).ToString("C", ukCulture) over your weekly budget.
                </p>
                <p class="aislepilot-overbudget-note">
                    @(string.IsNullOrWhiteSpace(result.BudgetRebalanceStatusMessage)
                        ? "Keep this plan if you are happy to spend more, or refresh with a lower-cost mix."
                        : result.BudgetRebalanceStatusMessage)
                </p>
                <form method="post"
                      action="@Url.Action("RebalanceBudget", "AislePilot")#aislepilot-overview"
                      class="aislepilot-overview-regenerate-form">
                    @Html.AntiForgeryToken()
                    <partial name="_AislePilotHiddenRequestFields"
                             model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                    <button type="submit"
                            class="aislepilot-overview-regenerate-btn"
                            data-loading-label="Refreshing lower-cost plan...">
                        Refresh for lower cost
                    </button>
                </form>
            </div>
        }
        <div class="aislepilot-budget-grid">
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Supermarket</p>
                <p class="aislepilot-stat-value">@result.Supermarket</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Portion size</p>
                <p class="aislepilot-stat-value">@result.PortionSize</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Budget</p>
                <p class="aislepilot-stat-value">@result.WeeklyBudget.ToString("C", ukCulture)</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Estimated total</p>
                <p class="aislepilot-stat-value">@result.EstimatedTotalCost.ToString("C", ukCulture)</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Budget difference</p>
                <p class="aislepilot-stat-value @(result.IsOverBudget ? "is-over-budget" : "is-on-budget")">
                    @result.BudgetDelta.ToString("C", ukCulture)
                </p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Plan length</p>
                <p class="aislepilot-stat-value">@result.PlanDays day(s)</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Cook days</p>
                <p class="aislepilot-stat-value">@result.CookDays</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Meals per day</p>
                <p class="aislepilot-stat-value">@result.MealsPerDay</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Leftovers</p>
                <p class="aislepilot-stat-value">@result.LeftoverDays day(s)</p>
            </article>
        </div>
    </section>

    <section class="aislepilot-shell aislepilot-window-shell" aria-labelledby="aislepilot-window-title" data-aislepilot-window data-reveal>
        <div class="aislepilot-window-head">
            <h2 id="aislepilot-window-title" class="aislepilot-section-title">
                Weekly plan
                <span class="aislepilot-window-title-meta">@mealCount @mealLabel across @dayCardCount day card(s)</span>
            </h2>
            <div class="aislepilot-window-nav">
                <p class="aislepilot-window-nav-hint" data-window-hint>Tap a tab to switch between meals, shopping list, and exports.</p>
                <div class="aislepilot-window-tabs" role="tablist" aria-label="AislePilot weekly plan views">
                    <button type="button" id="aislepilot-tab-meals" class="aislepilot-window-tab" data-window-tab="aislepilot-meals" role="tab" aria-controls="aislepilot-meals" aria-selected="true">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="5" cy="7" r="1"></circle>
                                    <circle cx="5" cy="12" r="1"></circle>
                                    <circle cx="5" cy="17" r="1"></circle>
                                    <path d="M8 7h11M8 12h11M8 17h11"></path>
                                </svg>
                            </span>
                            Meals
                        </span>
                    </button>
                    <button type="button" id="aislepilot-tab-shop" class="aislepilot-window-tab" data-window-tab="aislepilot-shop" role="tab" aria-controls="aislepilot-shop" aria-selected="false">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="9" cy="19" r="1.5"></circle>
                                    <circle cx="17" cy="19" r="1.5"></circle>
                                    <path d="M3 4h2l2.4 10h10.8l1.8-7H7"></path>
                                </svg>
                            </span>
                            Shopping
                        </span>
                    </button>
                    <button type="button" id="aislepilot-tab-export" class="aislepilot-window-tab" data-window-tab="aislepilot-export" role="tab" aria-controls="aislepilot-export" aria-selected="false">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M12 16V6"></path>
                                    <path d="m8 10 4-4 4 4"></path>
                                    <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path>
                                </svg>
                            </span>
                            Export
                        </span>
                    </button>
                </div>
            </div>
        </div>
        <div class="aislepilot-window-viewport" data-window-viewport>
            <div class="aislepilot-window-track" data-window-track>
                <section id="aislepilot-meals" aria-label="Meals" role="tabpanel" aria-labelledby="aislepilot-tab-meals" class="aislepilot-window-panel" data-window-name="Meals">
                    @if (result.LeftoverDays > 0)
                    {
                        <div class="aislepilot-leftover-editor">
                            <div class="aislepilot-leftover-editor-head">
                                <p class="aislepilot-window-meta">@result.LeftoverDays leftover day(s) are allocated. Green days are double-cook days.</p>
                                <button type="button"
                                        class="aislepilot-leftover-toggle"
                                        data-leftover-toggle
                                        aria-expanded="false">
                                    Rebalance leftovers
                                </button>
                            </div>
                            <div class="aislepilot-leftover-planner-shell" data-leftover-planner hidden>
                                <p class="aislepilot-leftover-helper">Tap a day with leftovers, then tap another day to move one leftover.</p>
                                <form method="post"
                                      action="@Url.Action("Index", "AislePilot")#aislepilot-meals"
                                      class="aislepilot-leftover-rebalance-form"
                                      data-leftover-rebalance-form
                                      data-preserve-scroll-form>
                                    @Html.AntiForgeryToken()
                                    <partial name="_AislePilotHiddenRequestFields"
                                             model="BuildHiddenRequestFields(includeLeftoverCsvDataAttribute: true)" />
                                </form>
                                <div class="aislepilot-leftover-planner" role="list" aria-label="Leftover day allocation">
                                    @for (var dayIndex = 0; dayIndex < planWeekDayNames.Length; dayIndex++)
                                    {
                                        var dayLeftoverCount = leftoverSourceWeekDayIndexes.Count(index => index == dayIndex);
                                        var dayChipClass = dayLeftoverCount > 0
                                            ? "aislepilot-leftover-day-chip is-leftover-source"
                                            : "aislepilot-leftover-day-chip";
                                        <button type="button"
                                                class="@dayChipClass"
                                                data-leftover-day-zone
                                                data-day-index="@dayIndex"
                                                data-leftover-count="@dayLeftoverCount"
                                                aria-label="Leftover allocation for @planWeekDayNames[dayIndex]"
                                                role="listitem">
                                            <span class="aislepilot-leftover-day-name">@planWeekDayShortLabels[dayIndex]</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <div class="aislepilot-meal-grid"
                         data-meal-image-poll-root
                         data-fallback-meal-image-url="@fallbackMealImageUrl"
                         data-meal-image-poll-enabled="@(Model.MealImagePollingEnabled ? "true" : "false")"
                         data-meal-image-poll-url="@mealImagesPollUrl">
                        @foreach (var dayGroup in dayMealGroups)
                        {
                            var firstMealIndex = dayGroup.Entries[0].index;
                            var mealCardClass = dayGroup.LeftoverDaysCovered > 0
                                ? "aislepilot-card aislepilot-day-card is-leftover-source"
                                : "aislepilot-card aislepilot-day-card";
                            var tabPrefix = $"meal-slot-{firstMealIndex}";
                            <article class="@mealCardClass" data-leftover-day-card data-day-index="@firstMealIndex" data-day-meal-card>
                                <div class="aislepilot-card-head">
                                    <p class="aislepilot-card-kicker">@dayGroup.Day</p>
                                    @if (dayGroup.Entries.Count > 1)
                                    {
                                        <p class="aislepilot-day-card-meta">@dayGroup.Entries.Count meals</p>
                                    }
                                </div>

                                @if (dayGroup.Entries.Count > 1)
                                {
                                    <div class="aislepilot-day-meal-tabs" role="tablist" aria-label="Meal slots for @dayGroup.Day">
                                        @for (var slotIndex = 0; slotIndex < dayGroup.Entries.Count; slotIndex++)
                                        {
                                            var slotMeal = dayGroup.Entries[slotIndex].meal;
                                            var slotTabId = $"{tabPrefix}-tab-{slotIndex}";
                                            <button type="button"
                                                    id="@slotTabId"
                                                    class="aislepilot-day-meal-tab@(slotIndex == 0 ? " is-active" : string.Empty)"
                                                    data-day-meal-tab
                                                    data-slot-index="@slotIndex"
                                                    role="tab"
                                                    aria-controls="@($"{tabPrefix}-panel-{slotIndex}")"
                                                    aria-selected="@(slotIndex == 0 ? "true" : "false")">
                                                @slotMeal.MealType
                                            </button>
                                        }
                                    </div>
                                }

                                <div class="aislepilot-day-meal-slider" data-day-meal-slider>
                                    <div class="aislepilot-day-meal-track" data-day-meal-track>
                                        @for (var slotIndex = 0; slotIndex < dayGroup.Entries.Count; slotIndex++)
                                        {
                                            var entry = dayGroup.Entries[slotIndex];
                                            var meal = entry.meal;
                                            var mealIndex = entry.index;
                                            var isIgnored = ignoredMealSlotIndexes.Contains(mealIndex) || meal.IsIgnored;
                                            var panelLabelledBy = dayGroup.Entries.Count > 1
                                                ? $"{tabPrefix}-tab-{slotIndex}"
                                                : null;
                                            <section id="@($"{tabPrefix}-panel-{slotIndex}")"
                                                     class="aislepilot-day-meal-panel@(isIgnored ? " is-ignored" : string.Empty)"
                                                     data-day-meal-panel
                                                     role="tabpanel"
                                                     aria-labelledby="@panelLabelledBy"
                                                     aria-hidden="@(slotIndex == 0 ? "false" : "true")">
                                                <div class="aislepilot-meal-image-shell">
                                                    <img class="aislepilot-meal-image"
                                                         src="@ResolveClientMealImageUrl(meal.MealImageUrl)"
                                                         data-meal-image
                                                         data-meal-name="@meal.MealName"
                                                         alt="@($"{meal.MealName} plated meal")"
                                                         loading="lazy"
                                                         decoding="async" />
                                                </div>
                                                <div class="aislepilot-card-head">
                                                    <p class="aislepilot-card-kicker">@meal.MealType</p>
                                                    @if (isIgnored)
                                                    {
                                                        <p class="aislepilot-cost is-ignored">Ignored</p>
                                                    }
                                                    else
                                                    {
                                                        <p class="aislepilot-cost">@meal.EstimatedCost.ToString("C", ukCulture)</p>
                                                    }
                                                </div>
                                                <h3>@meal.MealName</h3>
                                                <div class="aislepilot-card-compact-meta">
                                                    <span class="aislepilot-card-meta-pill">
                                                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                            <svg viewBox="0 0 24 24" focusable="false">
                                                                <circle cx="12" cy="12" r="7"></circle>
                                                                <path d="M12 8v4l3 2"></path>
                                                            </svg>
                                                        </span>
                                                        Prep @meal.EstimatedPrepMinutes mins
                                                    </span>
                                                    @if (dayGroup.LeftoverDaysCovered > 0)
                                                    {
                                                        <span class="aislepilot-card-meta-pill">
                                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                <svg viewBox="0 0 24 24" focusable="false">
                                                                    <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                                                    <path d="M20 4v6h-6"></path>
                                                                </svg>
                                                            </span>
                                                            Makes extra for @dayGroup.LeftoverDaysCovered leftover day(s)
                                                        </span>
                                                    }
                                                </div>
                                                <div class="aislepilot-card-action-row">
                                                    <details class="aislepilot-meal-details">
                                                        <summary>
                                                            <span class="aislepilot-btn-label">
                                                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                    <svg viewBox="0 0 24 24" focusable="false">
                                                                        <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
                                                                        <circle cx="12" cy="12" r="2.5"></circle>
                                                                    </svg>
                                                                </span>
                                                                View details
                                                            </span>
                                                        </summary>
                                                        <div class="aislepilot-meal-details-panel">
                                                            <p class="aislepilot-card-meta aislepilot-card-reason">@meal.MealReason</p>
                                                            <div class="aislepilot-meal-details-grid">
                                                                <div class="aislepilot-nutrition-details">
                                                                    <p class="aislepilot-card-kicker">Est. calories + macros</p>
                                                                    <ul class="aislepilot-nutrition-list">
                                                                        <li>@meal.CaloriesPerServing kcal per serving</li>
                                                                        <li>Protein: @meal.ProteinGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                                        <li>Carbs: @meal.CarbsGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                                        <li>Fat: @meal.FatGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                                    </ul>
                                                                </div>
                                                                <div class="aislepilot-recipe-details">
                                                                    <p class="aislepilot-card-kicker">Ingredients</p>
                                                                    <ul class="case-list">
                                                                        @foreach (var ingredientLine in meal.IngredientLines)
                                                                        {
                                                                            <li>@ingredientLine</li>
                                                                        }
                                                                    </ul>
                                                                    <p class="aislepilot-card-kicker">Method</p>
                                                                    <ol class="case-list">
                                                                        @foreach (var step in meal.RecipeSteps)
                                                                        {
                                                                            <li>@step</li>
                                                                        }
                                                                    </ol>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </details>

                                                    <form method="post"
                                                          action="@Url.Action("SwapMeal", "AislePilot")#aislepilot-meals"
                                                          class="aislepilot-swap-form aislepilot-card-action-inline"
                                                          data-preserve-scroll-form
                                                          data-ajax-swap-form>
                                                        @Html.AntiForgeryToken()
                                                        <partial name="_AislePilotHiddenRequestFields"
                                                                 model="BuildHiddenRequestFields()" />
                                                        <input type="hidden" name="dayIndex" value="@mealIndex" />
                                                        <input type="hidden" name="currentMealName" value="@meal.MealName" />
                                                        <button type="submit" class="aislepilot-swap-btn" data-loading-label="Swapping..." data-loading-delay-ms="220">
                                                            <span class="aislepilot-btn-label">
                                                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                    <svg viewBox="0 0 24 24" focusable="false">
                                                                        <path d="M16 3h5v5"></path>
                                                                        <path d="M21 3 9 15"></path>
                                                                        <path d="M8 21H3v-5"></path>
                                                                        <path d="M3 21 15 9"></path>
                                                                    </svg>
                                                                </span>
                                                                Swap meal
                                                            </span>
                                                        </button>
                                                    </form>

                                                    <form method="post"
                                                          action="@Url.Action("IgnoreMeal", "AislePilot")#aislepilot-meals"
                                                          class="aislepilot-swap-form aislepilot-ignore-form aislepilot-card-action-inline"
                                                          data-preserve-scroll-form
                                                          data-ajax-swap-form>
                                                        @Html.AntiForgeryToken()
                                                        <partial name="_AislePilotHiddenRequestFields"
                                                                 model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                                        <input type="hidden" name="dayIndex" value="@mealIndex" />
                                                        @{
                                                            var ignoreActionLabel = isIgnored ? "Include meal" : "Ignore meal";
                                                        }
                                                        <button type="submit"
                                                                class="aislepilot-swap-btn is-secondary is-icon-only"
                                                                data-loading-label="Updating..."
                                                                data-loading-delay-ms="180"
                                                                aria-label="@ignoreActionLabel"
                                                                title="@ignoreActionLabel">
                                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                <svg viewBox="0 0 24 24" focusable="false">
                                                                    @if (isIgnored)
                                                                    {
                                                                        <path d="M4 12h16"></path>
                                                                        <path d="M12 4v16"></path>
                                                                    }
                                                                    else
                                                                    {
                                                                        <path d="M4 12h16"></path>
                                                                    }
                                                                </svg>
                                                            </span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </section>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="aislepilot-shop" aria-label="Shopping" role="tabpanel" aria-labelledby="aislepilot-tab-shop" class="aislepilot-window-panel" data-window-name="Shopping">
                    <div class="aislepilot-shopping-grid">
                        @foreach (var department in groupedItems)
                        {
                            <article class="aislepilot-card">
                                <h3>@department.Key</h3>
                                <ul class="aislepilot-shop-list">
                                    @foreach (var item in department)
                                    {
                                        <li>
                                            <label class="aislepilot-checkbox-item">
                                                <input type="checkbox" />
                                                <span>@item.Name (@item.QuantityDisplay) - @item.EstimatedCost.ToString("C", ukCulture)</span>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </article>
                        }
                    </div>
                </section>

                <section id="aislepilot-export" aria-label="Export" role="tabpanel" aria-labelledby="aislepilot-tab-export" class="aislepilot-window-panel" data-window-name="Export">
                    <div class="aislepilot-export-actions">
                        <form method="post" asp-action="ExportPlanPack">
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                            <button type="submit" class="aislepilot-export-btn" data-loading-label="Building PDF...">Download full plan pack (.pdf)</button>
                        </form>

                        <form method="post" asp-action="ExportChecklist">
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                            <button type="submit" class="aislepilot-export-btn" data-loading-label="Building checklist...">Download shopping checklist (.txt)</button>
                        </form>

                        <button type="button" class="aislepilot-export-btn" onclick="window.print()">Print current view</button>

                        <div data-notes-export-shell>
                            <textarea hidden data-notes-export-content>@shoppingListNotesText</textarea>
                            <button type="button"
                                    class="aislepilot-export-btn"
                                    data-notes-export-trigger
                                    data-notes-default-label="Share shopping list to iPhone Notes"
                                    data-notes-shared-label="Share sheet opened. Choose Notes."
                                    data-notes-copied-label="Shopping list copied. Paste into Notes."
                                    data-notes-failed-label="Could not share. Try again.">
                                Share shopping list to iPhone Notes
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </section>
}
