                                            var slotIsIgnored = ignoredMealSlotIndexes.Contains(slotEntry.index) || slotMeal.IsIgnored;
                                            var slotSummaryMeta = slotIsIgnored
                                                ? "Removed"
                                                : $"{slotMeal.EstimatedCost.ToString("C", ukCulture)} \u00A0\u00A0\u00B7\u00A0\u00A0 {Math.Max(0, slotMeal.EstimatedPrepMinutes)} mins";
                                            var slotTabId = $"{tabPrefix}-tab-{slotIndex}";
