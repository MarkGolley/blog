                                                <p class="aislepilot-card-kicker">Ingredients</p>
                                                <ul class="case-list">
                                                    @if (result.DessertAddOnIngredientLines.Count == 0)
                                                    {
                                                        <li>Ingredients are included in your shopping list.</li>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var ingredientLine in result.DessertAddOnIngredientLines)
                                                        {
                                                            <li>@ingredientLine</li>
                                                        }
                                                    }
                                                </ul>
                                                <p class="aislepilot-card-kicker">Method</p>
                                                <ol class="case-list">
                                                    <li>Heat oven to 180C and line a tray-bake tin.</li>
                                                    <li>Cream butter and sugar, then beat in eggs.</li>
                                                    <li>Fold in flour and cocoa, then spread mixture in the tin.</li>
                                                    <li>Bake until springy and cool before slicing.</li>
                                                </ol>
                                            </div>
                                        </section>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="aislepilot-shop" aria-label="Shopping" role="tabpanel" aria-labelledby="aislepilot-tab-shop" class="aislepilot-window-panel aislepilot-shop-panel" data-window-name="Shopping">
                    @if (result.IncludeDessertAddOn)
                    {
                        <p class="aislepilot-window-meta">
                            Dessert add-on ingredients are included in this list (@result.DessertAddOnEstimatedCost.ToString("C", ukCulture)).
                        </p>
                    }
                    <div class="aislepilot-shopping-grid">
                        @foreach (var department in groupedItems)
                        {
                            <article class="aislepilot-card aislepilot-shop-card">
                                <h3>@department.Key</h3>
                                <ul class="aislepilot-shop-list">
                                    @foreach (var item in department)
                                    {
                                        var shoppingItemKey = $"{department.Key}|{item.Name}|{item.QuantityDisplay}|{item.EstimatedCost.ToString("0.00", CultureInfo.InvariantCulture)}";
                                        <li>
                                            <label class="aislepilot-checkbox-item"
                                                   data-shopping-item-label
                                                   data-shopping-item-key="@shoppingItemKey">
                                                <input type="checkbox"
                                                       data-shopping-item-input
                                                       aria-label="Mark @item.Name as already have this ingredient" />
                                                <span data-shopping-item-text>@item.Name (@item.QuantityDisplay) - @item.EstimatedCost.ToString("C", ukCulture)</span>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </article>
                        }
                        <article class="aislepilot-card aislepilot-shop-card aislepilot-shop-card-custom"
                                 data-custom-shopping-shell>
                            <h3>Your extra items</h3>
                            <p class="aislepilot-card-meta">Add common purchases like toilet roll, cleaning supplies, or anything else you want on this trip.</p>
                            <form class="aislepilot-custom-shopping-form" data-custom-shopping-form>
                                <label class="sr-only" for="aislepilot-custom-shopping-input">Add your own shopping item</label>
                                <input id="aislepilot-custom-shopping-input"
                                       type="text"
                                       class="aislepilot-custom-shopping-input"
                                       data-custom-shopping-input
                                       maxlength="80"
                                       placeholder="Add your own item" />
                                <button type="submit"
                                        class="aislepilot-swap-btn is-secondary is-compact"
                                        data-custom-shopping-add>
                                    Add item
                                </button>
                            </form>
                            <p class="aislepilot-card-meta" data-custom-shopping-empty>No extra items yet.</p>
                            <ul class="aislepilot-shop-list" data-custom-shopping-list hidden></ul>
                        </article>
                    </div>
                </section>

                <section id="aislepilot-export" aria-label="Exports" role="tabpanel" aria-labelledby="aislepilot-tab-export" class="aislepilot-window-panel aislepilot-export-panel" data-window-name="Exports">
                    <div class="aislepilot-export-actions">
                        <div class="aislepilot-export-action">
                            <form method="post" asp-action="ExportPlanPack" data-export-theme-form>
                                @Html.AntiForgeryToken()
                                <partial name="_AislePilotHiddenRequestFields"
                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                <input type="hidden" name="exportTheme" value="light" data-export-theme-input />
                                <button type="submit" class="aislepilot-export-btn" data-loading-label="Building PDF...">Download full plan pack (.pdf)</button>
                            </form>
                        </div>

                        <div class="aislepilot-export-action">
                            <form method="post" asp-action="ExportChecklist">
                                @Html.AntiForgeryToken()
                                <partial name="_AislePilotHiddenRequestFields"
                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                <button type="submit" class="aislepilot-export-btn" data-loading-label="Building checklist...">Download shopping checklist (.txt)</button>
                            </form>
                        </div>

                        <div class="aislepilot-export-action">
                            <button type="button" class="aislepilot-export-btn" onclick="window.print()">Print current view</button>
                        </div>

                        <div class="aislepilot-export-action" data-notes-export-shell>
                            <textarea hidden data-notes-export-content>@shoppingListNotesText</textarea>
                            <button type="button"
                                    class="aislepilot-export-btn"
                                    data-notes-export-trigger
                                    data-notes-default-label="Share shopping list"
                                    data-notes-shared-label="Share sheet opened. Choose your app."
                                    data-notes-copied-label="Shopping list copied."
                                    data-notes-failed-label="Could not share. Try again.">
                                Share shopping list
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </section>
}

