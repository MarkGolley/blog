                            var firstSlotEntry = dayGroup.Entries[0];
                            var firstSlotMeal = firstSlotEntry.meal;
                            var firstSlotIsIgnored = ignoredMealSlotIndexes.Contains(firstSlotEntry.index) || firstSlotMeal.IsIgnored;
                            var firstSlotMealImageUrl = AislePilotMealImageUrlResolver.ResolveClientMealImageUrl(firstSlotMeal.MealImageUrl);
                            var daySummaryMeta = firstSlotIsIgnored
                                ? "Removed"
