                                            ? $"{dayGroup.Day}: cook-extra x{dayGroup.LeftoverDaysCovered}"
                                            : $"{dayGroup.Day}: no cook-extra";
                                        var dayAllocationControlClass = dayGroup.LeftoverDaysCovered > 0
                                            ? "aislepilot-day-card-leftover-controls is-leftover-source is-menu-only"
