                                                                                <path d="M21 3 9 15"></path>
                                                                                <path d="M8 21H3v-5"></path>
                                                                                <path d="M3 21 15 9"></path>
                                                                            </svg>
                                                                        </span>
                                                                        <span class="aislepilot-swap-action-label">Swap</span>
                                                                    </span>
                                                                </button>
                                                            </form>

                                                            <form method="post"
                                                                  action="@Url.Action("ToggleEnjoyedMeal", "AislePilot")#aislepilot-meals"
                                                                  class="aislepilot-swap-form aislepilot-favorite-form aislepilot-card-more-action-form"
                                                                  data-preserve-scroll-form
                                                                  data-ajax-swap-form
                                                                  data-skip-submit-loading>
