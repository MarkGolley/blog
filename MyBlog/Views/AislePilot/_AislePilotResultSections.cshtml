@using System.Globalization
@using System.Text
@using System.Text.Json
@using MyBlog.Models
@using MyBlog.Services
@model AislePilotPageViewModel

@if (Model.HasResult && Model.Result is not null)
{
    var result = Model.Result;
    var ukCulture = CultureInfo.GetCultureInfo("en-GB");
    var fallbackMealImageUrl = AislePilotMealImageUrlResolver.ResolveClientMealImageUrl("/images/aislepilot-icon.svg");
    var mealImagesPollUrl = Url.Action("MealImages", "AislePilot") ?? "/projects/aisle-pilot/meal-images";
    var aisleRank = result.AisleOrderUsed
        .Select((department, index) => new { department, index })
        .ToDictionary(x => x.department, x => x.index, StringComparer.OrdinalIgnoreCase);
    var groupedItems = result.ShoppingItems
        .GroupBy(item => item.Department)
        .OrderBy(group => aisleRank.GetValueOrDefault(group.Key, int.MaxValue))
        .ToList();
    var planDays = Math.Clamp(result.PlanDays, 1, 7);
    var weekDayNames = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    var planWeekDayNames = weekDayNames.Take(planDays).ToArray();
    var mealTypeOrder = new[] { "Breakfast", "Lunch", "Dinner" };
    var mealTypeRank = mealTypeOrder
        .Select((type, index) => new { type, index })
        .ToDictionary(x => x.type, x => x.index, StringComparer.OrdinalIgnoreCase);
    var dayMealGroups = result.MealPlan
        .Select((meal, index) => new { meal, index })
        .GroupBy(entry => entry.meal.Day)
        .Select(group => new
        {
            Day = group.Key,
            Entries = group
                .OrderBy(entry => mealTypeRank.GetValueOrDefault(entry.meal.MealType ?? string.Empty, int.MaxValue))
                .ThenBy(entry => entry.index)
                .ToList(),
            LeftoverDaysCovered = group.Max(entry => entry.meal.LeftoverDaysCovered)
        })
        .ToList();
    var canReorderDayCards = dayMealGroups.Count > 1;
    var weekDayLookup = planWeekDayNames
        .Select((name, index) => new { name, index })
        .ToDictionary(x => x.name, x => x.index, StringComparer.OrdinalIgnoreCase);
    var leftoverSourceWeekDayIndexes = dayMealGroups
        .SelectMany(dayGroup =>
        {
            if (!weekDayLookup.TryGetValue(dayGroup.Day, out var weekDayIndex))
            {
                return Enumerable.Empty<int>();
            }

            return Enumerable.Repeat(weekDayIndex, dayGroup.LeftoverDaysCovered);
        })
        .ToList();
    var leftoverSourceDayIndexesCsv = string.Join(",", leftoverSourceWeekDayIndexes);
    var currentPlanMealNames = result.MealPlan
        .Select(meal => meal.MealName)
        .ToList();
    HashSet<string> ParseSavedEnjoyedMealNames(string? savedMealNamesState)
    {
        if (string.IsNullOrWhiteSpace(savedMealNamesState))
        {
            return [];
        }

        try
        {
            var parsed = JsonSerializer.Deserialize<List<string>>(savedMealNamesState);
            return (parsed ?? [])
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Select(name => name.Trim())
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            return [];
        }
    }
    var savedEnjoyedMealNames = ParseSavedEnjoyedMealNames(Model.Request.SavedEnjoyedMealNamesState);
    string GetShortDayLabel(string? dayName)
    {
        var normalized = dayName?.Trim();
        if (string.IsNullOrWhiteSpace(normalized)) return "Day";
        return normalized switch { "Monday" => "Mon", "Tuesday" => "Tue", "Wednesday" => "Wed", "Thursday" => "Thu", "Friday" => "Fri", "Saturday" => "Sat", "Sunday" => "Sun", _ => normalized.Length <= 3 ? normalized : normalized[..3] };
    }
    var mealCount = result.MealPlan.Count;
    HashSet<int> ParseIgnoredMealSlotIndexes(string? ignoredMealSlotIndexesCsv, int maxMealSlotIndex)
    {
        if (string.IsNullOrWhiteSpace(ignoredMealSlotIndexesCsv))
        {
            return [];
        }

        return ignoredMealSlotIndexesCsv
            .Split([',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(token => int.TryParse(token, out var index) ? index : -1)
            .Where(index => index >= 0 && index <= maxMealSlotIndex)
            .Distinct()
            .ToHashSet();
    }
    var ignoredMealSlotIndexes = ParseIgnoredMealSlotIndexes(Model.Request.IgnoredMealSlotIndexesCsv, Math.Max(0, mealCount - 1));
    var safeHouseholdSize = Math.Clamp(Model.Request.HouseholdSize, 1, 8);
    var householdLabel = safeHouseholdSize == 1 ? "person" : "people";
    var budgetDeltaSummaryText = result.BudgetDelta switch
    {
        > 0m => $"{result.BudgetDelta.ToString("C", ukCulture)} under",
        < 0m => $"{Math.Abs(result.BudgetDelta).ToString("C", ukCulture)} over",
        _ => "On budget"
    };
    var layoutInsight = result.LayoutInsight ?? new AislePilotSupermarketLayoutInsightViewModel();
    var layoutVerificationText = layoutInsight.LastVerifiedUtc.HasValue ? $"Checked {layoutInsight.LastVerifiedUtc.Value.ToLocalTime():MMM yyyy}" : "Chain default";
    var layoutConfidenceText = string.IsNullOrWhiteSpace(layoutInsight.ConfidenceLabel) ? layoutVerificationText : $"{layoutInsight.ConfidenceLabel} confidence. {layoutVerificationText}";
    var priceInsight = result.PriceInsight ?? new AislePilotSupermarketPriceInsightViewModel();
    var normalizedPriceFactor = Math.Clamp(priceInsight.RelativeCostFactor, 0.75m, 1.35m);
    var priceDeltaPercent = decimal.Round(Math.Abs((normalizedPriceFactor - 1m) * 100m), 0, MidpointRounding.AwayFromZero);
    var priceAdjustmentText = priceDeltaPercent == 0m
        ? "around Tesco baseline"
        : normalizedPriceFactor > 1m
            ? $"{priceDeltaPercent:0}% above Tesco baseline"
            : $"{priceDeltaPercent:0}% below Tesco baseline";
    var priceVerificationText = priceInsight.LastVerifiedUtc.HasValue ? $"Checked {priceInsight.LastVerifiedUtc.Value.ToLocalTime():MMM yyyy}" : "Standard basket";
    var priceConfidenceText = string.IsNullOrWhiteSpace(priceInsight.ConfidenceLabel) ? priceVerificationText : $"{priceInsight.ConfidenceLabel} confidence. {priceVerificationText}";
    var layoutSummary = string.IsNullOrWhiteSpace(layoutInsight.SourceLabel) ? null : $"{layoutInsight.SourceLabel}. {layoutConfidenceText}";
    var layoutReviewSummary = layoutInsight.NeedsReview ? "Branch aisle order can vary. Use Custom if the order looks wrong." : null;
    var supermarketPriceSummary = !string.IsNullOrWhiteSpace(priceInsight.SourceLabel)
        ? $"{priceInsight.SourceLabel}. {priceAdjustmentText}.{(string.IsNullOrWhiteSpace(priceInsight.RelativeCostBasis) ? string.Empty : $" {priceInsight.RelativeCostBasis}.")} {priceConfidenceText}{(priceInsight.NeedsReview ? ". Stored public basket estimate." : string.Empty)}"
        : priceInsight.NeedsReview
            ? "Pricing is estimated from stored public basket data."
            : null;
    var supermarketInsights = AislePilotSupermarketInsightStripViewModel.Create(
        layoutInsight,
        priceInsight,
        priceAdjustmentText,
        layoutSummary,
        supermarketPriceSummary,
        layoutReviewSummary);
    var mealIngredientEstimateLabel = "Meal ingredient estimate";
    var shoppingEstimateDisclaimer = "This estimate covers the ingredients used in these meals. It adjusts for your selected supermarket using stored public pricing data. Actual checkout can be higher if shops only sell larger packs or bags.";
    var shoppingListNotesBuilder = new StringBuilder();
    shoppingListNotesBuilder.AppendLine("AislePilot Shopping List");
    shoppingListNotesBuilder.AppendLine($"Supermarket: {result.Supermarket}");
    shoppingListNotesBuilder.AppendLine($"{mealIngredientEstimateLabel}: {result.EstimatedTotalCost.ToString("C", ukCulture)}");
    if (!string.IsNullOrWhiteSpace(priceInsight.SourceLabel))
    {
        shoppingListNotesBuilder.AppendLine($"Store pricing: {priceInsight.SourceLabel} ({priceAdjustmentText})");
    }
    shoppingListNotesBuilder.AppendLine(shoppingEstimateDisclaimer);
    shoppingListNotesBuilder.AppendLine();
    foreach (var department in groupedItems)
    {
        shoppingListNotesBuilder.AppendLine(department.Key);
        foreach (var item in department)
        {
            shoppingListNotesBuilder.AppendLine(
                $"[ ] {item.Name} ({item.QuantityDisplay}) - Est. {item.EstimatedCost.ToString("C", ukCulture)}");
        }
        shoppingListNotesBuilder.AppendLine();
    }
    var shoppingListNotesText = shoppingListNotesBuilder.ToString().TrimEnd();
    var supportGridClasses = result.LeftoverDays > 0
        ? "aislepilot-budget-grid aislepilot-budget-grid--support has-leftovers"
        : "aislepilot-budget-grid aislepilot-budget-grid--support";
    var summaryCardClasses = "aislepilot-stat-card aislepilot-stat-card--support";
    AislePilotHiddenRequestFieldsViewModel BuildHiddenRequestFields(
        bool includeCurrentPlanMealNames = false,
        bool includeLeftoverCsvDataAttribute = false)
    {
        return new AislePilotHiddenRequestFieldsViewModel
        {
            ReturnUrl = Model.ReturnUrl,
            Request = Model.Request,
            LeftoverCookDayIndexesCsv = leftoverSourceDayIndexesCsv,
            CurrentPlanMealNames = includeCurrentPlanMealNames
                ? currentPlanMealNames
                : Array.Empty<string>(),
            IncludeCurrentPlanMealNames = includeCurrentPlanMealNames,
            IncludeLeftoverCsvDataAttribute = includeLeftoverCsvDataAttribute
        };
    }

    void RenderMealImageHint(
        string screenReaderLabel,
        bool includeMacros = true,
        bool includeIngredients = true,
        bool includeMethod = true)
    {
        <span class="aislepilot-meal-image-hint" aria-hidden="true">
            <span class="aislepilot-meal-image-hint-primary">
                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
                        <circle cx="12" cy="12" r="2.5"></circle>
                    </svg>
                </span>
                <span>Recipe</span>
            </span>
            <span class="aislepilot-meal-image-hint-chips">
                @if (includeMacros)
                {
                    <span class="aislepilot-meal-image-hint-chip">
                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <line x1="5" y1="18" x2="19" y2="18"></line>
                                <rect x="6" y="11" width="2.8" height="5" rx="0.6"></rect>
                                <rect x="10.6" y="8" width="2.8" height="8" rx="0.6"></rect>
                                <rect x="15.2" y="5" width="2.8" height="11" rx="0.6"></rect>
                            </svg>
                        </span>
                        <span>Macros</span>
                    </span>
                }
                @if (includeIngredients)
                {
                    <span class="aislepilot-meal-image-hint-chip">
                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <circle cx="6" cy="7" r="1"></circle>
                                <circle cx="6" cy="12" r="1"></circle>
                                <circle cx="6" cy="17" r="1"></circle>
                                <line x1="9" y1="7" x2="18" y2="7"></line>
                                <line x1="9" y1="12" x2="18" y2="12"></line>
                                <line x1="9" y1="17" x2="18" y2="17"></line>
                            </svg>
                        </span>
                        <span>Ingredients</span>
                    </span>
                }
                @if (includeMethod)
                {
                    <span class="aislepilot-meal-image-hint-chip">
                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M5 7h4"></path>
                                <path d="M5 12h4"></path>
                                <path d="M5 17h4"></path>
                                <path d="M12 7h7"></path>
                                <path d="M12 12h7"></path>
                                <path d="M12 17h7"></path>
                            </svg>
                        </span>
                        <span>Method</span>
                    </span>
                }
            </span>
        </span>
        <span class="sr-only">@screenReaderLabel</span>
    }

    <section id="aislepilot-overview" aria-labelledby="aislepilot-budget-title" class="aislepilot-shell" data-reveal>
        <div class="aislepilot-section-head aislepilot-overview-head">
            <div class="aislepilot-overview-title-row">
                <div>
                    <h2 id="aislepilot-budget-title" class="aislepilot-section-title">Plan snapshot</h2>
                    <p class="aislepilot-overview-caption">Budget, spend, and weekly structure at a glance.</p>
                </div>
            </div>
            <div class="aislepilot-overview-actions">
                <div class="aislepilot-overview-actions-inline">
                    <form method="post" action="@Url.Action("Index", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                        @Html.AntiForgeryToken()
                        <partial name="_AislePilotHiddenRequestFields"
                                 model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                        <input type="hidden" name="forceRefreshWeek" value="true" />
                        <button type="submit"
                                class="aislepilot-overview-regenerate-btn is-secondary"
                                data-loading-label="Refreshing plan..."
                                data-show-plan-skeleton
                                aria-label="Refresh plan"
                                title="Refresh plan">
                            <span class="aislepilot-btn-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                        <path d="M20 4v6h-6"></path>
                                    </svg>
                                </span>
                                <span>Refresh plan</span>
                            </span>
                        </button>
                    </form>
                    <form method="post" action="@Url.Action("SaveWeek", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                        @Html.AntiForgeryToken()
                        <partial name="_AislePilotHiddenRequestFields"
                                 model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                        <button type="submit"
                                class="aislepilot-overview-regenerate-btn is-secondary"
                                data-loading-label="Saving week...">
                            <span class="aislepilot-btn-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M5 4h11l3 3v13H5z"></path>
                                        <path d="M8 4v6h8V4"></path>
                                        <path d="M9 20v-6h6v6"></path>
                                    </svg>
                                </span>
                                <span>Save week</span>
                            </span>
                        </button>
                    </form>
                </div>
                <details class="aislepilot-overview-actions-dropdown" data-overview-actions-menu>
                    <summary class="aislepilot-overview-actions-trigger is-icon-only"
                             aria-label="Overview actions"
                             aria-expanded="false"
                             title="Overview actions">
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <line x1="4" y1="7" x2="20" y2="7"></line>
                                    <line x1="4" y1="12" x2="20" y2="12"></line>
                                    <line x1="4" y1="17" x2="20" y2="17"></line>
                                </svg>
                            </span>
                            <span class="sr-only">Overview actions</span>
                        </span>
                    </summary>
                    <div class="aislepilot-overview-actions-menu" role="group" aria-label="Overview actions">
                        <form method="post" action="@Url.Action("Index", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                            <input type="hidden" name="forceRefreshWeek" value="true" />
                            <button type="submit"
                                    class="aislepilot-overview-regenerate-btn is-secondary"
                                    data-loading-label="Refreshing plan..."
                                    data-show-plan-skeleton
                                    aria-label="Refresh plan"
                                    title="Refresh plan">
                                <span class="aislepilot-btn-label">
                                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" focusable="false">
                                            <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                            <path d="M20 4v6h-6"></path>
                                        </svg>
                                    </span>
                                    <span>Refresh plan</span>
                                </span>
                            </button>
                        </form>
                        <form method="post" action="@Url.Action("SaveWeek", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                            <button type="submit"
                                    class="aislepilot-overview-regenerate-btn is-secondary"
                                    data-loading-label="Saving week...">
                                <span class="aislepilot-btn-label">
                                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" focusable="false">
                                            <path d="M5 4h11l3 3v13H5z"></path>
                                            <path d="M8 4v6h8V4"></path>
                                            <path d="M9 20v-6h6v6"></path>
                                        </svg>
                                    </span>
                                    <span>Save week</span>
                                </span>
                            </button>
                        </form>
                    </div>
                </details>
            </div>
        </div>
        <div id="aislepilot-overview-content" class="aislepilot-overview-content" data-overview-content>
            @if (result.IsOverBudget)
            {
                <div class="aislepilot-overbudget-flag" role="status" aria-live="polite">
                    <p class="aislepilot-overbudget-title">
                        This plan is @Math.Abs(result.BudgetDelta).ToString("C", ukCulture) over your weekly budget.
                    </p>
                    <p class="aislepilot-overbudget-note">
                        @(string.IsNullOrWhiteSpace(result.BudgetRebalanceStatusMessage)
                            ? "Keep this plan if you are happy to spend more, or refresh with a lower-cost mix."
                            : result.BudgetRebalanceStatusMessage)
                    </p>
                    <form method="post"
                          action="@Url.Action("RebalanceBudget", "AislePilot")#aislepilot-overview"
                          class="aislepilot-overview-regenerate-form">
                        @Html.AntiForgeryToken()
                        <partial name="_AislePilotHiddenRequestFields"
                                 model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                        <button type="submit"
                                class="aislepilot-overview-regenerate-btn"
                                data-loading-label="Refreshing lower-cost plan..."
                                data-show-plan-skeleton>
                            Refresh lower-cost plan
                        </button>
                    </form>
                </div>
            }
            <div class="aislepilot-budget-grid aislepilot-budget-grid--primary"
                 data-overview-primary-grid>
                <article class="aislepilot-stat-card aislepilot-stat-card--meta aislepilot-stat-card--supermarket"
                         data-supermarket-card>
                    <p class="aislepilot-stat-label">Supermarket</p>
                    <p class="aislepilot-stat-value">@result.Supermarket</p>
                </article>
                <article class="aislepilot-stat-card aislepilot-stat-card--meta">
                    <p class="aislepilot-stat-label">Portion size</p>
                    <p class="aislepilot-stat-value">@result.PortionSize</p>
                </article>
                <article class="aislepilot-stat-card aislepilot-stat-card--meta">
                    <p class="aislepilot-stat-label">Cooking for</p>
                    <p class="aislepilot-stat-value">@safeHouseholdSize @householdLabel</p>
                </article>
                <article class="aislepilot-stat-card aislepilot-stat-card--featured">
                    <p class="aislepilot-stat-label">Budget</p>
                    <p class="aislepilot-stat-value">@result.WeeklyBudget.ToString("C", ukCulture)</p>
                </article>
                <article class="aislepilot-stat-card aislepilot-stat-card--featured">
                    <p class="aislepilot-stat-label">@mealIngredientEstimateLabel</p>
                    <p class="aislepilot-stat-value">@result.EstimatedTotalCost.ToString("C", ukCulture)</p>
                </article>
                <article class="aislepilot-stat-card aislepilot-stat-card--status @(result.IsOverBudget ? "is-over-budget" : "is-on-budget")">
                    <p class="aislepilot-stat-label">Budget difference</p>
                    <p class="aislepilot-stat-value @(result.IsOverBudget ? "is-over-budget" : "is-on-budget")">
                        @result.BudgetDelta.ToString("C", ukCulture)
                    </p>
                </article>
            </div>
            <div class="@supportGridClasses"
                 data-overview-support-grid>
                <article class="@summaryCardClasses">
                    <p class="aislepilot-stat-label">Plan length</p>
                    <p class="aislepilot-stat-value">@result.PlanDays day(s)</p>
                </article>
                <article class="@summaryCardClasses">
                    <p class="aislepilot-stat-label">Cook days</p>
                    <p class="aislepilot-stat-value">@result.CookDays</p>
                </article>
                <article class="@summaryCardClasses">
                    <p class="aislepilot-stat-label">Meals per day</p>
                    <p class="aislepilot-stat-value">@result.MealsPerDay</p>
                </article>
                @if (result.LeftoverDays > 0)
                {
                    <article class="@summaryCardClasses">
                        <p class="aislepilot-stat-label">Leftovers</p>
                        <p class="aislepilot-stat-value">@result.LeftoverDays day(s)</p>
                    </article>
                }
            </div>
            <partial name="_AislePilotOverviewSupermarketInsights" model="supermarketInsights" />
        </div>
    </section>

    <section class="aislepilot-shell aislepilot-window-shell" aria-labelledby="aislepilot-window-title" data-aislepilot-window data-reveal>
        <div class="aislepilot-mobile-context" aria-label="Plan summary and quick navigation">
            <div class="aislepilot-mobile-context-summary">
                <p class="aislepilot-mobile-context-meta">
                    <span class="aislepilot-mobile-context-title">Weekly plan</span>
                    <span class="aislepilot-mobile-context-meta-values">
                        <span>Meal est. @result.EstimatedTotalCost.ToString("C", ukCulture)</span>
                        <span aria-hidden="true">&middot;</span>
                        <span class="aislepilot-mobile-context-budget-status @(result.IsOverBudget ? "is-over-budget" : "is-on-budget")">@budgetDeltaSummaryText</span>
                    </span>
                </p>
            </div>
            <div class="aislepilot-mobile-context-jumps" role="tablist" aria-label="Jump to section">
                <button type="button"
                        class="aislepilot-mobile-context-jump is-active"
                        data-window-tab="aislepilot-meals"
                        role="tab"
                        aria-controls="aislepilot-meals"
                        aria-selected="true"
                        aria-current="page"
                        aria-label="Show meals"
                        title="Show meals">
                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <circle cx="5" cy="7" r="1"></circle>
                            <circle cx="5" cy="12" r="1"></circle>
                            <circle cx="5" cy="17" r="1"></circle>
                            <path d="M8 7h11M8 12h11M8 17h11"></path>
                        </svg>
                    </span>
                    <span class="aislepilot-mobile-context-jump-text">Meals</span>
                </button>
                <button type="button"
                        class="aislepilot-mobile-context-jump"
                        data-window-tab="aislepilot-shop"
                        role="tab"
                        aria-controls="aislepilot-shop"
                        aria-selected="false"
                        aria-current="false"
                        aria-label="Show shopping list"
                        title="Show shopping list">
                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <circle cx="9" cy="19" r="1.5"></circle>
                            <circle cx="17" cy="19" r="1.5"></circle>
                            <path d="M3 4h2l2.4 10h10.8l1.8-7H7"></path>
                        </svg>
                    </span>
                    <span class="aislepilot-mobile-context-jump-text">Shop</span>
                </button>
                <button type="button"
                        class="aislepilot-mobile-context-jump"
                        data-window-tab="aislepilot-export"
                        role="tab"
                        aria-controls="aislepilot-export"
                        aria-selected="false"
                        aria-current="false"
                        aria-label="Show exports"
                        title="Show exports">
                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M12 16V6"></path>
                            <path d="m8 10 4-4 4 4"></path>
                            <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path>
                        </svg>
                    </span>
                    <span class="aislepilot-mobile-context-jump-text">Export</span>
                </button>
            </div>
        </div>
        <div class="aislepilot-window-head">
            <h2 id="aislepilot-window-title" class="sr-only">Plan results</h2>
            <div class="aislepilot-window-nav">
                <p class="aislepilot-window-nav-hint" data-window-hint>Use tabs to switch between meals, shopping, and exports.</p>
                <div class="aislepilot-window-tabs" role="tablist" aria-label="AislePilot weekly plan views">
                    <button type="button"
                            id="aislepilot-tab-meals"
                            class="aislepilot-window-tab is-active"
                            data-window-tab="aislepilot-meals"
                            role="tab"
                            aria-controls="aislepilot-meals"
                            aria-selected="true"
                            aria-current="page"
                            aria-label="Meals"
                            title="Meals">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="5" cy="7" r="1"></circle>
                                    <circle cx="5" cy="12" r="1"></circle>
                                    <circle cx="5" cy="17" r="1"></circle>
                                    <path d="M8 7h11M8 12h11M8 17h11"></path>
                                </svg>
                            </span>
                            <span class="aislepilot-tab-text">Meals</span>
                        </span>
                    </button>
                    <button type="button"
                            id="aislepilot-tab-shop"
                            class="aislepilot-window-tab"
                            data-window-tab="aislepilot-shop"
                            role="tab"
                            aria-controls="aislepilot-shop"
                            aria-selected="false"
                            aria-current="false"
                            aria-label="Shopping"
                            title="Shopping">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="9" cy="19" r="1.5"></circle>
                                    <circle cx="17" cy="19" r="1.5"></circle>
                                    <path d="M3 4h2l2.4 10h10.8l1.8-7H7"></path>
                                </svg>
                            </span>
                            <span class="aislepilot-tab-text">Shop</span>
                        </span>
                    </button>
                    <button type="button"
                            id="aislepilot-tab-export"
                            class="aislepilot-window-tab"
                            data-window-tab="aislepilot-export"
                            role="tab"
                            aria-controls="aislepilot-export"
                            aria-selected="false"
                            aria-current="false"
                            aria-label="Exports"
                            title="Exports">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M12 16V6"></path>
                                    <path d="m8 10 4-4 4 4"></path>
                                    <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path>
                                </svg>
                            </span>
                            <span class="aislepilot-tab-text">Export</span>
                        </span>
                    </button>
                </div>
            </div>
        </div>
        <div class="aislepilot-window-viewport" data-window-viewport>
            <div class="aislepilot-window-track" data-window-track>
                <section id="aislepilot-meals" aria-label="Meals" role="tabpanel" aria-labelledby="aislepilot-tab-meals" class="aislepilot-window-panel" data-window-name="Meals">
                    @if (result.PlanDays > 1)
                    {
                        <form method="post"
                              action="@Url.Action("Index", "AislePilot")#aislepilot-meals"
                              class="aislepilot-leftover-rebalance-form"
                              data-leftover-rebalance-form
                              data-ajax-swap-form
                              data-leftover-max-extra="@Math.Max(0, result.PlanDays - 1)"
                              data-preserve-scroll-form
                              hidden>
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true, includeLeftoverCsvDataAttribute: true)" />
                        </form>
                    }
                    @if (canReorderDayCards)
                    {
                        <form method="post"
                              action="@Url.Action("MoveDayCard", "AislePilot")#aislepilot-meals"
                              class="aislepilot-day-reorder-form"
                              data-day-reorder-form
                              data-ajax-swap-form
                              data-preserve-scroll-form
                              hidden>
                            @Html.AntiForgeryToken()
                            <partial name="_AislePilotHiddenRequestFields"
                                     model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true, includeLeftoverCsvDataAttribute: true)" />
                        </form>
                    }
                    <section class="aislepilot-day-carousel"
                             data-day-card-carousel
                             aria-label="Meal plan day cards"
                             data-day-card-count="@dayMealGroups.Count">
                        <div class="aislepilot-day-carousel-header">
                            <div class="aislepilot-day-carousel-status"
                                 aria-live="polite"
                                 aria-atomic="true"
                                 data-day-carousel-status>
                                Day 1 of @dayMealGroups.Count
                            </div>
                            @if (dayMealGroups.Count > 1)
                            {
                                <div class="aislepilot-day-carousel-controls">
                                    <button type="button"
                                            class="aislepilot-day-carousel-arrow"
                                            data-day-carousel-prev
                                            aria-label="Show previous day"
                                            disabled>
                                        <span aria-hidden="true">&#8249;</span>
                                    </button>
                                    <button type="button"
                                            class="aislepilot-day-carousel-arrow"
                                            data-day-carousel-next
                                            aria-label="Show next day">
                                        <span aria-hidden="true">&#8250;</span>
                                    </button>
                                </div>
                            }
                        </div>
                        <div class="aislepilot-meal-grid"
                             data-day-carousel-viewport
                             data-meal-image-poll-root
                             data-fallback-meal-image-url="@fallbackMealImageUrl"
                             data-meal-image-poll-enabled="@(Model.MealImagePollingEnabled ? "true" : "false")"
                             data-meal-image-poll-url="@mealImagesPollUrl">
                            <div class="aislepilot-day-carousel-track" data-day-carousel-track>
                                @{
                                    var dayGroupRenderIndex = 0;
                                }
                                @foreach (var dayGroup in dayMealGroups)
                                {
                                    var dayGroupIndex = dayGroupRenderIndex++;
                                    var firstMealIndex = dayGroup.Entries[0].index;
                                    var firstSlotEntry = dayGroup.Entries[0];
                                    var firstSlotMeal = firstSlotEntry.meal;
                                    var firstSlotIsIgnored = ignoredMealSlotIndexes.Contains(firstSlotEntry.index) || firstSlotMeal.IsIgnored;
                                    var daySummaryMeta = firstSlotIsIgnored
                                        ? "Removed"
                                        : $"{firstSlotMeal.EstimatedCost.ToString("C", ukCulture)} \u00A0\u00A0\u00B7\u00A0\u00A0 {Math.Max(0, firstSlotMeal.EstimatedPrepMinutes)} mins";
                                    var mealCardClass = dayGroup.LeftoverDaysCovered > 0
                                        ? "aislepilot-card aislepilot-day-card is-leftover-source"
                                        : "aislepilot-card aislepilot-day-card";
                                    var tabPrefix = $"meal-slot-{firstMealIndex}";
                                    var dayWeekIndex = weekDayLookup.TryGetValue(dayGroup.Day, out var resolvedWeekDayIndex)
                                        ? resolvedWeekDayIndex
                                        : Math.Clamp(dayGroupIndex, 0, Math.Max(0, result.PlanDays - 1));
                                    var serializedDayMealNames = JsonSerializer.Serialize(dayGroup.Entries.Select(entry => entry.meal.MealName).ToList());
                                    var serializedIgnoredFlags = JsonSerializer.Serialize(dayGroup.Entries
                                        .Select(entry => ignoredMealSlotIndexes.Contains(entry.index) || entry.meal.IsIgnored)
                                        .ToList());
                                    var dayGroupHasSpecialTreat = dayGroup.Entries.Any(entry => entry.meal.IsSpecialTreat);
                                    var dayCardHeadingId = $"day-card-heading-{firstMealIndex}";
                                    <article class="@mealCardClass"
                                             id="@($"day-card-{firstMealIndex}")"
                                             data-leftover-day-card
                                             data-day-index="@firstMealIndex"
                                             data-day-meal-card
                                             data-day-card-order="@dayGroupIndex"
                                             data-day-card-leftover-count="@dayGroup.LeftoverDaysCovered"
                                             data-day-card-meal-names="@serializedDayMealNames"
                                             data-day-card-ignored-flags="@serializedIgnoredFlags"
                                             data-day-card-day-name="@dayGroup.Day"
                                             data-day-card-day-position="@(dayGroupIndex + 1)"
                                             data-day-card-total-days="@dayMealGroups.Count"
                                             data-day-card-has-special-treat="@(dayGroupHasSpecialTreat ? "true" : "false")"
                                             data-day-card-slide
                                             aria-labelledby="@dayCardHeadingId"
                                             aria-roledescription="slide"
                                             aria-label="@($"{dayGroup.Day}, day {dayGroupIndex + 1} of {dayMealGroups.Count}")"
                                             aria-hidden="@(dayGroupIndex == 0 ? "false" : "true")">
                                        <div class="aislepilot-day-card-body">
                                <div class="aislepilot-card-head aislepilot-day-card-head">
                                    <div class="aislepilot-day-card-head-main">
                                        <p class="aislepilot-card-kicker" id="@dayCardHeadingId">@dayGroup.Day</p>
                                        @if (dayGroup.Entries.Count > 1)
                                        {
                                            <p class="aislepilot-day-card-meta"
                                               data-day-card-summary
                                               data-day-card-summary-default="@daySummaryMeta"
                                               aria-label="Selected meal cost and cook time">@daySummaryMeta</p>
                                        }
                                        else
                                        {
                                            <p class="aislepilot-day-card-meta">@daySummaryMeta</p>
                                        }
                                    </div>
                                    <div class="aislepilot-day-card-head-side">
                                        @if (result.PlanDays > 1)
                                        {
                                            var dayAllocationAriaLabel = dayGroup.LeftoverDaysCovered > 0
                                                ? $"{dayGroup.Day}: cook-extra x{dayGroup.LeftoverDaysCovered}"
                                                : $"{dayGroup.Day}: no cook-extra";
                                            var dayAllocationControlClass = dayGroup.LeftoverDaysCovered > 0
                                                ? "aislepilot-day-card-leftover-controls is-leftover-source is-menu-only"
                                                : "aislepilot-day-card-leftover-controls is-menu-only";
                                            <div class="@dayAllocationControlClass"
                                                 data-leftover-day-zone
                                                 data-day-index="@dayWeekIndex"
                                                 data-day-name="@dayGroup.Day"
                                                 data-leftover-count="@dayGroup.LeftoverDaysCovered"
                                                 aria-label="@dayAllocationAriaLabel">
                                                @{
                                                    var dayCountHiddenAttribute = dayGroup.LeftoverDaysCovered > 1 ? null : "hidden";
                                                }
                                                <span class="aislepilot-leftover-day-count" data-leftover-day-count @dayCountHiddenAttribute>x@dayGroup.LeftoverDaysCovered</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                @if (dayGroup.Entries.Count > 1)
                                {
                                    <div class="aislepilot-day-meal-tabs" role="tablist" aria-label="Meal slots for @dayGroup.Day">
                                        @for (var slotIndex = 0; slotIndex < dayGroup.Entries.Count; slotIndex++)
                                        {
                                            var slotEntry = dayGroup.Entries[slotIndex];
                                            var slotMeal = slotEntry.meal;
                                            var slotIsIgnored = ignoredMealSlotIndexes.Contains(slotEntry.index) || slotMeal.IsIgnored;
                                            var slotSummaryMeta = slotIsIgnored
                                                ? "Removed"
                                                : $"{slotMeal.EstimatedCost.ToString("C", ukCulture)} \u00A0\u00A0\u00B7\u00A0\u00A0 {Math.Max(0, slotMeal.EstimatedPrepMinutes)} mins";
                                            var slotTabId = $"{tabPrefix}-tab-{slotIndex}";
                                            <button type="button"
                                                    id="@slotTabId"
                                                    class="aislepilot-day-meal-tab@(slotIndex == 0 ? " is-active" : string.Empty)@(slotIsIgnored ? " is-ignored" : string.Empty)"
                                                    data-day-meal-tab
                                                    data-slot-index="@slotIndex"
                                                    data-day-card-meal-name="@slotMeal.MealName"
                                                    data-day-card-meal-image-url="@AislePilotMealImageUrlResolver.ResolveClientMealImageUrl(slotMeal.MealImageUrl)"
                                                    data-day-card-summary-value="@slotSummaryMeta"
                                                    role="tab"
                                                    aria-controls="@($"{tabPrefix}-panel-{slotIndex}")"
                                                    aria-selected="@(slotIndex == 0 ? "true" : "false")"
                                                    aria-label="@(slotIsIgnored ? $"{slotMeal.MealType} (removed)" : slotMeal.MealType)">
                                                @slotMeal.MealType
                                            </button>
                                        }
                                    </div>
                                }

                                <div class="aislepilot-day-meal-slider" data-day-meal-slider>
                                    <div class="aislepilot-day-meal-track" data-day-meal-track>
                                        @for (var slotIndex = 0; slotIndex < dayGroup.Entries.Count; slotIndex++)
                                        {
                                            var entry = dayGroup.Entries[slotIndex];
                                            var meal = entry.meal;
                                            var mealIndex = entry.index;
                                            var isIgnored = ignoredMealSlotIndexes.Contains(mealIndex) || meal.IsIgnored;
                                            var isSavedMeal = savedEnjoyedMealNames.Contains(meal.MealName);
                                            var panelLabelledBy = dayGroup.Entries.Count > 1
                                                ? $"{tabPrefix}-tab-{slotIndex}"
                                                : null;
                                            var detailsPanelId = $"meal-details-{mealIndex}";
                                            var slotMoreActionsMenuId = $"meal-actions-{mealIndex}-{slotIndex}";
                                            var slotMoreActionsTitleId = $"meal-actions-title-{mealIndex}-{slotIndex}";
                                            var shouldPrioritizeImage = slotIndex == 0 && dayGroupIndex < 2;
                                            var mealDetailsTriggerLabel = "View meal details: macros, ingredients and method";
                                            <section id="@($"{tabPrefix}-panel-{slotIndex}")"
                                                     class="aislepilot-day-meal-panel@(isIgnored ? " is-ignored" : string.Empty)"
                                                     data-day-meal-panel
                                                     role="tabpanel"
                                                     aria-labelledby="@panelLabelledBy"
                                                     aria-hidden="@(slotIndex == 0 ? "false" : "true")">
                                                @if (isIgnored) { <span class="aislepilot-meal-removed-watermark" aria-hidden="true">Removed</span> }
                                                <h3 class="aislepilot-day-meal-title">@meal.MealName</h3>
                                                <div class="aislepilot-day-meal-summary" data-day-meal-summary>
                                                    @if (isIgnored)
                                                    {
                                                        <span class="aislepilot-day-meal-summary-item is-muted">Removed from this plan</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="aislepilot-day-meal-summary-item">@meal.EstimatedCost.ToString("C", ukCulture)</span>
                                                        <span class="aislepilot-day-meal-summary-separator" aria-hidden="true">&middot;</span>
                                                        <span class="aislepilot-day-meal-summary-item">@Math.Max(0, meal.EstimatedPrepMinutes) mins</span>
                                                        <span class="aislepilot-day-meal-summary-separator" aria-hidden="true">&middot;</span>
                                                        <span class="aislepilot-day-meal-summary-item">@meal.MealType</span>
                                                    }
                                                </div>
                                                @if (meal.IsSpecialTreat && !isIgnored) { <partial name="_AislePilotSpecialTreatBadge" /> }
                                                <details class="aislepilot-meal-details aislepilot-meal-details-image-toggle" data-inline-details-toggle>
                                                    <summary class="aislepilot-meal-image-summary"
                                                             aria-controls="@detailsPanelId"
                                                             aria-expanded="false"
                                                             aria-label="@mealDetailsTriggerLabel"
                                                             title="@mealDetailsTriggerLabel">
                                                        <div class="aislepilot-meal-image-shell" data-day-meal-swipe-surface>
                                                            <img class="aislepilot-meal-image"
                                                                 src="@AislePilotMealImageUrlResolver.ResolveClientMealImageUrl(meal.MealImageUrl)"
                                                                 data-meal-image
                                                                 data-meal-name="@meal.MealName"
                                                                 alt="@($"{meal.MealName} plated meal")"
                                                                 loading="@(shouldPrioritizeImage ? "eager" : "lazy")"
                                                                 fetchpriority="@(shouldPrioritizeImage ? "high" : "low")"
                                                                 decoding="async" />
                                                            @{ RenderMealImageHint(mealDetailsTriggerLabel); }
                                                        </div>
                                                    </summary>
                                                </details>
                                                <div class="aislepilot-card-action-row is-inline-actions aislepilot-day-card-header-actions aislepilot-meal-panel-image-actions@(slotIndex == 0 ? " is-active" : string.Empty)"
                                                     data-day-card-header-actions
                                                     data-slot-index="@slotIndex"
                                                     aria-hidden="@(slotIndex == 0 ? "false" : "true")">
                                                    <details class="aislepilot-card-more-actions" data-card-more-actions>
                                                        <summary class="aislepilot-more-actions-trigger"
                                                                 aria-controls="@slotMoreActionsMenuId"
                                                                 aria-expanded="false"
                                                                 aria-haspopup="dialog"
                                                                 aria-label="Meal actions"
                                                                 title="Meal actions">
                                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                <svg viewBox="0 0 24 24" focusable="false">
                                                                    <circle cx="6" cy="12" r="1.6"></circle>
                                                                    <circle cx="12" cy="12" r="1.6"></circle>
                                                                    <circle cx="18" cy="12" r="1.6"></circle>
                                                                </svg>
                                                            </span>
                                                            <span class="aislepilot-swap-action-label">Actions</span>
                                                        </summary>
                                                        <div id="@slotMoreActionsMenuId"
                                                             class="aislepilot-card-more-actions-menu"
                                                             role="group"
                                                             aria-label="Meal actions"
                                                             aria-labelledby="@slotMoreActionsTitleId"
                                                             data-card-more-actions-panel>
                                                            <div class="aislepilot-mobile-meal-sheet-head">
                                                                <span class="aislepilot-mobile-meal-sheet-handle" aria-hidden="true"></span>
                                                                <div class="aislepilot-mobile-meal-sheet-head-row">
                                                                    <p id="@slotMoreActionsTitleId" class="aislepilot-mobile-meal-sheet-title">@meal.MealName</p>
                                                                <button type="button"
                                                                        class="aislepilot-mobile-meal-sheet-close"
                                                                        data-card-more-actions-close
                                                                        aria-label="Close meal actions"
                                                                        title="Close meal actions">
                                                                    <span aria-hidden="true">×</span>
                                                                </button>
                                                                </div>
                                                            </div>
                                                            <form method="post"
                                                                  action="@Url.Action("SwapMeal", "AislePilot")#aislepilot-meals"
                                                                  class="aislepilot-swap-form aislepilot-card-more-action-form"
                                                                  data-preserve-scroll-form
                                                                  data-ajax-swap-form>
                                                                @Html.AntiForgeryToken()
                                                                <partial name="_AislePilotHiddenRequestFields"
                                                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                                                <input type="hidden" name="dayIndex" value="@mealIndex" />
                                                                <input type="hidden" name="currentMealName" value="@meal.MealName" />
                                                                <button type="submit"
                                                                        class="aislepilot-swap-btn is-secondary is-compact"
                                                                        data-loading-label="Swapping..."
                                                                        data-loading-delay-ms="320"
                                                                        aria-label="Swap meal"
                                                                        title="Swap meal">
                                                                    <span class="aislepilot-btn-label">
                                                                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                            <svg viewBox="0 0 24 24" focusable="false">
                                                                                <path d="M16 3h5v5"></path>
                                                                                <path d="M21 3 9 15"></path>
                                                                                <path d="M8 21H3v-5"></path>
                                                                                <path d="M3 21 15 9"></path>
                                                                            </svg>
                                                                        </span>
                                                                        <span class="aislepilot-swap-action-label">Swap</span>
                                                                    </span>
                                                                </button>
                                                            </form>

                                                            <form method="post"
                                                                  action="@Url.Action("ToggleEnjoyedMeal", "AislePilot")#aislepilot-meals"
                                                                  class="aislepilot-swap-form aislepilot-favorite-form aislepilot-card-more-action-form"
                                                                  data-preserve-scroll-form
                                                                  data-ajax-swap-form
                                                                  data-skip-submit-loading>
                                                                @Html.AntiForgeryToken()
                                                                <partial name="_AislePilotHiddenRequestFields"
                                                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                                                <input type="hidden" name="dayIndex" value="@mealIndex" />
                                                                <input type="hidden" name="mealName" value="@meal.MealName" />
                                                                @{
                                                                    var saveActionLabel = isSavedMeal ? "Unsave meal" : "Save meal";
                                                                    var saveButtonClass = isSavedMeal
                                                                        ? "aislepilot-swap-btn is-secondary is-saved-meal is-compact"
                                                                        : "aislepilot-swap-btn is-secondary is-compact";
                                                                }
                                                                <button type="submit"
                                                                        class="@saveButtonClass"
                                                                        aria-label="@saveActionLabel"
                                                                        title="@saveActionLabel">
                                                                    <span class="aislepilot-btn-label">
                                                                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                            <svg viewBox="0 0 24 24" focusable="false">
                                                                                <path d="m12 3 2.8 5.6 6.2.9-4.5 4.4 1 6.2L12 17.5 6.5 20.1l1-6.2L3 9.5l6.2-.9z"></path>
                                                                            </svg>
                                                                        </span>
                                                                        <span class="aislepilot-swap-action-label">@(isSavedMeal ? "Unsave" : "Save")</span>
                                                                    </span>
                                                                </button>
                                                            </form>

                                                            <form method="post"
                                                                  action="@Url.Action("IgnoreMeal", "AislePilot")#aislepilot-meals"
                                                                  class="aislepilot-swap-form aislepilot-ignore-form aislepilot-card-more-action-form"
                                                                  data-preserve-scroll-form
                                                                  data-ajax-swap-form>
                                                                @Html.AntiForgeryToken()
                                                                <partial name="_AislePilotHiddenRequestFields"
                                                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                                                <input type="hidden" name="dayIndex" value="@mealIndex" />
                                                                @{
                                                                    var ignoreActionLabel = isIgnored ? "Include meal" : "Ignore meal";
                                                                    var ignoreButtonClass = isIgnored
                                                                        ? "aislepilot-swap-btn is-secondary is-compact"
                                                                        : "aislepilot-swap-btn is-secondary is-danger is-compact";
                                                                }
                                                                <button type="submit"
                                                                        class="@ignoreButtonClass"
                                                                        data-loading-label="Updating..."
                                                                        data-loading-delay-ms="180"
                                                                        aria-label="@ignoreActionLabel"
                                                                        title="@ignoreActionLabel">
                                                                    <span class="aislepilot-btn-label">
                                                                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                            <svg viewBox="0 0 24 24" focusable="false">
                                                                                @if (isIgnored)
                                                                                {
                                                                                    <path d="M4 12h16"></path>
                                                                                    <path d="M12 4v16"></path>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <path d="M4 12h16"></path>
                                                                                }
                                                                            </svg>
                                                                        </span>
                                                                        <span class="aislepilot-swap-action-label">@(isIgnored ? "Include" : "Ignore")</span>
                                                                    </span>
                                                                </button>
                                                            </form>
                                                </div>
                                            </details>
                                        </div>
                                                @if (isIgnored)
                                                {
                                                    <div class="aislepilot-card-head">
                                                        <p class="aislepilot-cost is-ignored">Removed</p>
                                                    </div>
                                                }
                                                <div id="@detailsPanelId" class="aislepilot-meal-details-panel" data-inline-details-panel hidden aria-hidden="true">
                                                    <p class="aislepilot-card-meta aislepilot-card-reason">@meal.MealReason</p>
                                                    <details class="aislepilot-meal-section" data-meal-section="nutrition">
                                                        <summary class="aislepilot-meal-section-summary" data-meal-section-summary>
                                                            Est. calories + macros
                                                        </summary>
                                                        <div class="aislepilot-meal-section-content" data-meal-section-content>
                                                            <ul class="aislepilot-nutrition-list">
                                                                <li>@meal.CaloriesPerServing kcal per serving</li>
                                                                <li>Protein: @meal.ProteinGramsPerServing.ToString("0.#", ukCulture) g per serving</li>
                                                                <li>Carbs: @meal.CarbsGramsPerServing.ToString("0.#", ukCulture) g per serving</li>
                                                                <li>Fat: @meal.FatGramsPerServing.ToString("0.#", ukCulture) g per serving</li>
                                                            </ul>
                                                        </div>
                                                    </details>
                                                    <details class="aislepilot-meal-section" data-meal-section="ingredients">
                                                        <summary class="aislepilot-meal-section-summary" data-meal-section-summary>
                                                            Ingredients
                                                        </summary>
                                                        <div class="aislepilot-meal-section-content" data-meal-section-content>
                                                            <ul class="case-list">
                                                                @foreach (var ingredientLine in meal.IngredientLines)
                                                                {
                                                                    <li>@ingredientLine</li>
                                                                }
                                                            </ul>
                                                        </div>
                                                    </details>
                                                    <details class="aislepilot-meal-section" data-meal-section="method">
                                                        <summary class="aislepilot-meal-section-summary" data-meal-section-summary>
                                                            Method
                                                        </summary>
                                                        <div class="aislepilot-meal-section-content" data-meal-section-content>
                                                            <ol class="case-list">
                                                                @foreach (var step in meal.RecipeSteps)
                                                                {
                                                                    <li>@step</li>
                                                                }
                                                            </ol>
                                                        </div>
                                                    </details>
                                                </div>
                                            </section>
                                        }
                                    </div>
                                </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        </div>
                        @if (dayMealGroups.Count > 1)
                        {
                            <div class="aislepilot-day-carousel-pagination" data-day-carousel-pagination role="tablist" aria-label="Choose a day card">
                                @{ var dayDotIndex = 0; }
                                @foreach (var dayGroup in dayMealGroups)
                                {
                                    var dotIsActive = dayDotIndex == 0; var dayCardId = $"day-card-{dayGroup.Entries[0].index}"; var dayShortLabel = GetShortDayLabel(dayGroup.Day);
                                    <button type="button"
                                            class="aislepilot-day-carousel-dot@(dotIsActive ? " is-active" : string.Empty)"
                                            data-day-carousel-dot
                                            data-day-carousel-target="@dayDotIndex"
                                            role="tab"
                                            aria-controls="@dayCardId"
                                            aria-selected="@(dotIsActive ? "true" : "false")"
                                            aria-current="@(dotIsActive ? "true" : "false")" tabindex="@(dotIsActive ? "0" : "-1")"
                                            title="@($"Show {dayGroup.Day}")" aria-label="@($"Show {dayGroup.Day}")">
                                        <span class="aislepilot-day-carousel-dot-label">@dayShortLabel</span>
                                    </button>
                                    dayDotIndex++;
                                }
                            </div>
                        }
                    </section>
                        @if (result.IncludeDessertAddOn)
                        {
                            var dessertDetailsTriggerLabel = "View dessert details: ingredients and method";
                            <article class="aislepilot-card aislepilot-day-card" data-day-meal-card>
                                <div class="aislepilot-card-head">
                                    <p class="aislepilot-card-kicker">Dessert</p>
                                    <p class="aislepilot-day-card-meta">1 meal</p>
                                </div>
                                <div class="aislepilot-day-meal-tabs aislepilot-day-meal-tabs-static" aria-hidden="true" role="presentation">
                                    <span class="aislepilot-day-meal-tab is-active">Dessert</span>
                                </div>
                                <div class="aislepilot-day-meal-slider" data-day-meal-slider>
                                    <div class="aislepilot-day-meal-track" data-day-meal-track>
                                        <section class="aislepilot-day-meal-panel"
                                                 data-day-meal-panel
                                                 role="tabpanel"
                                                 aria-hidden="false">
                                            <div class="aislepilot-card-head aislepilot-card-head-with-title aislepilot-card-head-with-actions">
                                                <h3>@result.DessertAddOnName</h3>
                                                <div class="aislepilot-card-action-row is-inline-actions is-top-actions">
                                                    <form method="post"
                                                          action="@Url.Action("SwapDessert", "AislePilot")#aislepilot-meals"
                                                          class="aislepilot-swap-form aislepilot-card-action-inline"
                                                          data-preserve-scroll-form
                                                          data-ajax-swap-form>
                                                        @Html.AntiForgeryToken()
                                                        <partial name="_AislePilotHiddenRequestFields"
                                                                 model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                                        <input type="hidden" name="currentDessertAddOnName" value="@result.DessertAddOnName" />
                                                        <button type="submit"
                                                                class="aislepilot-swap-btn"
                                                                data-loading-label="Swapping..."
                                                                data-loading-delay-ms="320"
                                                                aria-label="Swap dessert"
                                                                title="Swap dessert">
                                                            <span class="aislepilot-btn-label">
                                                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                                    <svg viewBox="0 0 24 24" focusable="false">
                                                                        <path d="M16 3h5v5"></path>
                                                                        <path d="M21 3 9 15"></path>
                                                                        <path d="M8 21H3v-5"></path>
                                                                        <path d="M3 21 15 9"></path>
                                                                    </svg>
                                                                </span>
                                                                <span class="aislepilot-swap-action-label">Swap dessert</span>
                                                            </span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                            <details class="aislepilot-meal-details aislepilot-meal-details-image-toggle" data-inline-details-toggle>
                                                <summary class="aislepilot-meal-image-summary"
                                                         aria-controls="dessert-details-panel"
                                                         aria-expanded="false"
                                                         aria-label="@dessertDetailsTriggerLabel"
                                                         title="@dessertDetailsTriggerLabel">
                                                    <div class="aislepilot-meal-image-shell" data-day-meal-swipe-surface>
                                                        <img class="aislepilot-meal-image"
                                                             src="@fallbackMealImageUrl"
                                                             data-meal-image
                                                             data-meal-name="@result.DessertAddOnName"
                                                             alt="@($"{result.DessertAddOnName} plated dessert")"
                                                             loading="lazy"
                                                             fetchpriority="low"
                                                             decoding="async" />
                                                        @{ RenderMealImageHint(
                                                            dessertDetailsTriggerLabel,
                                                            includeMacros: false,
                                                            includeIngredients: true,
                                                            includeMethod: true); }
                                                    </div>
                                                </summary>
                                            </details>
                                            <div class="aislepilot-card-head">
                                                <p class="aislepilot-card-kicker">Dessert</p>
                                                <p class="aislepilot-cost">@result.DessertAddOnEstimatedCost.ToString("C", ukCulture)</p>
                                            </div>
                                            <div class="aislepilot-card-primary-row">
                                                <span class="aislepilot-card-meta-pill">Optional add-on</span>
                                            </div>
                                            <div id="dessert-details-panel" class="aislepilot-meal-details-panel" data-inline-details-panel hidden aria-hidden="true">
                                                <p class="aislepilot-card-meta aislepilot-card-reason">Dessert add-on for a more indulgent week.</p>
                                                <p class="aislepilot-card-kicker">Ingredients</p>
                                                <ul class="case-list">
                                                    @if (result.DessertAddOnIngredientLines.Count == 0)
                                                    {
                                                        <li>Ingredients are included in your shopping list.</li>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var ingredientLine in result.DessertAddOnIngredientLines)
                                                        {
                                                            <li>@ingredientLine</li>
                                                        }
                                                    }
                                                </ul>
                                                <p class="aislepilot-card-kicker">Method</p>
                                                <ol class="case-list">
                                                    <li>Heat oven to 180C and line a tray-bake tin.</li>
                                                    <li>Cream butter and sugar, then beat in eggs.</li>
                                                    <li>Fold in flour and cocoa, then spread mixture in the tin.</li>
                                                    <li>Bake until springy and cool before slicing.</li>
                                                </ol>
                                            </div>
                                        </section>
                                    </div>
                                </div>
                            </article>
                        }
                </section>

                <section id="aislepilot-shop" aria-label="Shopping" role="tabpanel" aria-labelledby="aislepilot-tab-shop" class="aislepilot-window-panel aislepilot-shop-panel" data-window-name="Shopping">
                    <p class="aislepilot-window-meta">
                        @mealIngredientEstimateLabel: @result.EstimatedTotalCost.ToString("C", ukCulture). @shoppingEstimateDisclaimer
                    </p>
                    @if (result.IncludeDessertAddOn)
                    {
                        <p class="aislepilot-window-meta">
                            Dessert add-on ingredients are included in this list (@result.DessertAddOnEstimatedCost.ToString("C", ukCulture)).
                        </p>
                    }
                    <div class="aislepilot-shopping-grid">
                        @foreach (var department in groupedItems)
                        {
                            <article class="aislepilot-card aislepilot-shop-card">
                                <div class="aislepilot-shop-card-head">
                                    <h3>@department.Key</h3>
                                    <span class="aislepilot-shop-card-count">@department.Count() item(s)</span>
                                </div>
                                <ul class="aislepilot-shop-list">
                                    @foreach (var item in department)
                                    {
                                        var shoppingItemKey = $"{department.Key}|{item.Name}|{item.QuantityDisplay}|{item.EstimatedCost.ToString("0.00", CultureInfo.InvariantCulture)}";
                                        <li>
                                            <label class="aislepilot-checkbox-item"
                                                   data-shopping-item-label
                                                   data-shopping-item-key="@shoppingItemKey">
                                                <input type="checkbox"
                                                       data-shopping-item-input
                                                       aria-label="Mark @item.Name as already have this ingredient" />
                                                <span data-shopping-item-text>@item.Name (@item.QuantityDisplay) - Est. @item.EstimatedCost.ToString("C", ukCulture)</span>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </article>
                        }
                        <article class="aislepilot-card aislepilot-shop-card aislepilot-shop-card-custom"
                                 data-custom-shopping-shell>
                            <h3>Your extra items</h3>
                            <p class="aislepilot-card-meta">Add common purchases like toilet roll, cleaning supplies, or anything else you want on this trip.</p>
                            <form class="aislepilot-custom-shopping-form" data-custom-shopping-form>
                                <label class="sr-only" for="aislepilot-custom-shopping-input">Add your own shopping item</label>
                                <input id="aislepilot-custom-shopping-input"
                                       type="text"
                                       class="aislepilot-custom-shopping-input"
                                       data-custom-shopping-input
                                       maxlength="80"
                                       placeholder="Add your own item" />
                                <button type="submit"
                                        class="aislepilot-swap-btn is-secondary is-compact"
                                        data-custom-shopping-add>
                                    Add item
                                </button>
                            </form>
                            <p class="aislepilot-card-meta" data-custom-shopping-empty>No extra items yet.</p>
                            <ul class="aislepilot-shop-list" data-custom-shopping-list hidden></ul>
                        </article>
                    </div>
                </section>

                <section id="aislepilot-export" aria-label="Exports" role="tabpanel" aria-labelledby="aislepilot-tab-export" class="aislepilot-window-panel aislepilot-export-panel" data-window-name="Exports">
                    <div class="aislepilot-export-intro">
                        <p class="aislepilot-export-eyebrow">Take this plan with you</p>
                        <h3 class="aislepilot-export-title">Start with the shopping list on your phone.</h3>
                        <p class="aislepilot-export-copy">Share is the quickest option for supermarket trips. Download the PDF when you want the full week, and keep the text checklist as a lightweight backup.</p>
                    </div>

                    <div class="aislepilot-export-actions">
                        <article class="aislepilot-export-action is-primary" data-notes-export-shell>
                            <div class="aislepilot-export-card-copy">
                                <p class="aislepilot-export-card-kicker">Best for shopping now</p>
                                <h4 class="aislepilot-export-card-title">Share to your phone</h4>
                                <p class="aislepilot-export-card-description">Opens the share sheet on supported devices and can fall back to copying the list when sharing is unavailable.</p>
                            </div>
                            <textarea hidden data-notes-export-content>@shoppingListNotesText</textarea>
                            <button type="button"
                                    class="aislepilot-export-btn is-primary"
                                    data-notes-export-trigger
                                    data-notes-default-label="Share shopping list"
                                    data-notes-shared-label="Share sheet opened. Choose your app."
                                    data-notes-copied-label="Shopping list copied."
                                    data-notes-failed-label="Could not share. Try again.">
                                Share shopping list
                            </button>
                        </article>

                        <article class="aislepilot-export-action is-secondary">
                            <div class="aislepilot-export-card-copy">
                                <p class="aislepilot-export-card-kicker">Full week pack</p>
                                <h4 class="aislepilot-export-card-title">Download the full plan</h4>
                                <p class="aislepilot-export-card-description">PDF with the meals, budget snapshot, and aisle-ordered shopping list in one file.</p>
                            </div>
                            <form method="post"
                                  asp-action="ExportPlanPack"
                                  data-export-theme-form
                                  data-export-download-form
                                  data-export-download-fallback-name="aislepilot-plan-pack.pdf">
                                @Html.AntiForgeryToken()
                                <partial name="_AislePilotHiddenRequestFields"
                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                <input type="hidden" name="exportTheme" value="light" data-export-theme-input />
                                <button type="submit" class="aislepilot-export-btn is-secondary" data-loading-label="Building PDF...">Download plan pack (.pdf)</button>
                            </form>
                        </article>

                        <article class="aislepilot-export-action is-secondary">
                            <div class="aislepilot-export-card-copy">
                                <p class="aislepilot-export-card-kicker">Plain text backup</p>
                                <h4 class="aislepilot-export-card-title">Download a checklist</h4>
                                <p class="aislepilot-export-card-description">Simple text version for Notes, reminders, or quick edits without the full PDF.</p>
                            </div>
                            <form method="post"
                                  asp-action="ExportChecklist"
                                  data-export-download-form
                                  data-export-download-fallback-name="aislepilot-checklist.txt">
                                @Html.AntiForgeryToken()
                                <partial name="_AislePilotHiddenRequestFields"
                                         model="BuildHiddenRequestFields(includeCurrentPlanMealNames: true)" />
                                <button type="submit" class="aislepilot-export-btn is-secondary" data-loading-label="Building checklist...">Download checklist (.txt)</button>
                            </form>
                        </article>
                    </div>

                    <div class="aislepilot-export-footer">
                        <p class="aislepilot-export-footer-copy">Need a paper copy for the kitchen or a shared shop?</p>
                        <button type="button" class="aislepilot-export-btn is-tertiary" onclick="window.print()">Print meal and shopping view</button>
                    </div>
                </section>
            </div>
        </div>
    </section>
}

