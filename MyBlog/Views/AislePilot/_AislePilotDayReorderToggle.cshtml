<button type="button"
        class="aislepilot-day-view-toggle"
        data-day-view-toggle
        data-day-view-default-label="Stacked view"
        data-day-view-active-label="Carousel view"
        aria-pressed="false"
        aria-label="Stacked view"
        title="Stacked view">
    <span class="aislepilot-symbol-glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
            <rect x="4" y="5" width="16" height="3.3" rx="1"></rect>
            <rect x="4" y="10.4" width="16" height="3.3" rx="1"></rect>
            <rect x="4" y="15.8" width="16" height="3.3" rx="1"></rect>
        </svg>
    </span>
    <span class="aislepilot-day-view-toggle-label" data-day-view-toggle-label>Stacked view</span>
</button>
<button type="button"
        class="aislepilot-day-reorder-toggle"
        data-day-reorder-toggle
        data-day-reorder-default-label="Swap meals"
        data-day-reorder-active-label="Done"
        aria-pressed="false"
        aria-label="Swap meals"
        title="Swap meals">
    <span class="aislepilot-symbol-glyph" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
            <path d="M10 6h10"></path>
            <path d="M10 12h10"></path>
            <path d="M10 18h10"></path>
            <circle cx="6.5" cy="6" r="1.5"></circle>
            <circle cx="6.5" cy="12" r="1.5"></circle>
            <circle cx="6.5" cy="18" r="1.5"></circle>
        </svg>
    </span>
    <span class="aislepilot-day-reorder-toggle-label" data-day-reorder-toggle-label>Swap meals</span>
</button>
