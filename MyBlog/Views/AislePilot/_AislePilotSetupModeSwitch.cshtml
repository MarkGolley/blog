@model AislePilotPageViewModel
@{
    var plannerToggleClass = ViewData["PlannerToggleClass"]?.ToString() ?? string.Empty;
    var generatorToggleClass = ViewData["GeneratorToggleClass"]?.ToString() ?? string.Empty;
    var defaultSetupMode = ViewData["DefaultSetupMode"]?.ToString() ?? "planner";
    var forceDefaultSetupMode = ViewData["ForceDefaultSetupMode"]?.ToString()?.ToLowerInvariant() ?? "false";
    var plannerSelected = ViewData["PlannerSelected"]?.ToString()?.ToLowerInvariant() ?? "true";
    var generatorSelected = ViewData["GeneratorSelected"]?.ToString()?.ToLowerInvariant() ?? "false";
}

<div class="aislepilot-setup-mode-shell">
    <div class="aislepilot-setup-mode-lede">
        <p class="aislepilot-setup-mode-kicker">Choose your output</p>
        <p class="aislepilot-setup-mode-caption">Use planner mode for a full week, or switch to ideas when you only need one pantry-led meal suggestion.</p>
    </div>
    <div class="aislepilot-setup-mode-switch"
         role="tablist"
         aria-label="Settings mode"
         data-setup-mode-switch
         data-setup-mode-default="@defaultSetupMode"
         data-setup-mode-force-default="@forceDefaultSetupMode">
        <button type="button"
                class="@plannerToggleClass"
                role="tab"
                aria-controls="aislepilot-planner-mode"
                aria-selected="@plannerSelected"
                data-setup-mode-toggle="planner">
            <span class="aislepilot-setup-mode-toggle-kicker">Best for weekly shops</span>
            <span class="aislepilot-setup-mode-toggle-main">
                <span class="aislepilot-setup-mode-toggle-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <rect x="3.5" y="4.5" width="17" height="15" rx="2"></rect>
                        <path d="M3.5 10h17M9 4.5v15M15 4.5v15"></path>
                    </svg>
                </span>
                <span class="aislepilot-setup-mode-toggle-copy">
                    <span class="aislepilot-setup-mode-toggle-title">Meal planner</span>
                    <span class="aislepilot-setup-mode-toggle-note">Multi-day output</span>
                </span>
            </span>
            <span class="aislepilot-setup-mode-toggle-detail">Build a week around budget, household size, and supermarket aisle order.</span>
        </button>
        <button type="button"
                class="@generatorToggleClass"
                role="tab"
                aria-controls="aislepilot-generator-mode"
                aria-selected="@generatorSelected"
                data-setup-mode-toggle="generator">
            <span class="aislepilot-setup-mode-toggle-kicker">Best for use-what-you-have</span>
            <span class="aislepilot-setup-mode-toggle-main">
                <span class="aislepilot-setup-mode-toggle-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M12 4v3"></path>
                        <path d="M12 17v3"></path>
                        <path d="M4 12h3"></path>
                        <path d="M17 12h3"></path>
                        <path d="m6.35 6.35 2.15 2.15"></path>
                        <path d="m15.5 15.5 2.15 2.15"></path>
                        <path d="m17.65 6.35-2.15 2.15"></path>
                        <path d="m8.5 15.5-2.15 2.15"></path>
                    </svg>
                </span>
                <span class="aislepilot-setup-mode-toggle-copy">
                    <span class="aislepilot-setup-mode-toggle-title">Meal ideas</span>
                    <span class="aislepilot-setup-mode-toggle-note">Single meal output</span>
                </span>
            </span>
            <span class="aislepilot-setup-mode-toggle-detail">Turn pantry items and preferences into three fast ideas without planning a full week.</span>
        </button>
    </div>
</div>
