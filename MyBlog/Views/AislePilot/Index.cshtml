@using System.Globalization
@using MyBlog.Services
@model AislePilotPageViewModel
@{
    Layout = "_AislePilotLayout";
    ViewData["ReturnUrl"] = Model.ReturnUrl;
    ViewData["Title"] = "AislePilot";
    ViewData["MetaDescription"] =
        "AislePilot: generate a weekly meal plan, track budget, and create a supermarket-ordered shopping list.";
    ViewData["CanonicalPath"] = "/projects/aisle-pilot";
    ViewData["OgImage"] = "/images/aislepilot-icon.svg";
    var ukCulture = CultureInfo.GetCultureInfo("en-GB");
    var supermarketOptions = Model.SupermarketOptions.Count > 0
        ? Model.SupermarketOptions.ToArray()
        : ["Tesco"];
    var portionSizeOptions = Model.PortionSizeOptions.Count > 0
        ? Model.PortionSizeOptions.ToArray()
        : ["Small", "Medium", "Large"];
    var selectedSupermarket = supermarketOptions.FirstOrDefault(
        option => option.Equals(Model.Request.Supermarket, StringComparison.OrdinalIgnoreCase))
        ?? supermarketOptions[0];
    var selectedPortionSizeIndex = Array.FindIndex(portionSizeOptions,
        option => option.Equals(Model.Request.PortionSize, StringComparison.OrdinalIgnoreCase));
    if (selectedPortionSizeIndex < 0)
    {
        selectedPortionSizeIndex = 0;
    }
    var portionSizeSliderValues = string.Join("|", portionSizeOptions);
    var selectedPortionSize = portionSizeOptions[selectedPortionSizeIndex];
    var selectedPlanDays = Math.Clamp(Model.Request.PlanDays, 1, 7);
    var selectedCookDays = Math.Clamp(Model.Request.CookDays, 1, selectedPlanDays);
    var weekDayNames = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    List<int> BuildDefaultCookDayMultipliers(int cookDays, int planDays)
    {
        var safePlanDays = Math.Clamp(planDays, 1, 7);
        var safeCookDays = Math.Clamp(cookDays, 1, safePlanDays);
        var leftoverDays = Math.Max(0, safePlanDays - safeCookDays);
        var multipliers = Enumerable.Repeat(1, safeCookDays).ToList();
        for (var index = 0; index < leftoverDays; index++)
        {
            multipliers[index % safeCookDays]++;
        }

        return multipliers;
    }

    List<string> BuildSpecialTreatCookDayLabels(int cookDays, int planDays)
    {
        var safePlanDays = Math.Clamp(planDays, 1, 7);
        var safeCookDays = Math.Clamp(cookDays, 1, safePlanDays);
        var planWeekDayNames = weekDayNames.Take(safePlanDays).ToArray();
        var multipliers = BuildDefaultCookDayMultipliers(safeCookDays, safePlanDays);
        var labels = new List<string>(safeCookDays);
        var dayCursor = 0;
        for (var index = 0; index < safeCookDays; index++)
        {
            var dayName = planWeekDayNames[Math.Clamp(dayCursor, 0, planWeekDayNames.Length - 1)];
            labels.Add(dayName);
            dayCursor += Math.Max(1, multipliers[index]);
        }

        return labels;
    }

    var specialTreatCookDayLabels = BuildSpecialTreatCookDayLabels(selectedCookDays, selectedPlanDays);
    var selectedSpecialTreatCookDayIndex = Model.Request.SelectedSpecialTreatCookDayIndex.HasValue
        ? Math.Clamp(Model.Request.SelectedSpecialTreatCookDayIndex.Value, 0, selectedCookDays - 1)
        : 0;
    var selectedSpecialTreatCookDayLabel = specialTreatCookDayLabels.Count == 0
        ? string.Empty
        : specialTreatCookDayLabels[Math.Clamp(selectedSpecialTreatCookDayIndex, 0, specialTreatCookDayLabels.Count - 1)];
    var selectedMealTypes = (Model.Request.SelectedMealTypes ?? [])
        .Where(type => !string.IsNullOrWhiteSpace(type))
        .Select(type =>
        {
            var normalized = type.Trim();
            if (normalized.Equals("Breakfast", StringComparison.OrdinalIgnoreCase))
            {
                return "Breakfast";
            }

            if (normalized.Equals("Lunch", StringComparison.OrdinalIgnoreCase))
            {
                return "Lunch";
            }

            if (normalized.Equals("Dinner", StringComparison.OrdinalIgnoreCase))
            {
                return "Dinner";
            }

            return string.Empty;
        })
        .Where(type => type.Length > 0)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(type => type.Equals("Breakfast", StringComparison.OrdinalIgnoreCase)
            ? 0
            : type.Equals("Lunch", StringComparison.OrdinalIgnoreCase)
                ? 1
                : 2)
        .ToList();
    if (selectedMealTypes.Count == 0)
    {
        selectedMealTypes = Math.Clamp(Model.Request.MealsPerDay, 1, 3) switch
        {
            1 => ["Dinner"],
            2 => ["Lunch", "Dinner"],
            _ => ["Breakfast", "Lunch", "Dinner"]
        };
    }

    var selectedMealTypesSet = selectedMealTypes.ToHashSet(StringComparer.OrdinalIgnoreCase);
    var selectedMealsPerDay = selectedMealTypes.Count;
    var selectedMealTypesSummary = new[] { "Breakfast", "Lunch", "Dinner" }
        .Where(type => selectedMealTypesSet.Contains(type))
        .ToList();
    var selectedMealTypesSummaryText = selectedMealTypesSummary.Count == 0
        ? "None selected"
        : string.Join(", ", selectedMealTypesSummary);
    var isCustomSupermarketSelected = string.Equals(selectedSupermarket, "Custom", StringComparison.OrdinalIgnoreCase);
    var selectedDietary = Model.Request.DietaryModes.ToHashSet(StringComparer.OrdinalIgnoreCase);
    var hasResult = Model.HasResult && Model.Result is not null;
    var setupHiddenAttribute = hasResult ? "hidden" : null;
    var storeLayoutSectionHiddenAttribute = isCustomSupermarketSelected ? null : "hidden";
    var customAisleFieldHiddenAttribute = isCustomSupermarketSelected ? null : "hidden";
    var hasServingValidationErrors =
        (ViewData.ModelState.TryGetValue("Request.HouseholdSize", out var householdFieldState) &&
         householdFieldState.Errors.Count > 0) ||
        (ViewData.ModelState.TryGetValue("Request.PortionSize", out var portionFieldState) &&
         portionFieldState.Errors.Count > 0);
    var hasDietaryValidationErrors =
        ViewData.ModelState.TryGetValue("Request.DietaryModes", out var dietaryFieldState) &&
        dietaryFieldState.Errors.Count > 0;
    var hasExclusionsValidationErrors =
        ViewData.ModelState.TryGetValue("Request.DislikesOrAllergens", out var exclusionsFieldState) &&
        exclusionsFieldState.Errors.Count > 0;
    var servingDetailsOpenAttribute = hasServingValidationErrors ? "open" : null;
    var dietaryDetailsOpenAttribute = hasDietaryValidationErrors ? "open" : null;
    var exclusionsDetailsOpenAttribute = hasExclusionsValidationErrors ? "open" : null;
    var dietarySummaryValues = Model.Request.DietaryModes
        .Where(mode => !string.IsNullOrWhiteSpace(mode))
        .Select(mode => mode.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    var dietarySummaryText = dietarySummaryValues.Count == 0
        ? "No dietary filters"
        : string.Join(", ", dietarySummaryValues);
    var safeHouseholdSize = Math.Clamp(Model.Request.HouseholdSize, 1, 8);
    var householdLabel = safeHouseholdSize == 1 ? "person" : "people";
    var servingSummaryText = $"{safeHouseholdSize} {householdLabel} - {selectedPortionSize} portions";
    var savedMealRepeatsEnabled = Model.Request.EnableSavedMealRepeats;
    var savedMealRepeatRatePercent = Math.Clamp(Model.Request.SavedMealRepeatRatePercent, 10, 100);
    var savedMealRepeatSummaryText = savedMealRepeatsEnabled
        ? $"Saved repeats {savedMealRepeatRatePercent}%"
        : "Saved repeats off";
    var cookingSummaryText = $"{(Model.Request.PreferQuickMeals ? "Quick meals on" : "Quick meals off")}, {savedMealRepeatSummaryText}";
    var specialOptions = new List<string>();
    if (Model.Request.IncludeSpecialTreatMeal)
    {
        specialOptions.Add(
            string.IsNullOrWhiteSpace(selectedSpecialTreatCookDayLabel)
                ? "Treat meal on"
                : $"Treat meal on {selectedSpecialTreatCookDayLabel}");
    }

    if (Model.Request.IncludeDessertAddOn)
    {
        specialOptions.Add("Dessert add-on on");
    }

    var specialOptionsSummaryText = specialOptions.Count == 0
        ? "No extras"
        : string.Join(", ", specialOptions);
    var exclusionsSummaryRaw = string.IsNullOrWhiteSpace(Model.Request.DislikesOrAllergens)
        ? "No exclusions set"
        : Model.Request.DislikesOrAllergens.Trim();
    var exclusionsSummaryText = exclusionsSummaryRaw;
    var hasPantryValidationErrors = ViewData.ModelState.TryGetValue("Request.PantryItems", out var pantryFieldState) &&
        pantryFieldState.Errors.Count > 0;
    var pantrySummaryRaw = string.IsNullOrWhiteSpace(Model.Request.PantryItems)
        ? "No foods listed"
        : Model.Request.PantryItems.Trim();
    var pantrySummaryText = pantrySummaryRaw;
    var generatorCoreSummaryText = Model.Request.RequireCorePantryIngredients
        ? "Strict core on"
        : "Strict core off";
    var shouldShowGeneratorMode = Model.PantrySuggestions.Count > 0 || hasPantryValidationErrors;
    var generatorOnlyPreferenceHiddenAttribute = shouldShowGeneratorMode ? null : "hidden";
    var plannerOnlyPreferenceHiddenAttribute = shouldShowGeneratorMode ? "hidden" : null;
    var defaultSetupMode = shouldShowGeneratorMode ? "generator" : "planner";
    var forceDefaultSetupMode = shouldShowGeneratorMode ? "true" : "false";
    var plannerModeHiddenAttribute = shouldShowGeneratorMode ? "hidden" : null;
    var generatorModeHiddenAttribute = shouldShowGeneratorMode ? null : "hidden";
    var plannerToggleClass = shouldShowGeneratorMode
        ? "aislepilot-setup-mode-toggle"
        : "aislepilot-setup-mode-toggle is-active";
    var generatorToggleClass = shouldShowGeneratorMode
        ? "aislepilot-setup-mode-toggle is-active"
        : "aislepilot-setup-mode-toggle";
    var appHeadClass = hasResult ? "aislepilot-app-head is-compact" : "aislepilot-app-head";
    var hasDesktopResults = hasResult || Model.PantrySuggestions.Count > 0;
    var appLayoutClass = hasDesktopResults
        ? "aislepilot-layout has-results"
        : "aislepilot-layout";
    var modelErrors = ViewData.ModelState.Values
        .SelectMany(state => state.Errors)
        .Select(error => error.ErrorMessage?.Trim())
        .Where(message => !string.IsNullOrWhiteSpace(message))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    var hasModelErrors = modelErrors.Count > 0;
    var joinedErrorText = string.Join(" ", modelErrors).ToLowerInvariant();
    var fallbackMealImageUrl = AislePilotMealImageUrlResolver.ResolveClientMealImageUrl("/images/aislepilot-icon.svg");
    var mealImagesPollUrl = Url.Action("MealImages", "AislePilot") ?? "/projects/aisle-pilot/meal-images";
    string FormatSupermarketLabel(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return value;
        }

        var trimmed = value.Trim();
        return ukCulture.TextInfo.ToTitleCase(trimmed.ToLower(ukCulture));
    }

    var looksLikeSwapIssue =
        joinedErrorText.Contains("swap", StringComparison.Ordinal) ||
        joinedErrorText.Contains("selected day was out of range", StringComparison.Ordinal) ||
        joinedErrorText.Contains("current plan", StringComparison.Ordinal);
    var looksLikeConstraintIssue =
        joinedErrorText.Contains("no meals match", StringComparison.Ordinal) ||
        joinedErrorText.Contains("dietary", StringComparison.Ordinal) ||
        joinedErrorText.Contains("allergen", StringComparison.Ordinal);
    var looksLikeAiIssue =
        joinedErrorText.Contains("ai", StringComparison.Ordinal) ||
        joinedErrorText.Contains("rate", StringComparison.Ordinal) ||
        joinedErrorText.Contains("timeout", StringComparison.Ordinal) ||
        joinedErrorText.Contains("temporarily", StringComparison.Ordinal) ||
        joinedErrorText.Contains("unavailable", StringComparison.Ordinal);
}

<div class="aislepilot-app@(hasDesktopResults ? " has-results" : string.Empty)">
    <partial name="_AislePilotAppHeader"
             model="Model"
             view-data='new ViewDataDictionary(ViewData)
             {
                 ["AppHeadClass"] = appHeadClass,
                 ["HasResult"] = hasResult
             }' />

    @if (hasModelErrors)
    {
        var alertTitle = looksLikeSwapIssue
            ? "Could not swap meal"
            : looksLikeConstraintIssue
                ? "Constraints are too strict"
                : looksLikeAiIssue
                    ? "Meal generation is temporarily unavailable"
                    : "Please review your settings";
        var alertGuidance = looksLikeSwapIssue
            ? "Try again or refresh your plan."
            : looksLikeConstraintIssue
                ? "Remove one restriction, then generate again."
                : looksLikeAiIssue
                    ? "Wait 15-30 seconds, then generate again."
                    : "Review the message below, then try again.";

        <partial name="_AislePilotAlert"
                 model="modelErrors"
                 view-data='new ViewDataDictionary(ViewData)
                 {
                     ["AlertTitle"] = alertTitle,
                     ["AlertGuidance"] = alertGuidance,
                     ["HasResult"] = hasResult
                 }' />
    }

    <div class="@appLayoutClass">
    <section id="aislepilot-setup" aria-labelledby="aislepilot-form-title" class="aislepilot-shell" data-reveal data-setup-panel @setupHiddenAttribute>
        <div class="aislepilot-section-head aislepilot-section-head-row">
            <div class="aislepilot-section-head-copy">
                <h2 id="aislepilot-form-title" class="aislepilot-section-title">Settings</h2>
                <p class="aislepilot-setup-intro">Move through the setup in three steps, then generate a plan shaped around your budget, household, and supermarket.</p>
                <ol class="aislepilot-setup-track" aria-label="Setup steps">
                    <li class="aislepilot-setup-track-item">
                        <span class="aislepilot-setup-track-number">1</span>
                        <span class="aislepilot-setup-track-label">Household</span>
                    </li>
                    <li class="aislepilot-setup-track-item">
                        <span class="aislepilot-setup-track-number">2</span>
                        <span class="aislepilot-setup-track-label">Plan rules</span>
                    </li>
                    <li class="aislepilot-setup-track-item">
                        <span class="aislepilot-setup-track-number">3</span>
                        <span class="aislepilot-setup-track-label">Generate</span>
                    </li>
                </ol>
            </div>
        </div>

        <form method="post" asp-action="Index" id="aislepilot-setup-form" class="contact-form aislepilot-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <input type="hidden" name="SetupMode" value="@defaultSetupMode" data-setup-mode-value />
            <input asp-for="Request.PantrySuggestionHistoryState" type="hidden" />
            <input asp-for="Request.SelectedDessertAddOnName" type="hidden" />
            <input asp-for="Request.SavedEnjoyedMealNamesState" type="hidden" />
            @if (hasResult && Model.Result is not null)
            {
                foreach (var mealName in Model.Result.MealPlan
                             .Select(meal => meal.MealName)
                             .Where(mealName => !string.IsNullOrWhiteSpace(mealName)))
                {
                    <input type="hidden" name="currentPlanMealNames" value="@mealName" />
                }
            }
            @if (!hasModelErrors)
            {
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            }

            <partial name="_AislePilotSetupModeSwitch"
                     model="Model"
                     view-data='new ViewDataDictionary(ViewData)
                     {
                         ["PlannerToggleClass"] = plannerToggleClass,
                         ["GeneratorToggleClass"] = generatorToggleClass,
                         ["DefaultSetupMode"] = defaultSetupMode,
                         ["ForceDefaultSetupMode"] = forceDefaultSetupMode,
                         ["PlannerSelected"] = shouldShowGeneratorMode ? "false" : "true",
                         ["GeneratorSelected"] = shouldShowGeneratorMode ? "true" : "false"
                     }' />

            <div class="aislepilot-setup-workspace">
                <div class="aislepilot-setup-primary">
                    <section class="aislepilot-setup-step">
                        <div class="aislepilot-setup-step-head">
                            <p class="aislepilot-setup-step-kicker">Step 1</p>
                            <h3 class="aislepilot-setup-step-title">Household and preferences</h3>
                            <p class="aislepilot-setup-step-copy">Set who the plan is for, what to avoid, and how much repetition is acceptable.</p>
                        </div>

            <partial name="_AislePilotSharedSetup"
                     model='new AislePilotSharedSetupViewModel
                     {
                         ServingDetailsOpen = hasServingValidationErrors,
                         ServingSummaryText = servingSummaryText,
                         HouseholdSize = Model.Request.HouseholdSize,
                         PortionSizeOptions = portionSizeOptions,
                         SelectedPortionSizeIndex = selectedPortionSizeIndex,
                         PortionSizeSliderValues = portionSizeSliderValues,
                         SelectedPortionSize = selectedPortionSize,
                         DietaryDetailsOpen = hasDietaryValidationErrors,
                         DietarySummaryText = dietarySummaryText,
                         DietaryOptions = Model.DietaryOptions.ToArray(),
                         DietarySelectionRules = Model.DietarySelectionRules,
                         SelectedDietaryModes = Model.Request.DietaryModes.ToArray(),
                         CookingSummaryText = cookingSummaryText,
                         PreferQuickMeals = Model.Request.PreferQuickMeals,
                         EnableSavedMealRepeats = savedMealRepeatsEnabled,
                         SavedMealRepeatRatePercent = savedMealRepeatRatePercent,
                         ExclusionsDetailsOpen = hasExclusionsValidationErrors,
                         ExclusionsSummaryText = exclusionsSummaryText,
                         DislikesOrAllergens = Model.Request.DislikesOrAllergens ?? string.Empty
                     }' />
                    </section>

                    <section class="aislepilot-setup-step"
                             data-planner-only-preference
                             @plannerOnlyPreferenceHiddenAttribute>
                        <div class="aislepilot-setup-step-head">
                            <p class="aislepilot-setup-step-kicker">Step 2</p>
                            <h3 class="aislepilot-setup-step-title">Plan rules</h3>
                            <p class="aislepilot-setup-step-copy">Choose the store, meal cadence, budget, and any extras that should shape the week.</p>
                        </div>
            <div class="aislepilot-planner-settings">
                <h2 class="aislepilot-planner-settings-title">
                    <span class="aislepilot-symbol-label">
                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <rect x="3.5" y="4.5" width="17" height="15" rx="2"></rect>
                                <path d="M3.5 10h17M9 4.5v15M15 4.5v15"></path>
                            </svg>
                        </span>
                        Planner settings
                    </span>
                </h2>

                <div class="aislepilot-planner-settings-list">
                    <details class="aislepilot-collapsible"
                             data-plan-basic-item="supermarket">
                        <summary>
                            <span class="aislepilot-collapsible-title">Supermarket</span>
                            <span class="aislepilot-collapsible-value" data-plan-basic-summary>@FormatSupermarketLabel(selectedSupermarket)</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                            <label asp-for="Request.Supermarket" class="sr-only">Supermarket</label>
                            <div class="aislepilot-supermarket-options" role="group" aria-label="Supermarket">
                                @foreach (var store in supermarketOptions)
                                {
                                    var isSelectedStore = store.Equals(selectedSupermarket, StringComparison.OrdinalIgnoreCase);
                                    <label class="aislepilot-supermarket-option">
                                        @if (isSelectedStore)
                                        {
                                            <input type="radio" name="Request.Supermarket" value="@store" checked data-supermarket-option />
                                        }
                                        else
                                        {
                                            <input type="radio" name="Request.Supermarket" value="@store" data-supermarket-option />
                                        }
                                        <span>@FormatSupermarketLabel(store)</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Request.Supermarket" class="text-danger"></span>
                        </fieldset>
                    </details>

                    <details class="aislepilot-collapsible"
                             data-plan-basic-item="meal-types">
                        <summary>
                            <span class="aislepilot-collapsible-title">Meal slots</span>
                            <span class="aislepilot-collapsible-value" data-plan-basic-summary>@selectedMealTypesSummaryText</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                            <label asp-for="Request.MealsPerDay" class="sr-only">Meal slots</label>
                            <input asp-for="Request.MealsPerDay" type="hidden" value="@selectedMealsPerDay" />
                            <input type="hidden" name="Request.SelectedMealTypes" value="" />
                            <div class="aislepilot-meals-per-day-options" role="group" aria-label="Meal slots">
                                <label class="aislepilot-meals-per-day-option">
                                    @if (selectedMealTypesSet.Contains("Breakfast"))
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Breakfast" checked />
                                    }
                                    else
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Breakfast" />
                                    }
                                    <span>Breakfast</span>
                                </label>
                                <label class="aislepilot-meals-per-day-option">
                                    @if (selectedMealTypesSet.Contains("Lunch"))
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Lunch" checked />
                                    }
                                    else
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Lunch" />
                                    }
                                    <span>Lunch</span>
                                </label>
                                <label class="aislepilot-meals-per-day-option">
                                    @if (selectedMealTypesSet.Contains("Dinner"))
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Dinner" checked />
                                    }
                                    else
                                    {
                                        <input type="checkbox" name="Request.SelectedMealTypes" value="Dinner" />
                                    }
                                    <span>Dinner</span>
                                </label>
                            </div>
                            <span asp-validation-for="Request.SelectedMealTypes" class="text-danger"></span>
                            <span asp-validation-for="Request.MealsPerDay" class="text-danger"></span>
                        </fieldset>
                    </details>

                    <details class="aislepilot-collapsible"
                             data-plan-basic-item="plan-days">
                        <summary>
                            <span class="aislepilot-collapsible-title">Plan length</span>
                            <span class="aislepilot-collapsible-value" data-plan-basic-summary>@($"{selectedPlanDays} day{(selectedPlanDays == 1 ? string.Empty : "s")}")</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-plan-basics">
                            <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact">
                                <label asp-for="Request.PlanDays">Plan length</label>
                                <div class="aislepilot-slider-track-line">
                                    <span class="aislepilot-slider-boundary">1</span>
                                    <input asp-for="Request.PlanDays"
                                           type="range"
                                           min="1"
                                           max="7"
                                           step="1"
                                           class="aislepilot-slider-input"
                                           aria-label="Plan length"
                                           data-number-slider-range
                                           data-number-slider-decimals="0"
                                           data-plan-days-slider />
                                    <span class="aislepilot-slider-boundary">7</span>
                                </div>
                                <div class="aislepilot-slider-meta">
                                    <span class="aislepilot-slider-value" data-number-slider-value>@selectedPlanDays</span>
                                </div>
                                <span asp-validation-for="Request.PlanDays" class="text-danger"></span>
                            </div>
                        </fieldset>
                    </details>

                    <input asp-for="Request.CookDays" type="hidden" value="@selectedCookDays" />

                    <details class="aislepilot-collapsible"
                             data-plan-basic-item="budget">
                        <summary>
                            <span class="aislepilot-collapsible-title">Weekly budget</span>
                            <span class="aislepilot-collapsible-value" data-plan-basic-summary>@Model.Request.WeeklyBudget.ToString("C0", ukCulture)</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-plan-basics">
                            <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact aislepilot-budget-slider-field">
                                <label asp-for="Request.WeeklyBudget">Weekly budget</label>
                                <div class="aislepilot-slider-track-line">
                                    <span class="aislepilot-slider-boundary" data-budget-min-label>&pound;15</span>
                                    <input asp-for="Request.WeeklyBudget"
                                           type="range"
                                           min="15"
                                           max="600"
                                           step="5"
                                           class="aislepilot-slider-input"
                                           aria-label="Weekly budget"
                                           data-budget-slider
                                           data-number-slider-range
                                           data-number-slider-prefix="&pound;"
                                           data-number-slider-decimals="0" />
                                    <span class="aislepilot-slider-boundary" data-budget-max-label>&pound;600</span>
                                </div>
                                <div class="aislepilot-slider-meta aislepilot-budget-meta">
                                    <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.WeeklyBudget.ToString("0", ukCulture)</span>
                                    <button type="button"
                                            class="aislepilot-budget-precision-trigger"
                                            data-budget-precision-trigger
                                            hidden>
                                        Need exact amount?
                                    </button>
                                    <span class="aislepilot-budget-precision"
                                          data-budget-precision-shell
                                          hidden>
                                        <span class="aislepilot-budget-precision-currency" aria-hidden="true">&pound;</span>
                                        <input type="number"
                                               inputmode="numeric"
                                               min="15"
                                               max="600"
                                               step="5"
                                               value="@Model.Request.WeeklyBudget.ToString("0", ukCulture)"
                                               class="aislepilot-budget-precision-input"
                                               data-budget-precision-input
                                               aria-label="Set weekly budget exactly" />
                                    </span>
                                </div>
                                <span asp-validation-for="Request.WeeklyBudget" class="text-danger"></span>
                            </div>
                        </fieldset>
                    </details>

                    <details class="aislepilot-collapsible"
                             data-plan-basic-item="special-options">
                        <summary>
                            <span class="aislepilot-collapsible-title">Special options</span>
                            <span class="aislepilot-collapsible-value" data-special-options-summary>@specialOptionsSummaryText</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                            <div class="aislepilot-special-option-row">
                                <label class="aislepilot-checkbox-item aislepilot-toggle-chip">
                                    <input asp-for="Request.IncludeSpecialTreatMeal" type="checkbox" />
                                    <span>Special treat dinner on</span>
                                </label>
                                <div class="aislepilot-field aislepilot-field-chip aislepilot-special-treat-day-inline"
                                     data-special-treat-day-field
                                     hidden="@(!Model.Request.IncludeSpecialTreatMeal)">
                                    <label asp-for="Request.SelectedSpecialTreatCookDayIndex" class="sr-only">Special treat day</label>
                                    <select asp-for="Request.SelectedSpecialTreatCookDayIndex"
                                            class="aislepilot-special-treat-day-select"
                                            data-special-treat-day-select
                                            aria-label="Special treat day">
                                        @for (var cookDayIndex = 0; cookDayIndex < specialTreatCookDayLabels.Count; cookDayIndex++)
                                        {
                                            <option value="@cookDayIndex">@specialTreatCookDayLabels[cookDayIndex]</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <span asp-validation-for="Request.SelectedSpecialTreatCookDayIndex" class="text-danger"></span>
                            <label class="aislepilot-checkbox-item aislepilot-toggle-chip">
                                <input asp-for="Request.IncludeDessertAddOn" type="checkbox" />
                                <span>Add dessert</span>
                            </label>
                        </fieldset>
                    </details>
                </div>
            </div>
                    </section>

                    <section class="aislepilot-setup-step"
                             data-generator-only-preference
                             @generatorOnlyPreferenceHiddenAttribute>
                        <div class="aislepilot-setup-step-head">
                            <p class="aislepilot-setup-step-kicker">Step 2</p>
                            <h3 class="aislepilot-setup-step-title">Pantry rules</h3>
                            <p class="aislepilot-setup-step-copy">List what you have on hand and decide whether ideas should stay strict to those ingredients.</p>
                        </div>
            <div class="aislepilot-planner-settings">
                <h2 class="aislepilot-planner-settings-title">
                    <span class="aislepilot-symbol-label">
                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                <path d="M20 4v6h-6"></path>
                            </svg>
                        </span>
                        Generator settings
                    </span>
                </h2>

                <div class="aislepilot-planner-settings-list">
                    <details class="aislepilot-collapsible" open>
                        <summary>
                            <span class="aislepilot-collapsible-title">Foods on hand</span>
                            <span class="aislepilot-collapsible-value"
                                  data-pantry-summary
                                  title="@pantrySummaryText">@pantrySummaryText</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-generator-pantry-panel aislepilot-field aislepilot-field-optional aislepilot-pantry-entry-field">
                            <label asp-for="Request.PantryItems" class="sr-only">Pantry items</label>
                            <textarea asp-for="Request.PantryItems"
                                      class="aislepilot-pantry-entry-input"
                                      rows="3"
                                      placeholder="Example: rice, eggs, chicken breast, frozen peas, spinach, olive oil"></textarea>
                            <span asp-validation-for="Request.PantryItems" class="text-danger"></span>
                        </fieldset>
                    </details>

                    <details class="aislepilot-collapsible">
                        <summary>
                            <span class="aislepilot-collapsible-title">Core ingredients</span>
                            <span class="aislepilot-collapsible-value" data-generator-core-summary>@generatorCoreSummaryText</span>
                        </summary>
                        <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                            <label class="aislepilot-checkbox-item aislepilot-toggle-chip">
                                <input asp-for="Request.RequireCorePantryIngredients" type="checkbox" disabled="@(!shouldShowGeneratorMode)" />
                                <span>Only listed ingredients</span>
                            </label>
                        </fieldset>
                    </details>
                </div>
            </div>
                    </section>

            <section id="aislepilot-planner-mode"
                     class="aislepilot-setup-mode aislepilot-setup-step"
                     aria-label="Meal planner"
                     role="tabpanel"
                     data-setup-mode-panel="planner"
                     @plannerModeHiddenAttribute>
                <div class="aislepilot-setup-step-head">
                    <p class="aislepilot-setup-step-kicker">Step 3</p>
                    <h3 class="aislepilot-setup-step-title">Generate the week</h3>
                    <p class="aislepilot-setup-step-copy">Review the snapshot, then build a meal plan, recipes, and a supermarket-ordered shopping list.</p>
                </div>
                <div class="aislepilot-setup-mode-head">
                    <p class="aislepilot-setup-mode-copy">Build your weekly plan, recipes, and supermarket-ordered shopping list.</p>
                </div>

                <div class="aislepilot-setup-sections">
                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-plan-basics"
                              hidden
                              aria-hidden="true"
                              disabled>
                    <legend>
                        <span class="aislepilot-symbol-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <rect x="3.5" y="4.5" width="17" height="15" rx="2"></rect>
                                    <path d="M3.5 10h17M9 4.5v15M15 4.5v15"></path>
                                </svg>
                            </span>
                            Planner settings
                        </span>
                    </legend>
                    <div class="aislepilot-inline-fields">
                        <div class="aislepilot-field aislepilot-field-chip aislepilot-field--full">
                            <label asp-for="Request.Supermarket">Supermarket</label>
                            <div class="aislepilot-supermarket-options">
                                @foreach (var store in supermarketOptions)
                                {
                                    var isSelectedStore = store.Equals(selectedSupermarket, StringComparison.OrdinalIgnoreCase);
                                    <label class="aislepilot-supermarket-option">
                                        @if (isSelectedStore)
                                        {
                                            <input type="radio" name="Request.Supermarket" value="@store" checked data-supermarket-option />
                                        }
                                        else
                                    {
                                        <input type="radio" name="Request.Supermarket" value="@store" data-supermarket-option />
                                    }
                                        <span>@FormatSupermarketLabel(store)</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Request.Supermarket" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact">
                            <label asp-for="Request.WeeklyBudget">Weekly budget</label>
                            <div class="aislepilot-slider-track-line">
                                <span class="aislepilot-slider-boundary">&pound;15</span>
                                <input asp-for="Request.WeeklyBudget"
                                       type="range"
                                       min="15"
                                       max="600"
                                       step="5"
                                       class="aislepilot-slider-input"
                                       data-number-slider-range
                                       data-number-slider-prefix="&pound;"
                                       data-number-slider-decimals="0" />
                                <span class="aislepilot-slider-boundary">&pound;600</span>
                            </div>
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.WeeklyBudget.ToString("0", ukCulture)</span>
                            </div>
                            <span asp-validation-for="Request.WeeklyBudget" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact">
                            <label asp-for="Request.PlanDays">Plan length</label>
                            <div class="aislepilot-slider-track-line">
                                <span class="aislepilot-slider-boundary">1</span>
                                <input asp-for="Request.PlanDays"
                                       type="range"
                                       min="1"
                                       max="7"
                                       step="1"
                                       class="aislepilot-slider-input"
                                       data-number-slider-range
                                       data-number-slider-decimals="0"
                                       data-plan-days-slider />
                                <span class="aislepilot-slider-boundary">7</span>
                            </div>
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@selectedPlanDays</span>
                            </div>
                            <span asp-validation-for="Request.PlanDays" class="text-danger"></span>
                        </div>

                    </div>
                    </fieldset>

                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section"
                              data-store-layout-section
                              @storeLayoutSectionHiddenAttribute>
                        <legend>
                            <span class="aislepilot-symbol-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M12 21s6-5.5 6-10a6 6 0 1 0-12 0c0 4.5 6 10 6 10Z"></path>
                                        <circle cx="12" cy="11" r="2.2"></circle>
                                    </svg>
                                </span>
                                Store layout
                            </span>
                        </legend>
                        <div class="aislepilot-field" data-custom-aisle-field @customAisleFieldHiddenAttribute>
                            <label asp-for="Request.CustomAisleOrder">Custom aisle order (only for Custom supermarket)</label>
                            <input asp-for="Request.CustomAisleOrder" placeholder="Produce, Bakery, Dairy & Eggs, Frozen, Tins & Dry Goods..." />
                            <span asp-validation-for="Request.CustomAisleOrder" class="text-danger"></span>
                        </div>
                    </fieldset>
                </div>

                <div class="aislepilot-submit-actions">
                    <button type="submit"
                            data-loading-label="Generating plan..."
                            data-setup-mode-submit="planner"
                            data-show-plan-skeleton>
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M7 17 17 7"></path>
                                    <path d="M8 7h9v9"></path>
                                </svg>
                            </span>
                            Generate weekly plan
                        </span>
                    </button>
                </div>
            </section>

            <section id="aislepilot-generator-mode"
                     class="aislepilot-setup-mode is-secondary aislepilot-setup-step"
                     aria-label="Meal generator"
                     role="tabpanel"
                     data-setup-mode-panel="generator"
                     @generatorModeHiddenAttribute>
                <div class="aislepilot-setup-step-head">
                    <p class="aislepilot-setup-step-kicker">Step 3</p>
                    <h3 class="aislepilot-setup-step-title">Generate meal ideas</h3>
                    <p class="aislepilot-setup-step-copy">Create three quick ideas based on the foods already in your kitchen.</p>
                </div>
                <div class="aislepilot-setup-mode-head">
                    <p class="aislepilot-setup-mode-copy">Use your on-hand foods to generate 3 quick meal ideas.</p>
                </div>
                <div class="aislepilot-submit-actions aislepilot-generator-submit-actions">
                    <button
                        type="submit"
                        data-loading-label="Finding 3 meals..."
                        data-setup-mode-submit="generator"
                        formaction="@Url.Action("SuggestFromPantry", "AislePilot")">
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M13 2 5 13h6l-1 9 8-11h-6z"></path>
                                </svg>
                            </span>
                            Generate 3 meal ideas
                        </span>
                    </button>
                </div>
            </section>
                </div>

                <aside class="aislepilot-setup-summary"
                       aria-labelledby="aislepilot-setup-summary-title"
                       data-planner-only-preference
                       @plannerOnlyPreferenceHiddenAttribute>
                    <partial name="_AislePilotPlannerSetupSummary"
                             model='new AislePilotPlannerSetupSummaryViewModel
                             {
                                 ServingSummaryText = servingSummaryText,
                                 DietarySummaryText = dietarySummaryText,
                                 SelectedSupermarketLabel = FormatSupermarketLabel(selectedSupermarket),
                                 MealTypesSummaryText = selectedMealTypesSummaryText,
                                 PlanLengthText = $"{selectedPlanDays} day{(selectedPlanDays == 1 ? string.Empty : "s")}",
                                 BudgetText = Model.Request.WeeklyBudget.ToString("C0", ukCulture),
                                 SpecialOptionsSummaryText = specialOptionsSummaryText
                             }' />
                </aside>

                <aside class="aislepilot-setup-summary is-generator"
                       aria-labelledby="aislepilot-generator-summary-title"
                       data-generator-only-preference
                       @generatorOnlyPreferenceHiddenAttribute>
                    <partial name="_AislePilotGeneratorSetupSummary"
                             model='new AislePilotGeneratorSetupSummaryViewModel
                             {
                                 PantrySummaryText = pantrySummaryText,
                                 DietarySummaryText = dietarySummaryText,
                                 GeneratorCoreSummaryText = generatorCoreSummaryText,
                                 PreferQuickMeals = Model.Request.PreferQuickMeals
                             }' />
                </aside>
            </div>
        </form>
    </section>

    @if (hasDesktopResults)
    {
        <div class="aislepilot-results-stack">
        @if (Model.PantrySuggestions.Count > 0)
        {
            <partial name="_AislePilotPantrySuggestions"
                     model="Model"
                     view-data='new ViewDataDictionary(ViewData)
                     {
                         ["FallbackMealImageUrl"] = fallbackMealImageUrl,
                         ["MealImagesPollUrl"] = mealImagesPollUrl
                     }' />
        }

        <partial name="_AislePilotResultSections" model="Model" />
        </div>
    }
    else
    {
        <partial name="_AislePilotResultSections" model="Model" />
    }

    <partial name="_AislePilotPlanLoadingShell" />
    </div>
</div>

@section Head {
    <partial name="_AislePilotHeadAssets" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/aisle-pilot/setup-mode.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot/meal-image-polling.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot/core.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot/action-menus.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot/shopping.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot.js" asp-append-version="true"></script>
}
