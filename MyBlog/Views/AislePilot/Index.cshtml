                <div class="aislepilot-setup-mode-head">
                    <p class="aislepilot-setup-mode-copy">Use your on-hand foods to generate 3 quick meal ideas.</p>
                </div>
                <div class="aislepilot-submit-actions aislepilot-generator-submit-actions">
                    <button
                        type="submit"
                        data-loading-label="Finding 3 meals..."
                        data-setup-mode-submit="generator"
                        formaction="@Url.Action("SuggestFromPantry", "AislePilot")">
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M13 2 5 13h6l-1 9 8-11h-6z"></path>
                                </svg>
                            </span>
                            Generate 3 meal ideas
                        </span>
                    </button>
                </div>
            </section>
        </form>
    </section>

    @if (hasDesktopResults)
    {
        <div class="aislepilot-results-stack">
        @if (Model.PantrySuggestions.Count > 0)
        {
            var strictCoreModeEnabled = Model.Request.RequireCorePantryIngredients;
            var hasTopUpSuggestions = Model.PantrySuggestions.Any(suggestion => !suggestion.CanCookNow);
            var pantrySuggestionCountLabel = $"{Model.PantrySuggestions.Count} suggestion{(Model.PantrySuggestions.Count == 1 ? string.Empty : "s")}";
            var currentSuggestionMealNames = Model.PantrySuggestions
                .Select(suggestion => suggestion.MealName)
                .Where(mealName => !string.IsNullOrWhiteSpace(mealName))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
            var pantryIntroText = strictCoreModeEnabled
                ? "Strict core mode is on: each suggestion is built from your listed core ingredients plus minor basics only."
                : hasTopUpSuggestions
                    ? "Best matches from your ingredients. Some are cook-now dishes; some need a small top-up shop."
                    : "These dishes can be cooked immediately from what you already have.";
            <section aria-labelledby="aislepilot-pantry-title" class="aislepilot-shell" data-reveal>
                <div class="aislepilot-section-head aislepilot-section-head-row">
                    <h2 id="aislepilot-pantry-title" class="aislepilot-section-title">Meal suggestions</h2>
                    <span class="aislepilot-section-chip">@pantrySuggestionCountLabel</span>
                </div>
                <p class="section-intro">@pantryIntroText</p>
                <div class="aislepilot-meal-grid"
                     data-meal-image-poll-root
                     data-fallback-meal-image-url="@fallbackMealImageUrl"
                     data-meal-image-poll-enabled="@(Model.MealImagePollingEnabled ? "true" : "false")"
                     data-meal-image-poll-url="@mealImagesPollUrl">
                    @{
                        var pantrySuggestionIndex = 0;
                    }
                    @foreach (var suggestion in Model.PantrySuggestions)
                    {
                        var suggestionIndex = pantrySuggestionIndex++;
                        var meal = suggestion.MealCard;
                        var imageUrl = meal is null
                            ? fallbackMealImageUrl
                            : ResolveClientMealImageUrl(meal.MealImageUrl);
                        var shouldPrioritizeSuggestionImage = suggestionIndex < 2;
                        <article class="aislepilot-card">
                            <div class="aislepilot-meal-image-shell">
                                <img class="aislepilot-meal-image"
                                     src="@imageUrl"
                                     data-meal-image
                                     data-meal-name="@suggestion.MealName"
                                     alt="@($"{suggestion.MealName} plated meal")"
                                     loading="@(shouldPrioritizeSuggestionImage ? "eager" : "lazy")"
                                     fetchpriority="@(shouldPrioritizeSuggestionImage ? "high" : "low")"
                                     decoding="async" />
                            </div>
                            <div class="aislepilot-card-head aislepilot-card-head-with-title">
                                <h3>@suggestion.MealName</h3>
                                @if (!suggestion.CanCookNow && suggestion.MissingIngredientsEstimatedCost > 0m)
                                {
                                    <p class="aislepilot-cost">Top-up @suggestion.MissingIngredientsEstimatedCost.ToString("C", ukCulture)</p>
                                }
                            </div>
                            <div class="aislepilot-card-compact-meta">
                                <span class="aislepilot-card-meta-pill">
                                    <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" focusable="false">
                                            <circle cx="12" cy="12" r="7"></circle>
                                            <path d="M12 8v4l3 2"></path>
                                        </svg>
                                    </span>
                                    Prep @(meal?.EstimatedPrepMinutes ?? 25) mins
                                </span>
                                <span class="aislepilot-card-meta-pill">
                                    @(suggestion.CanCookNow
                                        ? "Cook now"
                                        : $"Needs {suggestion.MissingCoreIngredientCount} extra item{(suggestion.MissingCoreIngredientCount == 1 ? string.Empty : "s")}")
                                </span>
                                <span class="aislepilot-card-meta-pill">
                                    @($"{suggestion.MatchPercent}% pantry match")
                                </span>
                            </div>
                            <div class="aislepilot-card-action-row">
                                <details class="aislepilot-meal-details">
                                    <summary>
                                        <span class="aislepilot-btn-label">
                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" focusable="false">
                                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
                                                    <circle cx="12" cy="12" r="2.5"></circle>
                                                </svg>
                                            </span>
                                            View details
                                        </span>
                                    </summary>
                                    <div class="aislepilot-meal-details-panel">
                                        @if (meal is not null)
                                        {
                                            <p class="aislepilot-card-meta aislepilot-card-reason">@meal.MealReason</p>
                                        }
                                        <div class="aislepilot-meal-details-grid">
                                            <div class="aislepilot-nutrition-details">
                                                <p class="aislepilot-card-kicker">Est. calories + macros</p>
                                                <ul class="aislepilot-nutrition-list">
                                                    <li>@(meal?.CaloriesPerServing ?? 0) kcal per serving</li>
                                                    <li>Protein: @((meal?.ProteinGramsPerServing ?? 0m).ToString("0.#", ukCulture)) g</li>
                                                    <li>Carbs: @((meal?.CarbsGramsPerServing ?? 0m).ToString("0.#", ukCulture)) g</li>
                                                    <li>Fat: @((meal?.FatGramsPerServing ?? 0m).ToString("0.#", ukCulture)) g</li>
                                                </ul>
                                            </div>
                                            <div class="aislepilot-recipe-details">
                                                <p class="aislepilot-card-kicker">Ingredients</p>
                                                <ul class="case-list">
                                                    @foreach (var ingredient in meal?.IngredientLines ?? Array.Empty<string>())
                                                    {
                                                        <li>@ingredient</li>
                                                    }
                                                </ul>
                                                @if (suggestion.MissingIngredients.Count > 0)
                                                {
                                                    <p class="aislepilot-card-kicker">Need to buy</p>
                                                    <ul class="case-list">
                                                        @foreach (var item in suggestion.MissingIngredients)
                                                        {
                                                            <li>@item</li>
                                                        }
                                                    </ul>
                                                }
                                                <p class="aislepilot-card-kicker">Method</p>
                                                <ol class="case-list">
                                                    @foreach (var step in meal?.RecipeSteps ?? Array.Empty<string>())
                                                    {
                                                        <li>@step</li>
                                                    }
                                                </ol>
                                            </div>
                                        </div>
                                    </div>
                                </details>
                                <form method="post"
                                      action="@Url.Action("SwapPantrySuggestion", "AislePilot")#aislepilot-pantry-title"
                                      class="aislepilot-swap-form aislepilot-card-action-inline">
                                    @Html.AntiForgeryToken()
                                    <partial name="_AislePilotHiddenRequestFields" model="BuildPantryHiddenRequestFields()" />
                                    @foreach (var mealName in currentSuggestionMealNames)
                                    {
                                        <input type="hidden" name="currentSuggestionMealNames" value="@mealName" />
                                    }
                                    <input type="hidden" name="currentMealName" value="@suggestion.MealName" />
                                    <button type="submit" class="aislepilot-swap-btn" data-loading-label="Swapping...">
                                        <span class="aislepilot-btn-label">
                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" focusable="false">
                                                    <path d="M16 3h5v5"></path>
                                                    <path d="M21 3 9 15"></path>
                                                    <path d="M8 21H3v-5"></path>
                                                    <path d="M3 21 15 9"></path>
                                                </svg>
                                            </span>
                                            Swap idea
                                        </span>
                                    </button>
                                </form>
                            </div>
                            @if (suggestion.MissingIngredients.Count > 0 && meal is null)
                            {
                                <p class="aislepilot-card-kicker">Need to buy</p>
                                <ul class="case-list">
                                    @foreach (var item in suggestion.MissingIngredients)
                                    {
                                        <li>@item</li>
                                    }
                                </ul>
                            }
                        </article>
                    }
                    <form method="post"
                          action="@Url.Action("SuggestFromPantry", "AislePilot")#aislepilot-pantry-title"
                          class="aislepilot-pantry-refresh-form aislepilot-pantry-refresh-tile">
                        @Html.AntiForgeryToken()
                        <partial name="_AislePilotHiddenRequestFields" model="BuildPantryHiddenRequestFields()" />
                        @foreach (var mealName in currentSuggestionMealNames)
                        {
                            <input type="hidden" name="excludedMealNames" value="@mealName" />
                        }
                        <button type="submit" class="aislepilot-swap-btn" data-loading-label="Finding 3 more...">
                            <span class="aislepilot-btn-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                        <path d="M20 4v6h-6"></path>
                                    </svg>
                                </span>
                                Show 3 more ideas
                            </span>
                        </button>
                    </form>
                </div>
            </section>
        }

        <partial name="_AislePilotResultSections" model="Model" />
        </div>
    }
    else
    {
        <partial name="_AislePilotResultSections" model="Model" />
    }

    <div class="aislepilot-plan-loading-shell" data-plan-loading-shell hidden aria-hidden="true">
        <div class="aislepilot-plan-loading-surface" role="status" aria-live="polite">
            <p class="aislepilot-plan-loading-title">Building your weekly plan...</p>
            <p class="aislepilot-plan-loading-meta">This usually takes around 10-20 seconds.</p>
            <div class="aislepilot-plan-loading-grid" aria-hidden="true">
                <div class="aislepilot-plan-loading-card">
                    <div class="aislepilot-plan-loading-line is-wide"></div>
                    <div class="aislepilot-plan-loading-line"></div>
                    <div class="aislepilot-plan-loading-line is-short"></div>
                </div>
                <div class="aislepilot-plan-loading-card">
                    <div class="aislepilot-plan-loading-line is-wide"></div>
                    <div class="aislepilot-plan-loading-line"></div>
                    <div class="aislepilot-plan-loading-line is-short"></div>
                </div>
                <div class="aislepilot-plan-loading-card">
                    <div class="aislepilot-plan-loading-line is-wide"></div>
                    <div class="aislepilot-plan-loading-line"></div>
                    <div class="aislepilot-plan-loading-line is-short"></div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

@section Head {
    <link rel="icon" type="image/svg+xml" href="~/images/aislepilot-favicon.svg" />
    <link rel="apple-touch-icon" href="~/images/aislepilot-icon.svg" />
    <meta name="theme-color" content="#103F65" />
    <script>
        (() => {
            try {
                const key = "aislepilot:swap-scroll";
                const raw = sessionStorage.getItem(key);
                if (!raw) {
                    return;
                }

                const parsed = JSON.parse(raw);
                if (!parsed || typeof parsed.y !== "number") {
                    sessionStorage.removeItem(key);
                    return;
                }

                if (typeof parsed.at === "number" && Date.now() - parsed.at > 60_000) {
                    sessionStorage.removeItem(key);
                    return;
                }

                document.documentElement.classList.add("aislepilot-restore-pending");
            } catch {
                // Ignore storage parsing issues.
            }
        })();
    </script>
    <link rel="stylesheet" href="~/css/aisle-pilot.css" asp-append-version="true" />
    <noscript>
        <style>
            [data-setup-panel][hidden] { display: block !important; }
            [data-setup-toggle] { display: none !important; }
            [data-aislepilot-window] .aislepilot-window-controls,
            [data-aislepilot-window] .aislepilot-window-tabs { display: none !important; }
            [data-aislepilot-window] .aislepilot-mobile-context { display: none !important; }
            [data-aislepilot-window] .aislepilot-window-viewport { overflow: visible !important; height: auto !important; }
            [data-aislepilot-window] .aislepilot-window-track { display: block !important; transform: none !important; }
            [data-aislepilot-window] .aislepilot-window-panel { min-width: 100% !important; margin-bottom: 0.75rem; }
        </style>
    </noscript>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/aisle-pilot/setup-mode.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot/meal-image-polling.js" asp-append-version="true"></script>
    <script src="~/js/aisle-pilot.js" asp-append-version="true"></script>
}
