@using System.Globalization
@using System.Text
@model AislePilotPageViewModel
@{
    Layout = "_AislePilotLayout";
    ViewData["ReturnUrl"] = Model.ReturnUrl;
    ViewData["Title"] = "AislePilot";
    ViewData["MetaDescription"] =
        "AislePilot prototype: generate a weekly meal plan, track budget, and create a supermarket-ordered shopping list.";
    ViewData["CanonicalPath"] = "/projects/aisle-pilot";
    ViewData["OgImage"] = "/images/aislepilot-icon.svg";
    var ukCulture = CultureInfo.GetCultureInfo("en-GB");
    var supermarketOptions = Model.SupermarketOptions.Count > 0
        ? Model.SupermarketOptions.ToArray()
        : ["Tesco"];
    var portionSizeOptions = Model.PortionSizeOptions.Count > 0
        ? Model.PortionSizeOptions.ToArray()
        : ["Small", "Medium", "Large"];
    var selectedSupermarket = supermarketOptions.FirstOrDefault(
        option => option.Equals(Model.Request.Supermarket, StringComparison.OrdinalIgnoreCase))
        ?? supermarketOptions[0];
    var selectedPortionSizeIndex = Array.FindIndex(portionSizeOptions,
        option => option.Equals(Model.Request.PortionSize, StringComparison.OrdinalIgnoreCase));
    if (selectedPortionSizeIndex < 0)
    {
        selectedPortionSizeIndex = 0;
    }
    var portionSizeSliderValues = string.Join("|", portionSizeOptions);
    var selectedPortionSize = portionSizeOptions[selectedPortionSizeIndex];
    var isCustomSupermarketSelected = string.Equals(selectedSupermarket, "Custom", StringComparison.OrdinalIgnoreCase);
    var selectedDietary = Model.Request.DietaryModes.ToHashSet(StringComparer.OrdinalIgnoreCase);
    var hasResult = Model.HasResult && Model.Result is not null;
    var setupHiddenAttribute = hasResult ? "hidden" : null;
    var storeLayoutSectionHiddenAttribute = isCustomSupermarketSelected ? null : "hidden";
    var customAisleFieldHiddenAttribute = isCustomSupermarketSelected ? null : "hidden";
    var hasPantryValidationErrors = ViewData.ModelState.TryGetValue("Request.PantryItems", out var pantryFieldState) &&
        pantryFieldState.Errors.Count > 0;
    var shouldShowGeneratorMode = Model.PantrySuggestions.Count > 0 || hasPantryValidationErrors;
    var defaultSetupMode = shouldShowGeneratorMode ? "generator" : "planner";
    var forceDefaultSetupMode = shouldShowGeneratorMode ? "true" : "false";
    var plannerModeHiddenAttribute = shouldShowGeneratorMode ? "hidden" : null;
    var generatorModeHiddenAttribute = shouldShowGeneratorMode ? null : "hidden";
    var plannerToggleClass = shouldShowGeneratorMode
        ? "aislepilot-setup-mode-toggle"
        : "aislepilot-setup-mode-toggle is-active";
    var generatorToggleClass = shouldShowGeneratorMode
        ? "aislepilot-setup-mode-toggle is-active"
        : "aislepilot-setup-mode-toggle";
    var appHeadClass = hasResult ? "aislepilot-app-head is-compact" : "aislepilot-app-head";
    var modelErrors = ViewData.ModelState.Values
        .SelectMany(state => state.Errors)
        .Select(error => error.ErrorMessage?.Trim())
        .Where(message => !string.IsNullOrWhiteSpace(message))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    var hasModelErrors = modelErrors.Count > 0;
    var joinedErrorText = string.Join(" ", modelErrors).ToLowerInvariant();
    string FormatSetupOptionLabel(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return value;
        }

        return value.Trim().ToUpperInvariant();
    }
    var looksLikeSwapIssue =
        joinedErrorText.Contains("swap", StringComparison.Ordinal) ||
        joinedErrorText.Contains("selected day was out of range", StringComparison.Ordinal) ||
        joinedErrorText.Contains("current plan", StringComparison.Ordinal);
    var looksLikeConstraintIssue =
        joinedErrorText.Contains("no meals match", StringComparison.Ordinal) ||
        joinedErrorText.Contains("dietary", StringComparison.Ordinal) ||
        joinedErrorText.Contains("allergen", StringComparison.Ordinal);
    var looksLikeAiIssue =
        joinedErrorText.Contains("ai", StringComparison.Ordinal) ||
        joinedErrorText.Contains("rate", StringComparison.Ordinal) ||
        joinedErrorText.Contains("timeout", StringComparison.Ordinal) ||
        joinedErrorText.Contains("temporarily", StringComparison.Ordinal) ||
        joinedErrorText.Contains("unavailable", StringComparison.Ordinal);
}

<div class="aislepilot-app">
    <section aria-label="AislePilot header" class="@appHeadClass" data-reveal>
        <div class="aislepilot-brand-lockup" aria-label="AislePilot brand">
            <img class="aislepilot-brand-logo" src="~/images/aislepilot-logo-horizontal.svg" alt="AislePilot" />
        </div>
        @if (!hasResult)
        {
            <h1 id="aislepilot-title" class="aislepilot-app-title">The fastest way to plan meals and shop your supermarket.</h1>
            <p class="aislepilot-app-subtitle">
                Mobile-first weekly planning with supermarket-aware shopping order, recipes, and exports for real in-store use.
            </p>
        }
    </section>

    @if (hasModelErrors)
    {
        var alertTitle = looksLikeSwapIssue
            ? "Could not swap that meal"
            : looksLikeConstraintIssue
                ? "Constraints are too strict for this plan"
                : looksLikeAiIssue
                    ? "Meal generation is temporarily unavailable"
                    : "Something needs attention";
        var alertGuidance = looksLikeSwapIssue
            ? "Try swapping again, or regenerate your plan to refresh all meals."
            : looksLikeConstraintIssue
                ? "Remove one dietary constraint or allergen, then generate again."
                : looksLikeAiIssue
                    ? "Wait 15-30 seconds and retry. If it still fails, regenerate with fewer strict constraints."
                    : "Review the message below and try again.";

        <section aria-labelledby="aislepilot-alert-title" class="aislepilot-shell aislepilot-alert-shell" data-reveal>
            <h2 id="aislepilot-alert-title" class="aislepilot-section-title">@alertTitle</h2>
            <p class="aislepilot-alert-guidance">@alertGuidance</p>
            <ul class="aislepilot-alert-list">
                @foreach (var errorMessage in modelErrors.Take(3))
                {
                    <li>@errorMessage</li>
                }
            </ul>
            <div class="aislepilot-alert-actions">
                <button type="submit"
                        class="aislepilot-alert-btn"
                        form="aislepilot-setup-form"
                        data-loading-label="Generating plan...">
                    Try generating again
                </button>
                @if (hasResult)
                {
                    <button type="button"
                            class="aislepilot-alert-btn is-secondary"
                            data-setup-toggle
                            aria-controls="aislepilot-setup"
                            aria-expanded="false">
                        Edit setup first
                    </button>
                }
                else
                {
                    <a href="#aislepilot-setup" class="aislepilot-alert-btn is-secondary">Review setup</a>
                }
            </div>
        </section>
    }

    <section id="aislepilot-setup" aria-labelledby="aislepilot-form-title" class="aislepilot-shell" data-reveal data-setup-panel @setupHiddenAttribute>
        <h2 id="aislepilot-form-title" class="aislepilot-section-title">Setup</h2>

        <form method="post" asp-action="Index" id="aislepilot-setup-form" class="contact-form aislepilot-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <input type="hidden" name="SetupMode" value="@defaultSetupMode" data-setup-mode-value />
            @if (!hasModelErrors)
            {
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            }

            <div class="aislepilot-setup-mode-switch"
                 role="tablist"
                 aria-label="Setup mode"
                 data-setup-mode-switch
                 data-setup-mode-default="@defaultSetupMode"
                 data-setup-mode-force-default="@forceDefaultSetupMode">
                <button type="button"
                        class="@plannerToggleClass"
                        role="tab"
                        aria-controls="aislepilot-planner-mode"
                        aria-selected="@(shouldShowGeneratorMode ? "false" : "true")"
                        data-setup-mode-toggle="planner">
                    <span class="aislepilot-setup-mode-toggle-title">Meal planner</span>
                    <span class="aislepilot-setup-mode-toggle-note">Multi-day output</span>
                </button>
                <button type="button"
                        class="@generatorToggleClass"
                        role="tab"
                        aria-controls="aislepilot-generator-mode"
                        aria-selected="@(shouldShowGeneratorMode ? "true" : "false")"
                        data-setup-mode-toggle="generator">
                    <span class="aislepilot-setup-mode-toggle-title">Meal generator</span>
                    <span class="aislepilot-setup-mode-toggle-note">Single meal output</span>
                </button>
            </div>

            <section id="aislepilot-planner-mode"
                     class="aislepilot-setup-mode"
                     aria-label="Meal planner"
                     role="tabpanel"
                     data-setup-mode-panel="planner"
                     @plannerModeHiddenAttribute>
                <div class="aislepilot-setup-mode-head">
                    <p class="aislepilot-setup-mode-copy">Build your weekly plan, recipes, and supermarket-ordered shopping list.</p>
                </div>

                <div class="aislepilot-setup-sections">
                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-plan-basics">
                    <legend>
                        <span class="aislepilot-symbol-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <rect x="3.5" y="4.5" width="17" height="15" rx="2"></rect>
                                    <path d="M3.5 10h17M9 4.5v15M15 4.5v15"></path>
                                </svg>
                            </span>
                            Plan basics
                        </span>
                    </legend>
                    <div class="aislepilot-inline-fields">
                        <div class="aislepilot-field aislepilot-field-chip aislepilot-field--full">
                            <label asp-for="Request.Supermarket">Supermarket</label>
                            <div class="aislepilot-supermarket-options">
                                @foreach (var store in supermarketOptions)
                                {
                                    var isSelectedStore = store.Equals(selectedSupermarket, StringComparison.OrdinalIgnoreCase);
                                    <label class="aislepilot-supermarket-option">
                                        @if (isSelectedStore)
                                        {
                                            <input type="radio" name="Request.Supermarket" value="@store" checked data-supermarket-option />
                                        }
                                        else
                                    {
                                        <input type="radio" name="Request.Supermarket" value="@store" data-supermarket-option />
                                    }
                                        <span>@FormatSetupOptionLabel(store)</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Request.Supermarket" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field">
                            <label asp-for="Request.WeeklyBudget">Weekly budget</label>
                            <input asp-for="Request.WeeklyBudget"
                                   type="range"
                                   min="15"
                                   max="600"
                                   step="5"
                                   class="aislepilot-slider-input"
                                   data-number-slider-range
                                   data-number-slider-prefix="£"
                                   data-number-slider-decimals="0" />
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.WeeklyBudget.ToString("0", ukCulture)</span>
                                <span class="aislepilot-slider-hint">£15 to £600</span>
                            </div>
                            <span asp-validation-for="Request.WeeklyBudget" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field">
                            <label asp-for="Request.HouseholdSize">People</label>
                            <input asp-for="Request.HouseholdSize"
                                   type="range"
                                   min="1"
                                   max="8"
                                   step="1"
                                   class="aislepilot-slider-input"
                                   data-number-slider-range
                                   data-number-slider-decimals="0" />
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.HouseholdSize</span>
                                <span class="aislepilot-slider-hint">1 to 8</span>
                            </div>
                            <span asp-validation-for="Request.HouseholdSize" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field" data-option-slider>
                            <label asp-for="Request.PortionSize">Portion size</label>
                            <input asp-for="Request.PortionSize" type="hidden" data-option-slider-hidden />
                            <input type="range"
                                   min="0"
                                   max="@Math.Max(0, portionSizeOptions.Length - 1)"
                                   step="1"
                                   value="@selectedPortionSizeIndex"
                                   class="aislepilot-slider-input"
                                   data-option-slider-range
                                   data-option-slider-values="@portionSizeSliderValues" />
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-option-slider-value>@selectedPortionSize</span>
                                <span class="aislepilot-slider-hint">@portionSizeOptions.First() to @portionSizeOptions.Last()</span>
                            </div>
                            <span asp-validation-for="Request.PortionSize" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field">
                            <label asp-for="Request.CookDays">Cook days</label>
                            <input asp-for="Request.CookDays"
                                   type="range"
                                   min="1"
                                   max="7"
                                   step="1"
                                   class="aislepilot-slider-input"
                                   data-number-slider-range
                                   data-number-slider-decimals="0" />
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.CookDays</span>
                                <span class="aislepilot-slider-hint">1 to 7</span>
                            </div>
                            <span asp-validation-for="Request.CookDays" class="text-danger"></span>
                        </div>
                    </div>
                    </fieldset>

                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section aislepilot-dietary-grid">
                        <legend>
                            <span class="aislepilot-symbol-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M6 14c0-5 4-8 12-8-1 8-4 12-9 12-2 0-3-2-3-4z"></path>
                                        <path d="M9 15c2-2 4-4 8-6"></path>
                                    </svg>
                                </span>
                                Dietary requirements
                            </span>
                        </legend>
                        @foreach (var mode in Model.DietaryOptions)
                        {
                            var isChecked = selectedDietary.Contains(mode);
                            <label class="aislepilot-mode-option">
                                @if (isChecked)
                                {
                                    <input type="checkbox" name="Request.DietaryModes" value="@mode" checked />
                                }
                                else
                                {
                                    <input type="checkbox" name="Request.DietaryModes" value="@mode" />
                                }
                                <span>@FormatSetupOptionLabel(mode)</span>
                            </label>
                        }
                        <span asp-validation-for="Request.DietaryModes" class="text-danger"></span>
                    </fieldset>

                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                        <legend>
                            <span class="aislepilot-symbol-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <circle cx="12" cy="13" r="7"></circle>
                                        <path d="M12 13V9M9 3h6"></path>
                                    </svg>
                                </span>
                                Cooking preferences
                            </span>
                        </legend>
                        <label class="aislepilot-checkbox-item aislepilot-toggle-chip">
                            <input asp-for="Request.PreferQuickMeals" type="checkbox" />
                            <span>Prioritise quick meals</span>
                        </label>
                    </fieldset>

                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                        <legend>
                            <span class="aislepilot-symbol-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <circle cx="12" cy="12" r="8"></circle>
                                        <path d="M8 8l8 8"></path>
                                    </svg>
                                </span>
                                Exclusions
                            </span>
                        </legend>
                        <div class="aislepilot-field aislepilot-field-optional">
                            <label asp-for="Request.DislikesOrAllergens">Dislikes/allergens</label>
                            <input asp-for="Request.DislikesOrAllergens" placeholder="Example: peanuts, mushrooms, shellfish" />
                            <span asp-validation-for="Request.DislikesOrAllergens" class="text-danger"></span>
                        </div>
                    </fieldset>

                    <fieldset class="aislepilot-checkboxes aislepilot-setup-section"
                              data-store-layout-section
                              @storeLayoutSectionHiddenAttribute>
                        <legend>
                            <span class="aislepilot-symbol-label">
                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" focusable="false">
                                        <path d="M12 21s6-5.5 6-10a6 6 0 1 0-12 0c0 4.5 6 10 6 10Z"></path>
                                        <circle cx="12" cy="11" r="2.2"></circle>
                                    </svg>
                                </span>
                                Store layout
                            </span>
                        </legend>
                        <div class="aislepilot-field" data-custom-aisle-field @customAisleFieldHiddenAttribute>
                            <label asp-for="Request.CustomAisleOrder">Custom aisle order (only for Custom supermarket)</label>
                            <input asp-for="Request.CustomAisleOrder" placeholder="Produce, Bakery, Dairy & Eggs, Frozen, Tins & Dry Goods..." />
                            <span asp-validation-for="Request.CustomAisleOrder" class="text-danger"></span>
                        </div>
                    </fieldset>
                </div>

                <div class="aislepilot-submit-actions">
                    <button type="submit" data-loading-label="Generating plan..." data-setup-mode-submit="planner">
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M7 17 17 7"></path>
                                    <path d="M8 7h9v9"></path>
                                </svg>
                            </span>
                            Generate weekly plan
                        </span>
                    </button>
                </div>
            </section>

            <section id="aislepilot-generator-mode"
                     class="aislepilot-setup-mode is-secondary"
                     aria-label="Meal generator"
                     role="tabpanel"
                     data-setup-mode-panel="generator"
                     @generatorModeHiddenAttribute>
                <div class="aislepilot-setup-mode-head">
                    <p class="aislepilot-setup-mode-copy">Generate one quick dish from pantry items using your dietary requirements.</p>
                </div>
                <fieldset class="aislepilot-checkboxes aislepilot-setup-section">
                    <legend>
                        <span class="aislepilot-symbol-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M3 7.5 12 3l9 4.5v9L12 21l-9-4.5z"></path>
                                    <path d="M12 21v-9"></path>
                                    <path d="M3 7.5 12 12l9-4.5"></path>
                                </svg>
                            </span>
                            Foods on hand
                        </span>
                    </legend>
                    <div class="aislepilot-field aislepilot-field-optional">
                        <label asp-for="Request.PantryItems">What foods do you already have?</label>
                        <input asp-for="Request.PantryItems" placeholder="Example: rice, eggs, chicken breast, frozen peas, spinach, olive oil" />
                        <span asp-validation-for="Request.PantryItems" class="text-danger"></span>
                    </div>
                </fieldset>
                <div class="aislepilot-submit-actions">
                    <button
                        type="submit"
                        data-loading-label="Finding meals..."
                        data-setup-mode-submit="generator"
                        formaction="@Url.Action("SuggestFromPantry", "AislePilot")">
                        <span class="aislepilot-btn-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M13 2 5 13h6l-1 9 8-11h-6z"></path>
                                </svg>
                            </span>
                            Generate dish now
                        </span>
                    </button>
                </div>
            </section>
        </form>
    </section>

@if (Model.PantrySuggestions.Count > 0)
{
    <section aria-labelledby="aislepilot-pantry-title" class="aislepilot-shell" data-reveal>
        <h2 id="aislepilot-pantry-title" class="aislepilot-section-title">Can make now</h2>
        <p class="section-intro">These meals can be made immediately from what you already have.</p>
        <div class="aislepilot-pantry-grid">
            @foreach (var suggestion in Model.PantrySuggestions)
            {
                <article class="aislepilot-card">
                    <div class="aislepilot-card-head">
                        <h3>@suggestion.MealName</h3>
                        <p class="aislepilot-cost">Ready now</p>
                    </div>
                    <p class="aislepilot-card-kicker">Have now</p>
                    <ul class="case-list">
                        @foreach (var item in suggestion.MatchedIngredients)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </section>
}

@if (hasResult)
{
    var result = Model.Result!;
    var aisleRank = result.AisleOrderUsed
        .Select((department, index) => new { department, index })
        .ToDictionary(x => x.department, x => x.index, StringComparer.OrdinalIgnoreCase);
    var groupedItems = result.ShoppingItems
        .GroupBy(item => item.Department)
        .OrderBy(group => aisleRank.GetValueOrDefault(group.Key, int.MaxValue))
        .ToList();
    var weekDayNames = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    var weekDayShortLabels = new[] { "M", "T", "W", "T", "F", "S", "S" };
    var weekDayLookup = weekDayNames
        .Select((name, index) => new { name, index })
        .ToDictionary(x => x.name, x => x.index, StringComparer.OrdinalIgnoreCase);
    var leftoverSourceWeekDayIndexes = result.MealPlan
        .SelectMany(meal =>
        {
            if (!weekDayLookup.TryGetValue(meal.Day, out var weekDayIndex))
            {
                return Enumerable.Empty<int>();
            }

            return Enumerable.Repeat(weekDayIndex, meal.LeftoverDaysCovered);
        })
        .ToList();
    var leftoverSourceDayIndexesCsv = string.Join(",", leftoverSourceWeekDayIndexes);
    var mealCount = result.MealPlan.Count;
    var mealLabel = mealCount == 1 ? "meal" : "meals";
    var totalShopItems = result.ShoppingItems.Count;
    var departmentCount = groupedItems.Count;
    var shoppingListNotesBuilder = new StringBuilder();
    shoppingListNotesBuilder.AppendLine("AislePilot Shopping List");
    shoppingListNotesBuilder.AppendLine($"Supermarket: {result.Supermarket}");
    shoppingListNotesBuilder.AppendLine($"Estimated total: {result.EstimatedTotalCost.ToString("C", ukCulture)}");
    shoppingListNotesBuilder.AppendLine();
    foreach (var department in groupedItems)
    {
        shoppingListNotesBuilder.AppendLine(department.Key);
        foreach (var item in department)
        {
            shoppingListNotesBuilder.AppendLine(
                $"[ ] {item.Name} ({item.QuantityDisplay}) - {item.EstimatedCost.ToString("C", ukCulture)}");
        }
        shoppingListNotesBuilder.AppendLine();
    }
    var shoppingListNotesText = shoppingListNotesBuilder.ToString().TrimEnd();

    <section id="aislepilot-overview" aria-labelledby="aislepilot-budget-title" class="aislepilot-shell" data-reveal>
        <div class="aislepilot-section-head">
            <h2 id="aislepilot-budget-title" class="aislepilot-section-title">Overview</h2>
            <div class="aislepilot-overview-actions">
                <form method="post" action="@Url.Action("Index", "AislePilot")#aislepilot-overview" class="aislepilot-overview-regenerate-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                    <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                    <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                    <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                    <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                    <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                    <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                    <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                    <input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@leftoverSourceDayIndexesCsv" />
                    <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                    <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                    @foreach (var mode in Model.Request.DietaryModes)
                    {
                        <input type="hidden" name="Request.DietaryModes" value="@mode" />
                    }
                    <button type="submit" class="aislepilot-overview-regenerate-btn" data-loading-label="Regenerating...">Regenerate plan</button>
                </form>
                <button
                    type="button"
                    class="aislepilot-edit-setup-btn"
                    data-setup-toggle
                    aria-controls="aislepilot-setup"
                    aria-expanded="false">
                    Edit setup
                </button>
            </div>
        </div>
        @if (result.IsOverBudget)
        {
            <div class="aislepilot-overbudget-flag" role="status" aria-live="polite">
                <p class="aislepilot-overbudget-title">
                    This plan is @Math.Abs(result.BudgetDelta).ToString("C", ukCulture) over your weekly budget.
                </p>
                <p class="aislepilot-overbudget-note">
                    Keep this plan if you are happy to spend more, or refresh with a lower-cost mix.
                </p>
                <form method="post"
                      action="@Url.Action("RebalanceBudget", "AislePilot")#aislepilot-overview"
                      class="aislepilot-overview-regenerate-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                    <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                    <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                    <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                    <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                    <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                    <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                    <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                    <input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@leftoverSourceDayIndexesCsv" />
                    <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                    <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                    @foreach (var mode in Model.Request.DietaryModes)
                    {
                        <input type="hidden" name="Request.DietaryModes" value="@mode" />
                    }
                    @foreach (var existingMeal in result.MealPlan)
                    {
                        <input type="hidden" name="currentPlanMealNames" value="@existingMeal.MealName" />
                    }
                    <button type="submit"
                            class="aislepilot-overview-regenerate-btn"
                            data-loading-label="Refreshing lower-cost plan...">
                        Refresh for lower cost
                    </button>
                </form>
            </div>
        }
        <div class="aislepilot-budget-grid">
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Supermarket</p>
                <p class="aislepilot-stat-value">@result.Supermarket</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Portion size</p>
                <p class="aislepilot-stat-value">@result.PortionSize</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Budget</p>
                <p class="aislepilot-stat-value">@result.WeeklyBudget.ToString("C", ukCulture)</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Estimated total</p>
                <p class="aislepilot-stat-value">@result.EstimatedTotalCost.ToString("C", ukCulture)</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Budget difference</p>
                <p class="aislepilot-stat-value @(result.IsOverBudget ? "is-over-budget" : "is-on-budget")">
                    @result.BudgetDelta.ToString("C", ukCulture)
                </p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Cook days</p>
                <p class="aislepilot-stat-value">@result.CookDays</p>
            </article>
            <article class="aislepilot-stat-card">
                <p class="aislepilot-stat-label">Leftovers</p>
                <p class="aislepilot-stat-value">@result.LeftoverDays day(s)</p>
            </article>
        </div>

    </section>

    <section class="aislepilot-shell aislepilot-window-shell" aria-labelledby="aislepilot-window-title" data-aislepilot-window data-reveal>
        <div class="aislepilot-window-head">
            <h2 id="aislepilot-window-title" class="aislepilot-section-title">
                Weekly plan
                <span class="aislepilot-window-title-meta">@mealCount @mealLabel generated</span>
            </h2>
            <div class="aislepilot-window-nav">
                <p class="aislepilot-window-nav-hint" data-window-hint>Tap a tab to switch between meals, shopping list, and exports.</p>
                <div class="aislepilot-window-tabs" role="tablist" aria-label="AislePilot weekly plan views">
                    <button type="button" id="aislepilot-tab-meals" class="aislepilot-window-tab" data-window-tab="aislepilot-meals" role="tab" aria-controls="aislepilot-meals" aria-selected="true">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="5" cy="7" r="1"></circle>
                                    <circle cx="5" cy="12" r="1"></circle>
                                    <circle cx="5" cy="17" r="1"></circle>
                                    <path d="M8 7h11M8 12h11M8 17h11"></path>
                                </svg>
                            </span>
                            Meals
                        </span>
                    </button>
                    <button type="button" id="aislepilot-tab-shop" class="aislepilot-window-tab" data-window-tab="aislepilot-shop" role="tab" aria-controls="aislepilot-shop" aria-selected="false">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <circle cx="9" cy="19" r="1.5"></circle>
                                    <circle cx="17" cy="19" r="1.5"></circle>
                                    <path d="M3 4h2l2.4 10h10.8l1.8-7H7"></path>
                                </svg>
                            </span>
                            Shopping
                        </span>
                    </button>
                    <button type="button" id="aislepilot-tab-export" class="aislepilot-window-tab" data-window-tab="aislepilot-export" role="tab" aria-controls="aislepilot-export" aria-selected="false">
                        <span class="aislepilot-tab-label">
                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false">
                                    <path d="M12 16V6"></path>
                                    <path d="m8 10 4-4 4 4"></path>
                                    <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"></path>
                                </svg>
                            </span>
                            Export
                        </span>
                    </button>
                </div>
            </div>
        </div>
        <div class="aislepilot-window-viewport" data-window-viewport>
            <div class="aislepilot-window-track" data-window-track>
                <section id="aislepilot-meals" aria-label="Meals" role="tabpanel" aria-labelledby="aislepilot-tab-meals" class="aislepilot-window-panel" data-window-name="Meals">
                    @if (result.LeftoverDays > 0)
                    {
                        <div class="aislepilot-leftover-editor">
                            <div class="aislepilot-leftover-editor-head">
                                <p class="aislepilot-window-meta">@result.LeftoverDays leftover day(s) are allocated. Green days are double-cook days.</p>
                                <button type="button"
                                        class="aislepilot-leftover-toggle"
                                        data-leftover-toggle
                                        aria-expanded="false">
                                    Rebalance leftovers
                                </button>
                            </div>
                            <div class="aislepilot-leftover-planner-shell" data-leftover-planner hidden>
                                <p class="aislepilot-leftover-helper">Tap a day with leftovers, then tap another day to move one leftover.</p>
                                <form method="post"
                                      action="@Url.Action("Index", "AislePilot")#aislepilot-meals"
                                      class="aislepilot-leftover-rebalance-form"
                                      data-leftover-rebalance-form
                                      data-preserve-scroll-form>
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                    <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                                    <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                                    <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                                    <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                                    <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                                    <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                                    <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                                    <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                                    <input type="hidden"
                                           name="Request.LeftoverCookDayIndexesCsv"
                                           value="@leftoverSourceDayIndexesCsv"
                                           data-leftover-csv />
                                    <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                                    <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                                    @foreach (var mode in Model.Request.DietaryModes)
                                    {
                                        <input type="hidden" name="Request.DietaryModes" value="@mode" />
                                    }
                                </form>
                                <div class="aislepilot-leftover-planner" role="list" aria-label="Leftover day allocation">
                                    @for (var dayIndex = 0; dayIndex < weekDayNames.Length; dayIndex++)
                                    {
                                        var dayLeftoverCount = leftoverSourceWeekDayIndexes.Count(index => index == dayIndex);
                                        var dayChipClass = dayLeftoverCount > 0
                                            ? "aislepilot-leftover-day-chip is-leftover-source"
                                            : "aislepilot-leftover-day-chip";
                                        <button type="button"
                                                class="@dayChipClass"
                                                data-leftover-day-zone
                                                data-day-index="@dayIndex"
                                                data-leftover-count="@dayLeftoverCount"
                                                aria-label="Leftover allocation for @weekDayNames[dayIndex]"
                                                role="listitem">
                                            <span class="aislepilot-leftover-day-name">@weekDayShortLabels[dayIndex]</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    <div class="aislepilot-meal-grid">
                        @for (var mealIndex = 0; mealIndex < result.MealPlan.Count; mealIndex++)
                        {
                            var meal = result.MealPlan[mealIndex];
                            var mealCardClass = meal.LeftoverDaysCovered > 0 ? "aislepilot-card is-leftover-source" : "aislepilot-card";
                            <article class="@mealCardClass" data-leftover-day-card data-day-index="@mealIndex">
                                <div class="aislepilot-meal-image-shell">
                                    <img class="aislepilot-meal-image"
                                         src="@meal.MealImageUrl"
                                         alt="@($"{meal.MealName} plated meal")"
                                         loading="lazy"
                                         decoding="async" />
                                </div>
                                <div class="aislepilot-card-head">
                                    <p class="aislepilot-card-kicker">@meal.Day</p>
                                    <p class="aislepilot-cost">@meal.EstimatedCost.ToString("C", ukCulture)</p>
                                </div>
                                <h3>@meal.MealName</h3>
                                <div class="aislepilot-card-compact-meta">
                                    <span class="aislepilot-card-meta-pill">
                                        <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" focusable="false">
                                                <circle cx="12" cy="12" r="7"></circle>
                                                <path d="M12 8v4l3 2"></path>
                                            </svg>
                                        </span>
                                        Prep @meal.EstimatedPrepMinutes mins
                                    </span>
                                    @if (meal.LeftoverDaysCovered > 0)
                                    {
                                        <span class="aislepilot-card-meta-pill">
                                            <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" focusable="false">
                                                    <path d="M20 12a8 8 0 1 1-2.3-5.6"></path>
                                                    <path d="M20 4v6h-6"></path>
                                                </svg>
                                            </span>
                                            Makes extra for @meal.LeftoverDaysCovered leftover day(s)
                                        </span>
                                    }
                                </div>
                                <div class="aislepilot-card-action-row">
                                    <details class="aislepilot-meal-details">
                                        <summary>
                                            <span class="aislepilot-btn-label">
                                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" focusable="false">
                                                        <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"></path>
                                                        <circle cx="12" cy="12" r="2.5"></circle>
                                                    </svg>
                                                </span>
                                                View details
                                            </span>
                                        </summary>
                                        <div class="aislepilot-meal-details-panel">
                                            <p class="aislepilot-card-meta aislepilot-card-reason">@meal.MealReason</p>
                                            <div class="aislepilot-meal-details-grid">
                                                <div class="aislepilot-nutrition-details">
                                                    <p class="aislepilot-card-kicker">Est. calories + macros</p>
                                                    <ul class="aislepilot-nutrition-list">
                                                        <li>@meal.CaloriesPerServing kcal per serving</li>
                                                        <li>Protein: @meal.ProteinGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                        <li>Carbs: @meal.CarbsGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                        <li>Fat: @meal.FatGramsPerServing.ToString("0.#", ukCulture) g</li>
                                                    </ul>
                                                </div>
                                                <div class="aislepilot-recipe-details">
                                                    <p class="aislepilot-card-kicker">Ingredients</p>
                                                    <ul class="case-list">
                                                        @foreach (var ingredientLine in meal.IngredientLines)
                                                        {
                                                            <li>@ingredientLine</li>
                                                        }
                                                    </ul>
                                                    <p class="aislepilot-card-kicker">Method</p>
                                                    <ol class="case-list">
                                                        @foreach (var step in meal.RecipeSteps)
                                                        {
                                                            <li>@step</li>
                                                        }
                                                    </ol>
                                                </div>
                                            </div>
                                        </div>
                                    </details>

                                    <form method="post"
                                          action="@Url.Action("SwapMeal", "AislePilot")#aislepilot-meals"
                                          class="aislepilot-swap-form aislepilot-card-action-inline"
                                          data-preserve-scroll-form
                                          data-ajax-swap-form>
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                        <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                                        <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                                        <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                                        <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                                        <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                                        <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                                        <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                                        <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                                        <input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@leftoverSourceDayIndexesCsv" />
                                        <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                                        <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                                        @foreach (var mode in Model.Request.DietaryModes)
                                        {
                                            <input type="hidden" name="Request.DietaryModes" value="@mode" />
                                        }
                                        @foreach (var existingMeal in result.MealPlan)
                                        {
                                            <input type="hidden" name="currentPlanMealNames" value="@existingMeal.MealName" />
                                        }
                                        <input type="hidden" name="dayIndex" value="@mealIndex" />
                                        <input type="hidden" name="currentMealName" value="@meal.MealName" />
                                        <button type="submit" class="aislepilot-swap-btn" data-loading-label="Swapping..." data-loading-delay-ms="220">
                                            <span class="aislepilot-btn-label">
                                                <span class="aislepilot-symbol-glyph" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" focusable="false">
                                                        <path d="M16 3h5v5"></path>
                                                        <path d="M21 3 9 15"></path>
                                                        <path d="M8 21H3v-5"></path>
                                                        <path d="M3 21 15 9"></path>
                                                    </svg>
                                                </span>
                                                Swap meal
                                            </span>
                                        </button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="aislepilot-shop" aria-label="Shopping" role="tabpanel" aria-labelledby="aislepilot-tab-shop" class="aislepilot-window-panel" data-window-name="Shopping">
                    <div class="aislepilot-shopping-grid">
                        @foreach (var department in groupedItems)
                        {
                            <article class="aislepilot-card">
                                <h3>@department.Key</h3>
                                <ul class="aislepilot-shop-list">
                                    @foreach (var item in department)
                                    {
                                        <li>
                                            <label class="aislepilot-checkbox-item">
                                                <input type="checkbox" />
                                                <span>@item.Name (@item.QuantityDisplay) - @item.EstimatedCost.ToString("C", ukCulture)</span>
                                            </label>
                                        </li>
                                    }
                                </ul>
                            </article>
                        }
                    </div>
                </section>

                <section id="aislepilot-export" aria-label="Export" role="tabpanel" aria-labelledby="aislepilot-tab-export" class="aislepilot-window-panel" data-window-name="Export">
                    <div class="aislepilot-export-actions">
                        <form method="post" asp-action="ExportPlanPack">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                            <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                            <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                            <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                            <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                            <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                            <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                            <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                            <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                            <input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@leftoverSourceDayIndexesCsv" />
                            <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                            <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                            @foreach (var mode in Model.Request.DietaryModes)
                            {
                                <input type="hidden" name="Request.DietaryModes" value="@mode" />
                            }
                            <button type="submit" class="aislepilot-export-btn" data-loading-label="Building PDF...">Download full plan pack (.pdf)</button>
                        </form>

                        <form method="post" asp-action="ExportChecklist">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                            <input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
                            <input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
                            <input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
                            <input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
                            <input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
                            <input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
                            <input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
                            <input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
                            <input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@leftoverSourceDayIndexesCsv" />
                            <input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
                            <input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
                            @foreach (var mode in Model.Request.DietaryModes)
                            {
                                <input type="hidden" name="Request.DietaryModes" value="@mode" />
                            }
                            <button type="submit" class="aislepilot-export-btn" data-loading-label="Building checklist...">Download shopping checklist (.txt)</button>
                        </form>

                        <button type="button" class="aislepilot-export-btn" onclick="window.print()">Print current view</button>

                        <div data-notes-export-shell>
                            <textarea hidden data-notes-export-content>@shoppingListNotesText</textarea>
                            <button type="button"
                                    class="aislepilot-export-btn"
                                    data-notes-export-trigger
                                    data-notes-default-label="Share shopping list to iPhone Notes"
                                    data-notes-shared-label="Share sheet opened. Choose Notes."
                                    data-notes-copied-label="Shopping list copied. Paste into Notes."
                                    data-notes-failed-label="Could not share. Try again.">
                                Share shopping list to iPhone Notes
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </section>
}
</div>

@section Head {
    <link rel="icon" type="image/svg+xml" href="~/images/aislepilot-favicon.svg" />
    <link rel="apple-touch-icon" href="~/images/aislepilot-icon.svg" />
    <meta name="theme-color" content="#103F65" />
    <script>
        (() => {
            try {
                const key = "aislepilot:swap-scroll";
                const raw = sessionStorage.getItem(key);
                if (!raw) {
                    return;
                }

                const parsed = JSON.parse(raw);
                if (!parsed || typeof parsed.y !== "number") {
                    sessionStorage.removeItem(key);
                    return;
                }

                if (typeof parsed.at === "number" && Date.now() - parsed.at > 60_000) {
                    sessionStorage.removeItem(key);
                    return;
                }

                document.documentElement.classList.add("aislepilot-restore-pending");
            } catch {
                // Ignore storage parsing issues.
            }
        })();
    </script>
    <link rel="stylesheet" href="~/css/aisle-pilot.css" asp-append-version="true" />
    <noscript>
        <style>
            [data-setup-panel][hidden] { display: block !important; }
            [data-setup-toggle] { display: none !important; }
            [data-aislepilot-window] .aislepilot-window-controls,
            [data-aislepilot-window] .aislepilot-window-tabs { display: none !important; }
            [data-aislepilot-window] .aislepilot-window-viewport { overflow: visible !important; height: auto !important; }
            [data-aislepilot-window] .aislepilot-window-track { display: block !important; transform: none !important; }
            [data-aislepilot-window] .aislepilot-window-panel { min-width: 100% !important; margin-bottom: 0.75rem; }
        </style>
    </noscript>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/aisle-pilot.js" asp-append-version="true"></script>
}
