                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact">
                            <label asp-for="Request.WeeklyBudget">Weekly budget</label>
                            <div class="aislepilot-slider-track-line">
                                <span class="aislepilot-slider-boundary">&pound;15</span>
                                <input asp-for="Request.WeeklyBudget"
                                       type="range"
                                       min="15"
                                       max="600"
                                       step="5"
                                       class="aislepilot-slider-input"
                                       data-number-slider-range
                                       data-number-slider-prefix="&pound;"
                                       data-number-slider-decimals="0" />
                                <span class="aislepilot-slider-boundary">&pound;600</span>
                            </div>
                            <div class="aislepilot-slider-meta">
                                <span class="aislepilot-slider-value" data-number-slider-value>@Model.Request.WeeklyBudget.ToString("0", ukCulture)</span>
                            </div>
                            <span asp-validation-for="Request.WeeklyBudget" class="text-danger"></span>
                        </div>

                        <div class="aislepilot-field aislepilot-field-chip aislepilot-slider-field aislepilot-slider-field--compact">
                            <label asp-for="Request.PlanDays">Plan length</label>
                            <div class="aislepilot-slider-track-line">
                                <span class="aislepilot-slider-boundary">1</span>
                                <input asp-for="Request.PlanDays"
                                       type="range"
                                       min="1"
                                       max="7"
                                       step="1"
                                       class="aislepilot-slider-input"
                                       data-number-slider-range
                                       data-number-slider-decimals="0"
