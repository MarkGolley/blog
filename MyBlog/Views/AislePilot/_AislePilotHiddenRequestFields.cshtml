@model AislePilotHiddenRequestFieldsViewModel
@{
    var dietaryModes = Model.Request.DietaryModes ?? [];
    var selectedMealTypes = Model.Request.SelectedMealTypes ?? [];
}

<input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
<input type="hidden" name="Request.Supermarket" value="@Model.Request.Supermarket" />
<input type="hidden" name="Request.WeeklyBudget" value="@Model.Request.WeeklyBudget" />
<input type="hidden" name="Request.HouseholdSize" value="@Model.Request.HouseholdSize" />
<input type="hidden" name="Request.PortionSize" value="@Model.Request.PortionSize" />
<input type="hidden" name="Request.PlanDays" value="@Model.Request.PlanDays" />
<input type="hidden" name="Request.CookDays" value="@Model.Request.CookDays" />
<input type="hidden" name="Request.MealsPerDay" value="@Model.Request.MealsPerDay" />
<input type="hidden" name="Request.DislikesOrAllergens" value="@Model.Request.DislikesOrAllergens" />
<input type="hidden" name="Request.CustomAisleOrder" value="@Model.Request.CustomAisleOrder" />
<input type="hidden" name="Request.PantryItems" value="@Model.Request.PantryItems" />
<input type="hidden" name="Request.RequireCorePantryIngredients" value="@(Model.Request.RequireCorePantryIngredients ? "true" : "false")" />
@if (Model.IncludeLeftoverCsvDataAttribute)
{
    <input type="hidden"
           name="Request.LeftoverCookDayIndexesCsv"
           value="@Model.LeftoverCookDayIndexesCsv"
           data-leftover-csv />
}
else
{
<input type="hidden" name="Request.LeftoverCookDayIndexesCsv" value="@Model.LeftoverCookDayIndexesCsv" />
}
<input type="hidden" name="Request.SwapHistoryState" value="@Model.Request.SwapHistoryState" />
<input type="hidden" name="Request.IgnoredMealSlotIndexesCsv" value="@Model.Request.IgnoredMealSlotIndexesCsv" />
<input type="hidden" name="Request.PantrySuggestionHistoryState" value="@Model.Request.PantrySuggestionHistoryState" />
<input type="hidden" name="Request.PreferQuickMeals" value="@(Model.Request.PreferQuickMeals ? "true" : "false")" />
<input type="hidden" name="Request.IncludeSpecialTreatMeal" value="@(Model.Request.IncludeSpecialTreatMeal ? "true" : "false")" />
<input type="hidden" name="Request.IncludeDessertAddOn" value="@(Model.Request.IncludeDessertAddOn ? "true" : "false")" />
<input type="hidden" name="Request.SelectedDessertAddOnName" value="@Model.Request.SelectedDessertAddOnName" />
@foreach (var mode in dietaryModes)
{
    <input type="hidden" name="Request.DietaryModes" value="@mode" />
}
@foreach (var mealType in selectedMealTypes)
{
    <input type="hidden" name="Request.SelectedMealTypes" value="@mealType" />
}

@if (Model.IncludeCurrentPlanMealNames)
{
    foreach (var mealName in Model.CurrentPlanMealNames)
    {
        <input type="hidden" name="currentPlanMealNames" value="@mealName" />
    }
}
