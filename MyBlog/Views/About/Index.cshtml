@{
    ViewData["Title"] = "About";
    ViewData["MetaDescription"] = "About Mark Golley, a C#/.NET and Python developer focused on maintainable software, testing, and practical delivery.";
    ViewData["CanonicalPath"] = "/about";
}

<section id="about" aria-labelledby="about-title" data-reveal>
    <div class="about-content">
        <div class="about-image">
            <img src="~/images/me.jpg" alt="Portrait of Mark" />
        </div>
        <div class="about-text">
            <h1 id="about-title">Hi, I'm Mark, a C#/.NET engineer focused on reliable delivery.</h1>
            <p class="intro">
                I build pragmatic web software with a strong bias toward readable architecture, useful test coverage,
                and delivery that holds up once it leaves local development.
            </p>
            <p class="intro">
                My day-to-day tools are JetBrains Rider and PyCharm. I'm based in <strong>Burley In Wharfedale, UK</strong>,
                and the concise version is: ASP.NET Core, C#, xUnit, Python, GCP, and a preference for shipping
                cleanly instead of overcomplicating the first version.
            </p>
            <div class="hero-actions">
                <a class="btn btn-primary" asp-controller="Projects" asp-action="Index">View selected work</a>
                <a class="btn btn-secondary" asp-controller="Blog" asp-action="Index">Read articles</a>
                <a class="btn btn-secondary" asp-controller="Contact" asp-action="Index">Get in touch</a>
            </div>
        </div>
    </div>
</section>

<section aria-labelledby="quick-bits-title" data-reveal>
    <h2 id="quick-bits-title">Working style</h2>
    <div class="credentials-grid">
        <div class="credential-card">
            <div class="credential-title">Stack</div>
            <div class="credential-value">C#, .NET, xUnit, Python, GCP</div>
            <p class="credential-copy">Backend product work, test automation, and engineering support tooling.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Delivery habits</div>
            <div class="credential-value">Scope tightly, prove behaviour, then extend</div>
            <p class="credential-copy">I prefer shipping smaller slices with evidence rather than broad plans with no proof.</p>
        </div>
        <div class="credential-card">
            <div class="credential-title">Outside work</div>
            <div class="credential-value">Climbing and long walks</div>
            <p class="credential-copy">Usually with Ellie, the most food-motivated cocker spaniel in Yorkshire.</p>
        </div>
    </div>
</section>
