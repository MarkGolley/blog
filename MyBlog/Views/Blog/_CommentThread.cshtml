@model MyBlog.Models.CommentThreadViewModel

<div class="comment-thread" id="comment-@Model.Comment.Id">
    <div class="comment-item">
        <div class="comment-item-head">
            <div class="comment-meta">
                <strong>@Model.Comment.Author</strong> on @Model.Comment.PostedAt.ToString("dd MMMM yyyy 'at' HH:mm 'UTC'")
                @if (Model.TotalReplyCount > 0)
                {
                    <span class="reply-count"> - @Model.TotalReplyCount @(Model.TotalReplyCount == 1 ? "reply" : "replies")</span>
                }
            </div>

            <form asp-controller="Blog" asp-action="ToggleCommentLike" method="post" class="like-form like-form-inline comment-like-form">
                <input type="hidden" name="commentId" value="@Model.Comment.Id" />
                <input type="hidden" name="postId" value="@Model.Comment.PostId" />
                <input type="hidden" name="returnSlug" value="@Model.Comment.PostId" />
                <input type="hidden" name="returnAnchor" value="comment-@Model.Comment.Id" />
                <button
                    type="submit"
                    class="like-btn icon-like-btn like-btn-sm @(Model.IsLikedByCurrentVisitor ? "liked" : string.Empty)"
                    aria-label="@(Model.IsLikedByCurrentVisitor ? "Unlike this comment" : "Like this comment")">
                    <span class="like-symbol">@Html.Raw(Model.IsLikedByCurrentVisitor ? "&#9829;" : "&#9825;")</span>
                    <span class="like-count">@Model.LikeCount</span>
                </button>
            </form>
        </div>

        <div class="comment-body">
            @Html.Raw(Model.ContentHtml)
        </div>
    </div>

    @if (Model.Depth < MyBlog.Services.CommentService.MaxThreadDepth)
    {
        <details class="reply-toggle">
            <summary>Reply</summary>
            <form asp-controller="Blog" asp-action="AddComment" method="post" class="contact-form reply-form">
                <input type="hidden" name="PostId" value="@Model.Comment.PostId" />
                <input type="hidden" name="ParentCommentId" value="@Model.Comment.Id" />

                <label>Name</label>
                <input type="text" name="Author" placeholder="Your name" required />

                <label>Reply</label>
                <textarea name="Content" rows="3" placeholder="Write your reply..." required></textarea>

                <button type="submit">Submit reply</button>
            </form>
        </details>
    }
    else
    {
        <div class="reply-limit-note">Max thread depth reached.</div>
    }

    @if (Model.Replies.Any())
    {
        <details class="thread-toggle" data-thread-toggle open>
            <summary>Show thread (@Model.TotalReplyCount @(Model.TotalReplyCount == 1 ? "reply" : "replies"))</summary>
            <div class="comment-replies">
                @foreach (var reply in Model.Replies)
                {
                    <partial name="_CommentThread" model="reply" />
                }
            </div>
        </details>
    }
</div>
