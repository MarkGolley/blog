@model MyBlog.Models.BlogPostViewModel

@{
    var commentBanner = TempData["CommentBanner"]?.ToString();
    var commentStatus = Context.Request.Query["commentStatus"].ToString();
    if (string.IsNullOrWhiteSpace(commentBanner) &&
        string.Equals(commentStatus, "moderated", StringComparison.OrdinalIgnoreCase))
    {
        commentBanner = "Your comment was not published because it did not meet our moderation standards.";
    }

    ViewData["Title"] = Model.Post.Title;
    ViewData["MetaDescription"] = $"Read \"{Model.Post.Title}\" on MyBlog.";
    ViewData["CanonicalPath"] = $"/blog/{Uri.EscapeDataString(Model.Post.Id)}";
    ViewData["OgType"] = "article";
}

<section aria-labelledby="post-title" data-reveal>
    <h2 id="post-title">@Model.Post.Title</h2>
    <div class="post-meta">
        @Model.Post.DatePosted.ToString("dd MMMM yyyy")
        <span class="meta-dot">•</span>
        @Model.Post.ReadingTimeMinutes min read
    </div>
    @if (Model.Post.Tags.Any())
    {
        <div class="tag-list tag-list-inline">
            @foreach (var tag in Model.Post.Tags)
            {
                <a class="tag-chip tag-chip-link" asp-controller="Blog" asp-action="Index" asp-route-tag="@tag">@tag</a>
            }
        </div>
    }
    <div class="post-content">
        @Html.Raw(Model.Post.Content)
    </div>
    <form id="post-like-bottom" asp-controller="Blog" asp-action="TogglePostLike" method="post" class="like-form post-like-form post-like-form-bottom">
        <input type="hidden" name="postId" value="@Model.Post.Id" />
        <input type="hidden" name="returnSlug" value="@Model.Post.Id" />
        <input type="hidden" name="returnAnchor" value="post-like-bottom" />
        <button
            type="submit"
            class="like-btn icon-like-btn @(Model.IsPostLikedByCurrentVisitor ? "liked" : string.Empty)"
            aria-label="@(Model.IsPostLikedByCurrentVisitor ? "Unlike this post" : "Like this post")">
            <span class="like-symbol">@Html.Raw(Model.IsPostLikedByCurrentVisitor ? "&#9829;" : "&#9825;")</span>
            <span class="like-count">@Model.PostLikeCount</span>
        </button>
    </form>

    <partial name="_SubscribeForm" model="(Context.Request.Path + Context.Request.QueryString).ToString()" />
</section>

@if (Model.RelatedPosts.Any())
{
    <section aria-labelledby="related-posts-title" data-reveal>
        <h2 id="related-posts-title">Related posts</h2>
        <div class="blog-list related-posts-list">
            @foreach (var related in Model.RelatedPosts)
            {
                <article class="blog-post">
                    <div class="blog-post-main">
                        <h3>
                            <a asp-controller="Blog" asp-action="Post" asp-route-slug="@related.Id">@related.Title</a>
                        </h3>
                        <div class="post-meta">
                            @related.DatePosted.ToString("dd MMMM yyyy")
                            <span class="meta-dot">•</span>
                            @related.ReadingTimeMinutes min read
                        </div>
                        @if (related.Tags.Any())
                        {
                            <div class="tag-list">
                                @foreach (var tag in related.Tags.Take(4))
                                {
                                    <span class="tag-chip">@tag</span>
                                }
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    </section>
}

<section id="comments" aria-labelledby="comments-title" data-reveal>
    <h2 id="comments-title">Comments</h2>
    @if (Model.Comments != null && Model.Comments.Any())
    {
        <div class="thread-controls">
            <button type="button" class="thread-control-btn" data-thread-action="expand">Expand all threads</button>
            <button type="button" class="thread-control-btn" data-thread-action="collapse">Collapse all threads</button>
        </div>

        <div class="comment-list">
            @foreach (var thread in Model.Comments)
            {
                <partial name="_CommentThread" model="thread" />
            }
        </div>
    }
    else
    {
        <p>No comments yet.</p>
    }
</section>

<section aria-labelledby="add-comment-title" data-reveal>
    <h2 id="add-comment-title">Add a comment</h2>
    @if (!string.IsNullOrWhiteSpace(commentBanner))
    {
        <p class="moderation-notice" role="status">@commentBanner</p>
    }
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
    <form asp-controller="Blog" asp-action="AddComment" method="post" class="contact-form">
        <input type="hidden" name="PostId" value="@Model.Post.Id" />
        <input type="hidden" name="ParentCommentId" value="" />
        <div class="honeypot-field" aria-hidden="true">
            <label for="hp-root">Leave this field empty</label>
            <input type="text" id="hp-root" name="__hp" tabindex="-1" autocomplete="off" />
        </div>

        <label for="author-root">Name</label>
        <input type="text" id="author-root" name="Author" placeholder="Your name" required />

        <label for="content-root">Comment</label>
        <textarea id="content-root" name="Content" rows="4" placeholder="Share your thoughts..." required></textarea>

        <button type="submit">Submit comment</button>
    </form>
</section>
