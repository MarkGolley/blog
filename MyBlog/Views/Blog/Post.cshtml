@model MyBlog.Models.BlogPostViewModel

@{
    ViewData["Title"] = Model.Post.Title;
}

<section aria-labelledby="post-title">
    <h2 id="post-title">@Model.Post.Title</h2>
    <div class="post-meta">@Model.Post.DatePosted.ToString("dd MMMM yyyy")</div>
    <div class="post-content">
        @Html.Raw(Model.Post.Content)
    </div>
</section>

<section aria-labelledby="comments-title">
    <h2 id="comments-title">Comments</h2>

    @if (Model.Comments != null && Model.Comments.Any())
    {
        <div class="thread-controls">
            <button type="button" class="thread-control-btn" data-thread-action="expand">Expand all threads</button>
            <button type="button" class="thread-control-btn" data-thread-action="collapse">Collapse all threads</button>
        </div>

        <div class="comment-list">
            @foreach (var thread in Model.Comments)
            {
                <partial name="_CommentThread" model="thread" />
            }
        </div>
    }
    else
    {
        <p>No comments yet.</p>
    }
</section>

<section aria-labelledby="add-comment-title">
    <h2 id="add-comment-title">Add a comment</h2>
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
    <form asp-controller="Blog" asp-action="AddComment" method="post" class="contact-form">
        <input type="hidden" name="PostId" value="@Model.Post.Id" />
        <input type="hidden" name="ParentCommentId" value="" />

        <label for="author-root">Name</label>
        <input type="text" id="author-root" name="Author" placeholder="Your name" required />

        <label for="content-root">Comment</label>
        <textarea id="content-root" name="Content" rows="4" placeholder="Share your thoughts..." required></textarea>

        <button type="submit">Submit comment</button>
    </form>
</section>
