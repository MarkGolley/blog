@model MyBlog.Models.BlogIndexViewModel

@{
    ViewData["Title"] = "Articles";
    ViewData["MetaDescription"] = "Browse engineering articles from Mark Golley on ASP.NET Core, testing, cloud delivery, and practical software lessons.";
    ViewData["CanonicalPath"] = "/blog";
}

<section id="blogs" class="blog-page" aria-labelledby="blogs-title">
    <header class="blog-hero" data-reveal>
        <p class="hero-kicker">Engineering Writing</p>
        <h1 id="blogs-title">Articles</h1>
        <p class="section-intro">Practical writing on ASP.NET Core, testing, cloud delivery, and the engineering tradeoffs behind this site.</p>
        <p class="blog-stat-inline" aria-label="Post summary">
            @Model.TotalPostCount posts
            <span aria-hidden="true">•</span>
            @Model.FilteredPostCount visible
            <span aria-hidden="true">•</span>
            @Model.AvailableTags.Count topics
        </p>
        <div class="blog-stat-grid">
            <article class="metric-card">
                <p class="metric-value">@Model.TotalPostCount</p>
                <p class="metric-label">Total published posts</p>
            </article>
            <article class="metric-card">
                <p class="metric-value">@Model.FilteredPostCount</p>
                <p class="metric-label">Matching current filter</p>
            </article>
            <article class="metric-card">
                <p class="metric-value">@Model.AvailableTags.Count</p>
                <p class="metric-label">Topics you can explore</p>
            </article>
        </div>
    </header>

    <form method="get" asp-controller="Blog" asp-action="Index" class="blog-filter-form blog-filter-card" data-reveal>
        <div class="blog-filter-row">
            <input
                type="search"
                name="q"
                value="@Model.SearchQuery"
                placeholder="Search posts..."
                aria-label="Search blog posts" />

            <select name="tag" aria-label="Filter by tag">
                <option value="">All topics</option>
                @foreach (var tag in Model.AvailableTags)
                {
                    if (string.Equals(Model.SelectedTag, tag, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@tag" selected>@tag</option>
                    }
                    else
                    {
                        <option value="@tag">@tag</option>
                    }
                }
            </select>

            <button type="submit">Apply filters</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery) || !string.IsNullOrWhiteSpace(Model.SelectedTag))
            {
                <a class="blog-filter-reset" asp-controller="Blog" asp-action="Index">Reset</a>
            }
        </div>
    </form>

    <p class="blog-results-summary" data-reveal>
        Showing @Model.FilteredPostCount of @Model.TotalPostCount posts.
    </p>

    <div class="pinned-posts-block" data-reveal>
        <h3 class="blog-subtitle">Featured articles</h3>
        @if (Model.FeaturedPosts.Any())
        {
            <div class="blog-list pinned-blog-list">
                @foreach (var item in Model.FeaturedPosts)
                {
                    <article class="blog-post pinned-blog-post" id="featured-post-@item.Post.Id" data-reveal>
                        <div class="blog-post-row">
                            <div class="blog-post-main">
                                <h3>
                                    <a class="post-title-link" asp-controller="Blog" asp-action="Post" asp-route-slug="@item.Post.Id">
                                        @item.Post.Title
                                    </a>
                                </h3>
                                <div class="post-meta">
                                    <span class="pinned-badge">Featured</span>
                                    @item.Post.DatePosted.ToString("dd MMMM yyyy")
                                    <span class="meta-dot">•</span>
                                    @item.Post.ReadingTimeMinutes min read
                                </div>
                                @if (item.Post.Tags.Any())
                                {
                                    <div class="tag-list">
                                        @foreach (var tag in item.Post.Tags.Take(4))
                                        {
                                            <span class="tag-chip">@tag</span>
                                        }
                                    </div>
                                }
                            </div>
                            <form asp-controller="Blog" asp-action="TogglePostLike" method="post" class="like-form like-form-inline" data-like-async="true">
                                <input type="hidden" name="postId" value="@item.Post.Id" />
                                <input type="hidden" name="returnTo" value="index" />
                                <input type="hidden" name="returnAnchor" value="featured-post-@item.Post.Id" />
                                <button
                                    type="submit"
                                    class="like-btn icon-like-btn like-btn-sm @(item.IsLikedByCurrentVisitor ? "liked" : string.Empty)"
                                    aria-label="@(item.IsLikedByCurrentVisitor ? "Unlike this post" : "Like this post")">
                                    <span class="like-symbol">@Html.Raw(item.IsLikedByCurrentVisitor ? "&#9829;" : "&#9825;")</span>
                                    <span class="like-count">@item.LikeCount</span>
                                </button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="section-intro">No featured articles match the current filter.</p>
        }
    </div>

    <h3 class="blog-subtitle" data-reveal>All articles</h3>

    <div class="blog-list">
        @if (Model.Posts.Any())
        {
            @foreach (var item in Model.Posts)
            {
                <article class="blog-post" id="post-@item.Post.Id" data-reveal>
                    <div class="blog-post-row">
                        <div class="blog-post-main">
                            <h3>
                                <a class="post-title-link" asp-controller="Blog" asp-action="Post" asp-route-slug="@item.Post.Id">
                                    @item.Post.Title
                                </a>
                            </h3>
                            <div class="post-meta">
                                @item.Post.DatePosted.ToString("dd MMMM yyyy")
                                <span class="meta-dot">•</span>
                                @item.Post.ReadingTimeMinutes min read
                            </div>
                            @if (item.Post.Tags.Any())
                            {
                                <div class="tag-list">
                                    @foreach (var tag in item.Post.Tags.Take(4))
                                    {
                                        <span class="tag-chip">@tag</span>
                                    }
                                </div>
                            }
                        </div>
                        <form asp-controller="Blog" asp-action="TogglePostLike" method="post" class="like-form like-form-inline" data-like-async="true">
                            <input type="hidden" name="postId" value="@item.Post.Id" />
                            <input type="hidden" name="returnTo" value="index" />
                            <input type="hidden" name="returnAnchor" value="post-@item.Post.Id" />
                            <button
                                type="submit"
                                class="like-btn icon-like-btn like-btn-sm @(item.IsLikedByCurrentVisitor ? "liked" : string.Empty)"
                                aria-label="@(item.IsLikedByCurrentVisitor ? "Unlike this post" : "Like this post")">
                                <span class="like-symbol">@Html.Raw(item.IsLikedByCurrentVisitor ? "&#9829;" : "&#9825;")</span>
                                <span class="like-count">@item.LikeCount</span>
                            </button>
                        </form>
                    </div>
                </article>
            }
        }
        else
        {
            <p>No blog posts found.</p>
        }
    </div>

    <partial name="_SubscribeForm" model="(Context.Request.Path + Context.Request.QueryString).ToString()" />
</section>
