@model ModerationPlaygroundViewModel
@{
    ViewData["Title"] = "AI Experiments";
    ViewData["MetaDescription"] =
        "Applied AI experiments from Mark Golley focused on practical safety checks and real-world behavior.";
    ViewData["CanonicalPath"] = "/ai-experiments";
}

<section aria-labelledby="ai-experiments-title" class="portfolio-hero" data-reveal>
    <p class="hero-kicker">Applied AI</p>
    <h1 id="ai-experiments-title">Small AI experiments you can run directly.</h1>
    <p class="section-intro">
        These are lightweight checks from the same stack used on this site.
    </p>
    <div class="hero-actions">
        <a class="btn btn-primary" asp-controller="Projects" asp-action="Index">View projects</a>
        <a class="btn btn-secondary" asp-controller="Blog" asp-action="Index">Read blog</a>
    </div>
</section>

<section aria-labelledby="moderation-playground-title" data-reveal>
    <h2 id="moderation-playground-title">Moderation playground</h2>
    <p class="section-intro">
        Paste sample comment text to see <code>Allow</code>, <code>Block</code>, or <code>ManualReview</code>.
    </p>
    <p class="policy-note">Manual review is the safe fallback when no confident automated decision is available.</p>

    <form method="post" asp-action="RunModeration" class="contact-form">
        @Html.AntiForgeryToken()
        <label asp-for="InputText">Comment text</label>
        <textarea asp-for="InputText" rows="4" maxlength="2000" placeholder="Type or paste a comment sample..."></textarea>
        <span asp-validation-for="InputText" class="text-danger"></span>
        <input type="hidden" asp-for="PromptRiskInput" />

        <button type="submit">Run moderation check</button>
    </form>

    @if (Model.HasModerationResult)
    {
        var resultClass = Model.Decision == ModerationDecision.Allow
            ? "moderation-demo-result safe"
            : Model.Decision == ModerationDecision.Block
                ? "moderation-demo-result blocked"
                : "moderation-demo-result neutral";

        <div class="@resultClass">
            <p class="moderation-demo-title">@Model.ResultTitle</p>
            <p>@Model.ResultMessage</p>
            <p class="moderation-demo-meta">Reason: @Model.ReasonCode</p>
            @if (Model.FlaggedByModel.HasValue)
            {
                <p class="moderation-demo-meta">Model flagged: @(Model.FlaggedByModel.Value ? "Yes" : "No")</p>
            }
            @if (Model.LatencyMs.HasValue)
            {
                <p class="moderation-demo-meta">Latency: @Model.LatencyMs.Value ms</p>
            }
        </div>
    }
</section>

<section aria-labelledby="prompt-risk-scanner-title" data-reveal>
    <h2 id="prompt-risk-scanner-title">Prompt risk scanner</h2>
    <p class="section-intro">
        Fast heuristic scan for common injection and exfiltration patterns.
    </p>

    <form method="post" asp-action="RunPromptRisk" class="contact-form">
        @Html.AntiForgeryToken()
        <label asp-for="PromptRiskInput">Prompt text</label>
        <textarea asp-for="PromptRiskInput" rows="4" maxlength="2000" placeholder="Type or paste a prompt..."></textarea>
        <span asp-validation-for="PromptRiskInput" class="text-danger"></span>
        <input type="hidden" asp-for="InputText" />
        <button type="submit">Scan prompt risk</button>
    </form>

    @if (Model.HasPromptRiskResult)
    {
        var riskClass = Model.PromptRiskLevel switch
        {
            "Critical" => "prompt-risk-result risk-critical",
            "High" => "prompt-risk-result risk-high",
            "Medium" => "prompt-risk-result risk-medium",
            _ => "prompt-risk-result risk-low"
        };

        <div class="@riskClass">
            <p class="moderation-demo-title">@Model.PromptRiskLevel risk (@Model.PromptRiskScore/100)</p>
            <p>@Model.PromptRiskSummary</p>
            <p class="moderation-demo-meta">Recommendation: @Model.PromptRiskRecommendation</p>

            @if (Model.PromptRiskMatchedRules.Count > 0)
            {
                <ul class="case-list prompt-risk-rules">
                    @foreach (var rule in Model.PromptRiskMatchedRules)
                    {
                        <li>@rule</li>
                    }
                </ul>
            }
        </div>
    }
</section>

<section aria-labelledby="experiment-roadmap-title" data-reveal>
    <h2 id="experiment-roadmap-title">Experiment roadmap</h2>
    <p class="section-intro">Current direction and next implementation steps.</p>

    <div class="case-template-grid">
        <partial name="_CaseStudyTemplate" model='new CaseStudyTemplateViewModel
        {
            Title = "Prompt Injection Defense Bench",
            Status = "In progress",
            OneLiner = "Run attack prompts against current safeguards and track escapes.",
            WhyItMatters = "Makes prompt hardening measurable instead of guesswork.",
            TechnicalScope = new[]
            {
                "Maintain a compact attack suite with realistic misuse patterns.",
                "Compare current defenses against previous run output.",
                "Track escaped prompts and categorize failure type.",
                "Document one mitigation per escaped case."
            },
            ProofChecklist = new[]
            {
                "Run report with escaped count and risk level.",
                "Examples of escaped prompts with mitigation notes.",
                "Regression tests for fixed cases."
            },
            WhatItShows = "Practical safety iteration with visible before/after behavior.",
            NextMilestone = "Publish first escaped-prompt review and mitigation patch."
        }' />

        <partial name="_CaseStudyTemplate" model='new CaseStudyTemplateViewModel
        {
            Title = "Prompt Repair Assistant",
            Status = "Planned",
            OneLiner = "Suggest safer rewrites when prompt risk is medium/high.",
            WhyItMatters = "Turns risk detection into an actionable UX loop people can actually use.",
            TechnicalScope = new[]
            {
                "Map risky phrases to safe rewrite templates.",
                "Preserve user intent while removing attack patterns.",
                "Attach short explanation of what was changed.",
                "Measure drop in risk score after rewrite."
            },
            ProofChecklist = new[]
            {
                "Before/after prompt pairs with risk deltas.",
                "Automated tests for rewrite stability.",
                "False-positive review notes."
            },
            WhatItShows = "Ability to build user-facing safety tooling, not just backend checks.",
            NextMilestone = "Implement initial rewrite rules and validation tests."
        }' />
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
